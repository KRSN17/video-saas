<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <%- include('partials/head') %>
  <style>
    :root {
      --bg-primary: #0a0a1a;
      --bg-secondary: #1a1a2e;
      --accent-gradient: linear-gradient(135deg, #6c5ce7, #a855f7, #ec4899);
      --glass-bg: rgba(255, 255, 255, 0.04);
      --glass-border: rgba(255, 255, 255, 0.08);
      --font-main: 'Manrope', 'Gordita', sans-serif;
    }

    * { font-family: var(--font-main); }

    body {
      background: var(--bg-primary);
      color: #e2e8f0;
      overflow-x: hidden;
    }

    /* ── Navbar ── */
    .navbar-videogen {
      background: rgba(10, 10, 26, 0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--glass-border);
      padding: 16px 0;
      transition: all 0.3s ease;
    }
    .navbar-videogen.scrolled { box-shadow: 0 4px 30px rgba(0,0,0,0.4); }
    .navbar-brand-text {
      font-weight: 800;
      font-size: 1.5rem;
      background: var(--accent-gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .nav-link {
      color: rgba(255,255,255,0.7) !important;
      font-weight: 500;
      font-size: 15px;
      transition: color 0.3s;
    }
    .nav-link:hover { color: #fff !important; }
    .btn-nav-login {
      border: 1px solid rgba(168,85,247,0.5);
      color: #a855f7 !important;
      border-radius: 8px;
      padding: 8px 20px;
      font-weight: 600;
      transition: all 0.3s;
    }
    .btn-nav-login:hover {
      background: rgba(168,85,247,0.15);
      border-color: #a855f7;
    }
    .btn-nav-register {
      background: var(--accent-gradient);
      color: #fff !important;
      border: none;
      border-radius: 8px;
      padding: 8px 24px;
      font-weight: 600;
      transition: all 0.3s;
    }
    .btn-nav-register:hover { opacity: 0.9; transform: translateY(-1px); }

    /* ── Hero ── */
    .hero-section {
      min-height: 100vh;
      display: flex;
      align-items: center;
      background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
      position: relative;
    }
    .hero-section::before {
      content: '';
      position: absolute;
      top: 20%;
      left: 50%;
      transform: translateX(-50%);
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(168,85,247,0.12) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-title {
      font-size: clamp(2.5rem, 5vw, 4.2rem);
      font-weight: 800;
      line-height: 1.15;
      margin-bottom: 1.5rem;
    }
    .gradient-text {
      background: var(--accent-gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-subtitle {
      font-size: 1.15rem;
      color: rgba(255,255,255,0.6);
      max-width: 560px;
      margin: 0 auto 2.5rem;
      line-height: 1.7;
    }
    .btn-glow {
      background: var(--accent-gradient);
      color: #fff;
      border: none;
      padding: 16px 40px;
      border-radius: 12px;
      font-size: 1.05rem;
      font-weight: 700;
      position: relative;
      overflow: hidden;
      transition: all 0.4s ease;
      box-shadow: 0 0 30px rgba(168,85,247,0.35), 0 0 60px rgba(168,85,247,0.15);
    }
    .btn-glow:hover {
      transform: translateY(-3px);
      box-shadow: 0 0 40px rgba(168,85,247,0.5), 0 0 80px rgba(168,85,247,0.25);
      color: #fff;
    }
    .btn-glow::after {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: linear-gradient(45deg, transparent, rgba(255,255,255,0.1), transparent);
      transform: rotate(45deg);
      transition: all 0.6s;
    }
    .btn-glow:hover::after { left: 100%; }

    /* ── Glass card ── */
    .glass-card {
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: 16px;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      transition: all 0.4s ease;
    }
    .glass-card:hover {
      border-color: rgba(168,85,247,0.3);
      transform: translateY(-6px);
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }

    /* ── Features ── */
    .features-section {
      background: var(--bg-secondary);
      padding: 100px 0;
      position: relative;
    }
    .features-section::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(168,85,247,0.3), transparent);
    }
    .feature-icon-wrap {
      width: 64px;
      height: 64px;
      border-radius: 16px;
      background: linear-gradient(135deg, rgba(108,92,231,0.2), rgba(168,85,247,0.2));
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.25rem;
    }
    .feature-icon-wrap i {
      font-size: 1.5rem;
      background: var(--accent-gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .section-title {
      font-size: 2.2rem;
      font-weight: 800;
      margin-bottom: 1rem;
    }
    .section-subtitle {
      color: rgba(255,255,255,0.5);
      font-size: 1.05rem;
      max-width: 500px;
      margin: 0 auto 3.5rem;
    }

    /* ── Pricing ── */
    .pricing-section {
      background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);
      padding: 100px 0;
    }
    .pricing-card { padding: 2.5rem 2rem; text-align: center; }
    .pricing-card .price {
      font-size: 3rem;
      font-weight: 800;
      margin: 1rem 0 0.25rem;
    }
    .pricing-card .credits {
      color: rgba(255,255,255,0.5);
      font-size: 0.95rem;
      margin-bottom: 1.5rem;
    }
    .pricing-card ul {
      list-style: none;
      padding: 0;
      margin-bottom: 2rem;
    }
    .pricing-card ul li {
      padding: 8px 0;
      color: rgba(255,255,255,0.7);
      font-size: 0.95rem;
    }
    .pricing-card ul li i { color: #a855f7; margin-right: 8px; }
    .badge-popular {
      background: var(--accent-gradient);
      color: #fff;
      font-size: 0.75rem;
      font-weight: 700;
      padding: 4px 14px;
      border-radius: 20px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .popular-card {
      border-color: rgba(168,85,247,0.4) !important;
      box-shadow: 0 0 40px rgba(168,85,247,0.12);
      position: relative;
    }
    .popular-card::before {
      content: '';
      position: absolute;
      inset: -1px;
      border-radius: 16px;
      padding: 1px;
      background: var(--accent-gradient);
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      pointer-events: none;
    }
    .btn-pricing {
      width: 100%;
      padding: 12px;
      border-radius: 10px;
      font-weight: 700;
      border: 1px solid rgba(168,85,247,0.5);
      color: #a855f7;
      background: transparent;
      transition: all 0.3s;
    }
    .btn-pricing:hover {
      background: rgba(168,85,247,0.15);
      color: #c084fc;
    }
    .btn-pricing-primary {
      background: var(--accent-gradient) !important;
      border: none !important;
      color: #fff !important;
    }
    .btn-pricing-primary:hover { opacity: 0.9; }

    /* ── FAQ ── */
    .faq-section {
      background: var(--bg-primary);
      padding: 100px 0;
    }
    .accordion-item {
      background: var(--glass-bg) !important;
      border: 1px solid var(--glass-border) !important;
      border-radius: 12px !important;
      margin-bottom: 12px;
      overflow: hidden;
    }
    .accordion-button {
      background: transparent !important;
      color: #e2e8f0 !important;
      font-weight: 600;
      font-size: 1rem;
      box-shadow: none !important;
      padding: 1.25rem 1.5rem;
    }
    .accordion-button::after { filter: invert(1) brightness(0.7); }
    .accordion-button:not(.collapsed)::after { filter: invert(1) brightness(1); }
    .accordion-body {
      color: rgba(255,255,255,0.6);
      padding: 0 1.5rem 1.25rem;
      line-height: 1.7;
    }

    /* ── Animations ── */
    .fade-up {
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .fade-up.visible {
      opacity: 1;
      transform: translateY(0);
    }

    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-10px); }
    }
  </style>
</head>
<body>

  <!-- ══════ NAVBAR ══════ -->
  <nav class="navbar navbar-expand-lg navbar-dark navbar-videogen fixed-top">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center" href="/">
        <i class="fa-solid fa-play-circle me-2" style="font-size:1.6rem; color:#a855f7;"></i>
        <span class="navbar-brand-text">VideoGen AI</span>
      </a>
      <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navMain">
        <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link" href="#features">Features</a></li>
          <li class="nav-item"><a class="nav-link" href="#pricing">Pricing</a></li>
          <li class="nav-item"><a class="nav-link" href="#faq">FAQ</a></li>
        </ul>
        <div class="d-flex gap-2">
          <a href="/login" class="btn btn-nav-login">Login</a>
          <a href="/register" class="btn btn-nav-register">Register</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- ══════ HERO ══════ -->
  <section class="hero-section">
    <div class="container text-center position-relative" style="z-index:2;">
      <div class="fade-up">
        <span class="badge rounded-pill mb-4" style="background:rgba(168,85,247,0.15); color:#c084fc; font-size:0.85rem; padding:8px 20px; font-weight:600;">
          <i class="fa-solid fa-sparkles me-1"></i> AI-Powered Video Generation
        </span>
        <h1 class="hero-title">
          Create Stunning Videos<br><span class="gradient-text">with AI</span>
        </h1>
        <p class="hero-subtitle">
          Powered by fal.ai &mdash; Generate, merge, and download professional videos in seconds.
          Transform your ideas into cinematic reality.
        </p>
        <a href="/register" class="btn btn-glow">
          <i class="fa-solid fa-rocket me-2"></i>Get Started Free
        </a>
        <p class="mt-3" style="color:rgba(255,255,255,0.35); font-size:0.85rem;">No credit card required &bull; 5 free credits</p>
      </div>
    </div>
  </section>

  <!-- ══════ FEATURES ══════ -->
  <section class="features-section" id="features">
    <div class="container">
      <div class="text-center fade-up">
        <h2 class="section-title">Powerful <span class="gradient-text">Features</span></h2>
        <p class="section-subtitle">Everything you need to create professional video content at scale.</p>
      </div>
      <div class="row g-4">
        <!-- Text-to-Video -->
        <div class="col-lg-3 col-md-6 fade-up">
          <div class="glass-card p-4 h-100">
            <div class="feature-icon-wrap">
              <i class="fa-solid fa-pen-fancy"></i>
            </div>
            <h5 style="font-weight:700; margin-bottom:0.75rem;">Text-to-Video</h5>
            <p style="color:rgba(255,255,255,0.55); font-size:0.92rem; line-height:1.7; margin:0;">
              Describe your vision in text and watch AI bring it to life as a stunning video. Simple prompts, cinematic results.
            </p>
          </div>
        </div>
        <!-- Image-to-Video -->
        <div class="col-lg-3 col-md-6 fade-up">
          <div class="glass-card p-4 h-100">
            <div class="feature-icon-wrap">
              <i class="fa-solid fa-image"></i>
            </div>
            <h5 style="font-weight:700; margin-bottom:0.75rem;">Image-to-Video</h5>
            <p style="color:rgba(255,255,255,0.55); font-size:0.92rem; line-height:1.7; margin:0;">
              Upload any image and transform it into a dynamic, animated video clip. Add motion to your still visuals.
            </p>
          </div>
        </div>
        <!-- Video Merging -->
        <div class="col-lg-3 col-md-6 fade-up">
          <div class="glass-card p-4 h-100">
            <div class="feature-icon-wrap">
              <i class="fa-solid fa-layer-group"></i>
            </div>
            <h5 style="font-weight:700; margin-bottom:0.75rem;">Video Merging</h5>
            <p style="color:rgba(255,255,255,0.55); font-size:0.92rem; line-height:1.7; margin:0;">
              Combine multiple generated clips into a seamless, polished final video. Perfect for storytelling and longer content.
            </p>
          </div>
        </div>
        <!-- Credit System -->
        <div class="col-lg-3 col-md-6 fade-up">
          <div class="glass-card p-4 h-100">
            <div class="feature-icon-wrap">
              <i class="fa-solid fa-coins"></i>
            </div>
            <h5 style="font-weight:700; margin-bottom:0.75rem;">Credit System</h5>
            <p style="color:rgba(255,255,255,0.55); font-size:0.92rem; line-height:1.7; margin:0;">
              Flexible pay-as-you-go credits. Top up when you need, track usage in real time, never pay for what you don't use.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ PRICING ══════ -->
  <section class="pricing-section" id="pricing">
    <div class="container">
      <div class="text-center fade-up">
        <h2 class="section-title">Simple <span class="gradient-text">Pricing</span></h2>
        <p class="section-subtitle">Choose the plan that works for you. Upgrade or downgrade anytime.</p>
      </div>
      <div class="row g-4 justify-content-center">
        <!-- Starter -->
        <div class="col-lg-4 col-md-6 fade-up">
          <div class="glass-card pricing-card h-100">
            <h5 style="font-weight:700; color:rgba(255,255,255,0.8);">Starter</h5>
            <div class="price gradient-text">$9</div>
            <div class="credits">50 Credits</div>
            <ul>
              <li><i class="fa-solid fa-check"></i> Text-to-Video generation</li>
              <li><i class="fa-solid fa-check"></i> Image-to-Video generation</li>
              <li><i class="fa-solid fa-check"></i> 720p video output</li>
              <li><i class="fa-solid fa-check"></i> Email support</li>
            </ul>
            <a href="/register" class="btn btn-pricing">Get Started</a>
          </div>
        </div>
        <!-- Pro -->
        <div class="col-lg-4 col-md-6 fade-up">
          <div class="glass-card pricing-card popular-card h-100">
            <span class="badge-popular">Popular</span>
            <h5 style="font-weight:700; color:#fff; margin-top:0.75rem;">Pro</h5>
            <div class="price gradient-text">$29</div>
            <div class="credits">200 Credits</div>
            <ul>
              <li><i class="fa-solid fa-check"></i> Everything in Starter</li>
              <li><i class="fa-solid fa-check"></i> Video merging</li>
              <li><i class="fa-solid fa-check"></i> 1080p video output</li>
              <li><i class="fa-solid fa-check"></i> Priority support</li>
            </ul>
            <a href="/register" class="btn btn-pricing btn-pricing-primary">Get Started</a>
          </div>
        </div>
        <!-- Enterprise -->
        <div class="col-lg-4 col-md-6 fade-up">
          <div class="glass-card pricing-card h-100">
            <h5 style="font-weight:700; color:rgba(255,255,255,0.8);">Enterprise</h5>
            <div class="price gradient-text">$79</div>
            <div class="credits">600 Credits</div>
            <ul>
              <li><i class="fa-solid fa-check"></i> Everything in Pro</li>
              <li><i class="fa-solid fa-check"></i> 4K video output</li>
              <li><i class="fa-solid fa-check"></i> API access</li>
              <li><i class="fa-solid fa-check"></i> Dedicated support</li>
            </ul>
            <a href="/register" class="btn btn-pricing">Get Started</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ FAQ ══════ -->
  <section class="faq-section" id="faq">
    <div class="container">
      <div class="text-center fade-up">
        <h2 class="section-title">Frequently Asked <span class="gradient-text">Questions</span></h2>
        <p class="section-subtitle">Have questions? We have answers.</p>
      </div>
      <div class="row justify-content-center">
        <div class="col-lg-8 fade-up">
          <div class="accordion" id="faqAccordion">
            <div class="accordion-item">
              <h2 class="accordion-header">
                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1" aria-expanded="true">
                  How does AI video generation work?
                </button>
              </h2>
              <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                <div class="accordion-body">
                  Our platform uses advanced AI models powered by fal.ai to generate high-quality videos from text descriptions or images. Simply provide a prompt or upload an image, and the AI creates a professional video clip in seconds.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                  What are credits and how do they work?
                </button>
              </h2>
              <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                <div class="accordion-body">
                  Credits are our simple usage currency. Each video generation consumes a certain number of credits based on the output quality and duration. You can purchase credit packs anytime and they never expire.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                  Can I merge multiple generated videos?
                </button>
              </h2>
              <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                <div class="accordion-body">
                  Yes! Pro and Enterprise plan users can combine multiple AI-generated clips into a single seamless video. This is perfect for creating longer-form content, stories, or presentations from individual scenes.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                  What video formats and resolutions are supported?
                </button>
              </h2>
              <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                <div class="accordion-body">
                  Videos are generated in MP4 format. Resolution depends on your plan: Starter supports 720p, Pro supports 1080p, and Enterprise supports up to 4K. All videos can be downloaded instantly after generation.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq5">
                  Is there a free trial?
                </button>
              </h2>
              <div id="faq5" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                <div class="accordion-body">
                  Yes! Every new account receives 5 free credits to try out the platform. No credit card required to sign up. You can generate your first AI video within minutes of creating your account.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ FOOTER ══════ -->
  <%- include('partials/footer') %>

  <!-- Scripts -->
  <script src="/assets/js/bootstrap.bundle.min.js"></script>
  <script>
    // Navbar scroll effect
    window.addEventListener('scroll', () => {
      document.querySelector('.navbar-videogen')
        .classList.toggle('scrolled', window.scrollY > 50);
    });

    // Intersection Observer for fade-up animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => entry.target.classList.add('visible'), i * 100);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

    // Smooth scrolling for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => {
        e.preventDefault();
        const target = document.querySelector(a.getAttribute('href'));
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  </script>
</body>
</html>
