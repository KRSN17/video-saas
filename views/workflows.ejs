<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <%- include('partials/head') %>
  <style>
    body {
      background: #0a0a14;
      margin: 0;
      font-family: 'Manrope', sans-serif;
    }
    .dash-main {
      margin-left: 260px;
      min-height: 100vh;
    }

    /* Top Bar */
    .dash-topbar {
      padding: 20px 32px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .dash-topbar .topbar-left {
      display: flex;
      align-items: center;
      gap: 20px;
    }
    .dash-topbar h1 {
      font-size: 22px;
      font-weight: 700;
      margin: 0;
      background: linear-gradient(135deg, #7b5cff, #c86dd7, #7b5cff);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: gradientShift 4s ease infinite;
    }
    @keyframes gradientShift {
      0%, 100% { background-position: 0% center; }
      50% { background-position: 100% center; }
    }
    .btn-new-workflow {
      padding: 9px 20px;
      border-radius: 10px;
      background: rgba(123,92,255,0.15);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(123,92,255,0.3);
      color: #c4b5fd;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.25s ease;
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: 'Manrope', sans-serif;
    }
    .btn-new-workflow:hover {
      background: rgba(123,92,255,0.3);
      border-color: rgba(123,92,255,0.5);
      color: #fff;
      transform: translateY(-1px);
      box-shadow: 0 4px 20px rgba(123,92,255,0.25);
    }
    .dash-topbar .user-info {
      display: flex;
      align-items: center;
      gap: 10px;
      color: rgba(255,255,255,0.6);
      font-size: 14px;
    }
    .dash-topbar .user-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: linear-gradient(135deg, #7b5cff, #c86dd7);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-weight: 700;
      font-size: 14px;
    }

    /* Content */
    .dash-content {
      padding: 28px 32px;
    }

    /* Stats Row */
    .stats-row {
      display: flex;
      gap: 16px;
      margin-bottom: 28px;
    }
    .stat-pill {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 12px;
      padding: 14px 22px;
      display: flex;
      align-items: center;
      gap: 12px;
      transition: all 0.2s ease;
    }
    .stat-pill:hover {
      border-color: rgba(123,92,255,0.2);
      background: rgba(123,92,255,0.04);
    }
    .stat-pill .stat-icon {
      width: 38px;
      height: 38px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
    }
    .stat-pill .stat-icon.purple {
      background: rgba(123,92,255,0.15);
      color: #a78bfa;
    }
    .stat-pill .stat-icon.green {
      background: rgba(34,197,94,0.15);
      color: #4ade80;
    }
    .stat-pill .stat-label {
      font-size: 11px;
      color: rgba(255,255,255,0.4);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .stat-pill .stat-value {
      font-size: 18px;
      font-weight: 700;
      color: #fff;
    }
    .stat-pill .stat-value.small-val {
      font-size: 14px;
      font-weight: 600;
    }

    /* Workflow Grid */
    .workflow-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    @media (max-width: 1200px) {
      .workflow-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .workflow-grid { grid-template-columns: 1fr; }
      .dash-main { margin-left: 0 !important; }
      .stats-row { flex-direction: column; }
    }

    /* Workflow Card */
    .wf-card {
      background: rgba(255,255,255,0.025);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      overflow: hidden;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      cursor: pointer;
    }
    .wf-card:hover {
      transform: translateY(-3px);
      border-color: rgba(123,92,255,0.25);
      box-shadow: 0 8px 32px rgba(0,0,0,0.3), 0 0 0 1px rgba(123,92,255,0.1);
    }
    .wf-card.active-card {
      border-color: rgba(34,197,94,0.3);
      box-shadow: 0 0 24px rgba(34,197,94,0.08);
    }
    .wf-card.active-card:hover {
      border-color: rgba(34,197,94,0.45);
      box-shadow: 0 8px 32px rgba(0,0,0,0.3), 0 0 24px rgba(34,197,94,0.12);
    }

    /* Preview Area */
    .wf-preview {
      height: 110px;
      margin: 12px 12px 0;
      border-radius: 10px;
      background:
        linear-gradient(45deg, rgba(255,255,255,0.02) 25%, transparent 25%),
        linear-gradient(-45deg, rgba(255,255,255,0.02) 25%, transparent 25%),
        linear-gradient(45deg, transparent 75%, rgba(255,255,255,0.02) 75%),
        linear-gradient(-45deg, transparent 75%, rgba(255,255,255,0.02) 75%);
      background-size: 20px 20px;
      background-position: 0 0, 0 10px, 10px -10px, -10px 0px;
      background-color: rgba(0,0,0,0.3);
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.25);
      font-size: 13px;
      font-weight: 500;
      gap: 8px;
      position: relative;
      overflow: hidden;
    }
    .wf-preview::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, rgba(123,92,255,0.06) 0%, transparent 70%);
      pointer-events: none;
    }
    .wf-preview .preview-stat {
      display: flex;
      align-items: center;
      gap: 5px;
    }
    .wf-preview .preview-dot {
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: rgba(255,255,255,0.2);
      margin: 0 4px;
    }

    /* Card Body */
    .wf-body {
      padding: 16px;
    }
    .wf-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 4px;
    }
    .wf-name {
      font-size: 15px;
      font-weight: 700;
      color: #fff;
      cursor: default;
      flex: 1;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      line-height: 1.4;
    }
    .wf-name-input {
      font-size: 15px;
      font-weight: 700;
      color: #fff;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(123,92,255,0.4);
      border-radius: 6px;
      padding: 2px 8px;
      outline: none;
      width: 100%;
      font-family: 'Manrope', sans-serif;
    }
    .wf-menu-btn {
      background: none;
      border: none;
      color: rgba(255,255,255,0.3);
      cursor: pointer;
      padding: 2px 6px;
      font-size: 16px;
      border-radius: 6px;
      transition: all 0.15s ease;
      flex-shrink: 0;
      line-height: 1;
    }
    .wf-menu-btn:hover {
      color: rgba(255,255,255,0.7);
      background: rgba(255,255,255,0.06);
    }
    .wf-menu {
      position: absolute;
      right: 16px;
      top: auto;
      background: rgba(20,20,36,0.95);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 10px;
      padding: 6px;
      min-width: 150px;
      z-index: 100;
      box-shadow: 0 12px 40px rgba(0,0,0,0.5);
      display: none;
    }
    .wf-menu.show { display: block; }
    .wf-menu-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 12px;
      border-radius: 7px;
      color: rgba(255,255,255,0.7);
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.15s ease;
      border: none;
      background: none;
      width: 100%;
      text-align: left;
      font-family: 'Manrope', sans-serif;
    }
    .wf-menu-item:hover {
      background: rgba(255,255,255,0.06);
      color: #fff;
    }
    .wf-menu-item.danger { color: #f87171; }
    .wf-menu-item.danger:hover { background: rgba(239,68,68,0.1); color: #ef4444; }
    .wf-menu-item i { width: 16px; text-align: center; font-size: 12px; }

    .wf-timestamp {
      font-size: 12px;
      color: rgba(255,255,255,0.3);
      margin-bottom: 14px;
    }
    .wf-actions {
      display: flex;
      gap: 8px;
    }
    .wf-btn {
      padding: 7px 14px;
      border-radius: 8px;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.04);
      color: rgba(255,255,255,0.6);
      font-family: 'Manrope', sans-serif;
    }
    .wf-btn:hover {
      background: rgba(255,255,255,0.08);
      color: #fff;
      border-color: rgba(255,255,255,0.15);
    }
    .wf-btn.primary {
      background: rgba(123,92,255,0.15);
      border-color: rgba(123,92,255,0.25);
      color: #c4b5fd;
    }
    .wf-btn.primary:hover {
      background: rgba(123,92,255,0.3);
      border-color: rgba(123,92,255,0.4);
      color: #fff;
    }
    .wf-btn.danger:hover {
      background: rgba(239,68,68,0.12);
      border-color: rgba(239,68,68,0.25);
      color: #f87171;
    }

    /* Active Badge */
    .wf-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 10px;
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      background: rgba(34,197,94,0.1);
      color: #4ade80;
      border: 1px solid rgba(34,197,94,0.15);
    }
    .wf-badge-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #4ade80;
      animation: pulse-dot 2s ease infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    /* Empty State */
    .empty-state {
      text-align: center;
      padding: 80px 20px;
    }
    .empty-state .empty-icon {
      width: 80px;
      height: 80px;
      border-radius: 24px;
      background: rgba(123,92,255,0.08);
      border: 1px solid rgba(123,92,255,0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 24px;
      font-size: 32px;
      color: rgba(123,92,255,0.5);
    }
    .empty-state h3 {
      font-size: 20px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 8px;
    }
    .empty-state p {
      color: rgba(255,255,255,0.4);
      font-size: 14px;
      margin-bottom: 28px;
    }
    .btn-create-first {
      padding: 12px 28px;
      border-radius: 12px;
      background: linear-gradient(135deg, #7b5cff, #c86dd7);
      border: none;
      color: #fff;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.25s ease;
      font-family: 'Manrope', sans-serif;
    }
    .btn-create-first:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(123,92,255,0.4);
    }

    /* Modal */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.6);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      z-index: 2000;
      display: none;
      align-items: center;
      justify-content: center;
    }
    .modal-overlay.show { display: flex; }
    .modal-box {
      background: rgba(18,18,32,0.97);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 18px;
      padding: 32px;
      width: 420px;
      max-width: 90vw;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
      animation: modalIn 0.25s ease;
    }
    @keyframes modalIn {
      from { transform: scale(0.95) translateY(10px); opacity: 0; }
      to { transform: scale(1) translateY(0); opacity: 1; }
    }
    .modal-box h3 {
      font-size: 18px;
      font-weight: 700;
      color: #fff;
      margin: 0 0 20px;
    }
    .modal-input {
      width: 100%;
      padding: 12px 16px;
      border-radius: 10px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      color: #fff;
      font-size: 14px;
      font-family: 'Manrope', sans-serif;
      outline: none;
      transition: border-color 0.2s ease;
      margin-bottom: 20px;
      box-sizing: border-box;
    }
    .modal-input:focus {
      border-color: rgba(123,92,255,0.5);
    }
    .modal-input::placeholder {
      color: rgba(255,255,255,0.25);
    }
    .modal-actions {
      display: flex;
      gap: 10px;
      justify-content: flex-end;
    }
    .modal-btn {
      padding: 10px 22px;
      border-radius: 10px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
      font-family: 'Manrope', sans-serif;
    }
    .modal-btn.cancel {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.6);
    }
    .modal-btn.cancel:hover {
      background: rgba(255,255,255,0.1);
      color: #fff;
    }
    .modal-btn.create {
      background: linear-gradient(135deg, #7b5cff, #c86dd7);
      border: none;
      color: #fff;
    }
    .modal-btn.create:hover {
      box-shadow: 0 4px 20px rgba(123,92,255,0.4);
      transform: translateY(-1px);
    }
    .modal-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none !important;
    }

    /* Loading skeleton */
    .skeleton-card {
      background: rgba(255,255,255,0.025);
      border: 1px solid rgba(255,255,255,0.04);
      border-radius: 16px;
      overflow: hidden;
    }
    .skeleton-preview {
      height: 110px;
      margin: 12px;
      border-radius: 10px;
      background: linear-gradient(90deg, rgba(255,255,255,0.03) 25%, rgba(255,255,255,0.06) 50%, rgba(255,255,255,0.03) 75%);
      background-size: 200% 100%;
      animation: shimmer 1.5s ease infinite;
    }
    .skeleton-line {
      height: 14px;
      margin: 0 16px 8px;
      border-radius: 6px;
      background: linear-gradient(90deg, rgba(255,255,255,0.03) 25%, rgba(255,255,255,0.06) 50%, rgba(255,255,255,0.03) 75%);
      background-size: 200% 100%;
      animation: shimmer 1.5s ease infinite;
    }
    .skeleton-line.short { width: 40%; margin-bottom: 16px; }
    @keyframes shimmer {
      0% { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }
  </style>
</head>
<body>
  <%- include('partials/sidebar') %>

  <div class="dash-main" style="margin-left:260px;min-height:100vh;">
    <!-- Top Bar -->
    <div class="dash-topbar">
      <div class="topbar-left">
        <h1>My Workflows</h1>
        <button class="btn-new-workflow" id="btnNewWorkflow">
          <i class="fa-solid fa-plus"></i>
          New Workflow
        </button>
      </div>
      <div class="user-info">
        <span id="userName">--</span>
        <div class="user-avatar" id="userAvatar">?</div>
      </div>
    </div>

    <!-- Content -->
    <div class="dash-content">
      <!-- Stats Row -->
      <div class="stats-row" id="statsRow" style="display:none;">
        <div class="stat-pill">
          <div class="stat-icon purple">
            <i class="fa-solid fa-folder-open"></i>
          </div>
          <div>
            <div class="stat-label">Total Workflows</div>
            <div class="stat-value" id="statTotal">0</div>
          </div>
        </div>
        <div class="stat-pill">
          <div class="stat-icon green">
            <i class="fa-solid fa-bolt"></i>
          </div>
          <div>
            <div class="stat-label">Active Workflow</div>
            <div class="stat-value small-val" id="statActive">None</div>
          </div>
        </div>
      </div>

      <!-- Loading Skeletons -->
      <div class="workflow-grid" id="skeletonGrid">
        <div class="skeleton-card"><div class="skeleton-preview"></div><div class="skeleton-line"></div><div class="skeleton-line short"></div></div>
        <div class="skeleton-card"><div class="skeleton-preview"></div><div class="skeleton-line"></div><div class="skeleton-line short"></div></div>
        <div class="skeleton-card"><div class="skeleton-preview"></div><div class="skeleton-line"></div><div class="skeleton-line short"></div></div>
      </div>

      <!-- Workflow Grid -->
      <div class="workflow-grid" id="workflowGrid" style="display:none;"></div>

      <!-- Empty State -->
      <div class="empty-state" id="emptyState" style="display:none;">
        <div class="empty-icon">
          <i class="fa-solid fa-diagram-project"></i>
        </div>
        <h3>No workflows yet</h3>
        <p>Create your first workflow to get started</p>
        <button class="btn-create-first" id="btnCreateFirst">
          <i class="fa-solid fa-plus" style="margin-right:8px;"></i>Create Workflow
        </button>
      </div>
    </div>
  </div>

  <!-- New Workflow Modal -->
  <div class="modal-overlay" id="newWorkflowModal">
    <div class="modal-box">
      <h3>Create New Workflow</h3>
      <input type="text" class="modal-input" id="newWorkflowName" placeholder="My Awesome Workflow" maxlength="100" autocomplete="off">
      <div class="modal-actions">
        <button class="modal-btn cancel" id="modalCancel">Cancel</button>
        <button class="modal-btn create" id="modalCreate">Create</button>
      </div>
    </div>
  </div>

  <script>
  (function() {
    var token = localStorage.getItem('token');
    if (!token) { window.location.href = '/login'; return; }

    var workflows = [];
    var activeWorkflowId = localStorage.getItem('activeWorkflowId') || null;

    // ----- User Info -----
    fetch('/api/auth/profile', { headers: { 'Authorization': 'Bearer ' + token } })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.user) {
          var name = data.user.name || data.user.email || 'User';
          document.getElementById('userName').textContent = name;
          document.getElementById('userAvatar').textContent = name.charAt(0).toUpperCase();
        }
      }).catch(function() {});

    // ----- Relative Time -----
    function timeAgo(dateStr) {
      var now = Date.now();
      var then = new Date(dateStr).getTime();
      var diff = Math.floor((now - then) / 1000);
      if (diff < 5) return 'just now';
      if (diff < 60) return diff + 's ago';
      var mins = Math.floor(diff / 60);
      if (mins < 60) return mins + (mins === 1 ? ' min ago' : ' mins ago');
      var hrs = Math.floor(mins / 60);
      if (hrs < 24) return hrs + (hrs === 1 ? ' hour ago' : ' hours ago');
      var days = Math.floor(hrs / 24);
      if (days < 30) return days + (days === 1 ? ' day ago' : ' days ago');
      var months = Math.floor(days / 30);
      return months + (months === 1 ? ' month ago' : ' months ago');
    }

    // ----- Load Workflows -----
    function loadWorkflows() {
      fetch('/api/workflows', { headers: { 'Authorization': 'Bearer ' + token } })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          workflows = data.workflows || data || [];
          if (!Array.isArray(workflows)) workflows = [];
          renderWorkflows();
        })
        .catch(function(err) {
          console.error('Failed to load workflows:', err);
          workflows = [];
          renderWorkflows();
        });
    }

    // ----- Render -----
    function renderWorkflows() {
      var grid = document.getElementById('workflowGrid');
      var skeleton = document.getElementById('skeletonGrid');
      var empty = document.getElementById('emptyState');
      var stats = document.getElementById('statsRow');

      skeleton.style.display = 'none';

      if (workflows.length === 0) {
        grid.style.display = 'none';
        empty.style.display = 'block';
        stats.style.display = 'none';
        return;
      }

      empty.style.display = 'none';
      grid.style.display = 'grid';
      stats.style.display = 'flex';

      // Stats
      document.getElementById('statTotal').textContent = workflows.length;
      var activeWf = workflows.find(function(w) { return w.id === activeWorkflowId; });
      document.getElementById('statActive').textContent = activeWf ? activeWf.name : 'None';

      // Cards
      grid.innerHTML = '';
      workflows.forEach(function(wf) {
        var isActive = wf.id === activeWorkflowId;
        var nodeCount = 0;
        var connCount = 0;
        try {
          var savedData = typeof wf.data === 'string' ? JSON.parse(wf.data) : wf.data;
          if (savedData) {
            nodeCount = (savedData.nodes || []).length;
            connCount = (savedData.connections || savedData.edges || []).length;
          }
        } catch(e) {}

        var card = document.createElement('div');
        card.className = 'wf-card' + (isActive ? ' active-card' : '');
        card.setAttribute('data-id', wf.id);
        card.innerHTML =
          '<div class="wf-preview">' +
            '<span class="preview-stat"><i class="fa-solid fa-circle-nodes" style="font-size:12px;"></i> ' + nodeCount + ' nodes</span>' +
            '<span class="preview-dot"></span>' +
            '<span class="preview-stat"><i class="fa-solid fa-link" style="font-size:11px;"></i> ' + connCount + ' connections</span>' +
          '</div>' +
          '<div class="wf-body">' +
            '<div class="wf-header">' +
              '<span class="wf-name" title="Double-click to rename">' + escapeHtml(wf.name) + '</span>' +
              '<button class="wf-menu-btn" title="More options">&ctdot;</button>' +
            '</div>' +
            '<div class="wf-timestamp">Updated ' + timeAgo(wf.updatedAt || wf.updated_at || wf.createdAt || wf.created_at) + '</div>' +
            '<div class="wf-actions">' +
              '<button class="wf-btn primary" data-action="open">Open</button>' +
              '<button class="wf-btn" data-action="duplicate">Duplicate</button>' +
              '<button class="wf-btn danger" data-action="delete">Delete</button>' +
            '</div>' +
            (isActive ? '<div class="wf-badge"><span class="wf-badge-dot"></span> Active</div>' : '') +
            '<div class="wf-menu">' +
              '<button class="wf-menu-item" data-action="rename"><i class="fa-solid fa-pen"></i> Rename</button>' +
              '<button class="wf-menu-item" data-action="duplicate"><i class="fa-solid fa-copy"></i> Duplicate</button>' +
              '<button class="wf-menu-item danger" data-action="delete"><i class="fa-solid fa-trash"></i> Delete</button>' +
            '</div>' +
          '</div>';
        grid.appendChild(card);
      });
    }

    function escapeHtml(str) {
      var div = document.createElement('div');
      div.textContent = str || '';
      return div.innerHTML;
    }

    // ----- Event Delegation -----
    document.getElementById('workflowGrid').addEventListener('click', function(e) {
      var btn = e.target.closest('[data-action]');
      var card = e.target.closest('.wf-card');
      var menuBtn = e.target.closest('.wf-menu-btn');

      if (menuBtn && card) {
        e.stopPropagation();
        closeAllMenus();
        var menu = card.querySelector('.wf-menu');
        if (menu) menu.classList.toggle('show');
        return;
      }

      if (!card) return;
      var id = card.getAttribute('data-id');
      var action = btn ? btn.getAttribute('data-action') : null;
      closeAllMenus();

      // Click anywhere on card (not a button) = open
      if (!action) {
        localStorage.setItem('activeWorkflowId', id);
        window.location.href = '/workflow?id=' + id;
        return;
      }

      if (action === 'open') {
        localStorage.setItem('activeWorkflowId', id);
        window.location.href = '/workflow?id=' + id;
      } else if (action === 'duplicate') {
        duplicateWorkflow(id);
      } else if (action === 'delete') {
        deleteWorkflow(id);
      } else if (action === 'rename') {
        startRename(card, id);
      }
    });

    // Inline rename on double-click
    document.getElementById('workflowGrid').addEventListener('dblclick', function(e) {
      var nameEl = e.target.closest('.wf-name');
      var card = e.target.closest('.wf-card');
      if (!nameEl || !card) return;
      var id = card.getAttribute('data-id');
      startRename(card, id);
    });

    function startRename(card, id) {
      var nameEl = card.querySelector('.wf-name');
      if (!nameEl || nameEl.style.display === 'none') return;
      var currentName = nameEl.textContent;
      nameEl.style.display = 'none';

      var input = document.createElement('input');
      input.type = 'text';
      input.className = 'wf-name-input';
      input.value = currentName;
      nameEl.parentNode.insertBefore(input, nameEl);
      input.focus();
      input.select();

      function save() {
        var newName = input.value.trim();
        if (newName && newName !== currentName) {
          renameWorkflow(id, newName);
        }
        input.remove();
        nameEl.style.display = '';
      }

      function cancel() {
        input.remove();
        nameEl.style.display = '';
      }

      input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') { e.preventDefault(); save(); }
        if (e.key === 'Escape') { e.preventDefault(); cancel(); }
      });
      input.addEventListener('blur', save);
    }

    function closeAllMenus() {
      document.querySelectorAll('.wf-menu.show').forEach(function(m) { m.classList.remove('show'); });
    }
    document.addEventListener('click', function(e) {
      if (!e.target.closest('.wf-menu-btn') && !e.target.closest('.wf-menu')) {
        closeAllMenus();
      }
    });

    // ----- API Actions -----
    function createWorkflow(name) {
      return fetch('/api/workflows', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name })
      }).then(function(r) { return r.json(); });
    }

    function renameWorkflow(id, name) {
      fetch('/api/workflows/' + id, {
        method: 'PUT',
        headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name })
      }).then(function() { loadWorkflows(); })
        .catch(function(err) { console.error('Rename failed:', err); });
    }

    function duplicateWorkflow(id) {
      var wf = workflows.find(function(w) { return w.id === id; });
      if (!wf) return;
      fetch('/api/workflows', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: wf.name + ' (copy)', data: wf.data })
      }).then(function() { loadWorkflows(); })
        .catch(function(err) { console.error('Duplicate failed:', err); });
    }

    function deleteWorkflow(id) {
      if (!confirm('Delete this workflow? This cannot be undone.')) return;
      fetch('/api/workflows/' + id, {
        method: 'DELETE',
        headers: { 'Authorization': 'Bearer ' + token }
      }).then(function() {
        if (activeWorkflowId === id) {
          localStorage.removeItem('activeWorkflowId');
          activeWorkflowId = null;
        }
        loadWorkflows();
      }).catch(function(err) { console.error('Delete failed:', err); });
    }

    // ----- Modal -----
    var modal = document.getElementById('newWorkflowModal');
    var nameInput = document.getElementById('newWorkflowName');
    var createBtn = document.getElementById('modalCreate');

    function openModal() {
      modal.classList.add('show');
      nameInput.value = '';
      nameInput.focus();
      createBtn.disabled = false;
    }
    function closeModal() {
      modal.classList.remove('show');
    }

    document.getElementById('btnNewWorkflow').addEventListener('click', openModal);
    document.getElementById('btnCreateFirst').addEventListener('click', openModal);
    document.getElementById('modalCancel').addEventListener('click', closeModal);

    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeModal();
    });

    nameInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') { e.preventDefault(); doCreate(); }
      if (e.key === 'Escape') closeModal();
    });

    createBtn.addEventListener('click', doCreate);

    function doCreate() {
      var name = nameInput.value.trim() || 'My Awesome Workflow';
      createBtn.disabled = true;
      createBtn.textContent = 'Creating...';
      createWorkflow(name).then(function(data) {
        var newId = data.id || (data.workflow && data.workflow.id);
        if (newId) {
          localStorage.setItem('activeWorkflowId', newId);
          window.location.href = '/workflow?id=' + newId;
        } else {
          closeModal();
          loadWorkflows();
        }
      }).catch(function(err) {
        console.error('Create failed:', err);
        createBtn.disabled = false;
        createBtn.textContent = 'Create';
      });
    }

    // ----- Init -----
    loadWorkflows();
  })();
  </script>
</body>
</html>
