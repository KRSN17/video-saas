<%- include('partials/head') %>
<html><head><!-- head already included --></head>
<body style="margin:0;background:#0a0a14;font-family:'Manrope',sans-serif;">
<%- include('partials/sidebar') %>

<div style="margin-left:260px;min-height:100vh;padding:32px 40px;">

  <!-- Top: Create button -->
  <div style="margin-bottom:32px;">
    <button id="btnCreate" style="
      background: linear-gradient(135deg, #e8e462, #c8c442);
      color: #111; border:none; padding:12px 28px;
      border-radius:10px; font-size:14px; font-weight:700;
      cursor:pointer; font-family:inherit;
      display:inline-flex; align-items:center; gap:8px;
    ">+ Create New File</button>
  </div>

  <!-- Grid -->
  <div id="workflowGrid" style="
    display:grid;
    grid-template-columns: repeat(4, 1fr);
    gap:24px;
  "></div>

</div>

<script>
(function() {
  var token = localStorage.getItem('token');
  if (!token) { window.location.href = '/login'; return; }
  var headers = { 'Authorization': 'Bearer ' + token };
  var jsonHeaders = { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' };

  var grid = document.getElementById('workflowGrid');

  function timeAgo(dateStr) {
    if (!dateStr) return '';
    var diff = (Date.now() - new Date(dateStr).getTime()) / 1000;
    if (diff < 60) return 'just now';
    if (diff < 3600) return Math.floor(diff/60) + ' minutes ago';
    if (diff < 86400) return Math.floor(diff/3600) + ' hours ago';
    return Math.floor(diff/86400) + ' days ago';
  }

  function loadWorkflows() {
    fetch('/api/workflows', { headers: headers })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var workflows = data.workflows || [];
      grid.innerHTML = '';

      workflows.forEach(function(wf) {
        var nodeCount = 0;
        try {
          var d = typeof wf.data === 'string' ? JSON.parse(wf.data) : wf.data;
          if (d && d.nodes) nodeCount = d.nodes.length;
        } catch(e) {}

        var card = document.createElement('div');
        card.style.cssText = 'cursor:pointer;';
        card.innerHTML =
          '<div style="' +
            'background: rgba(255,255,255,0.04);' +
            'border: 1px solid rgba(255,255,255,0.08);' +
            'border-radius: 14px;' +
            'aspect-ratio: 4/3;' +
            'display: flex; align-items: center; justify-content: center;' +
            'transition: all 0.2s;' +
            'position: relative;' +
          '" class="wf-thumb" data-id="' + wf.id + '">' +
            '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5">' +
              '<rect x="3" y="3" width="6" height="6" rx="1"/>' +
              '<rect x="15" y="3" width="6" height="6" rx="1"/>' +
              '<rect x="9" y="15" width="6" height="6" rx="1"/>' +
              '<line x1="9" y1="6" x2="15" y2="6"/>' +
              '<line x1="12" y1="9" x2="12" y2="15"/>' +
            '</svg>' +
            (nodeCount > 0 ? '<span style="position:absolute;bottom:10px;right:12px;font-size:11px;color:rgba(255,255,255,0.2);">' + nodeCount + ' nodes</span>' : '') +
          '</div>' +
          '<div style="padding:10px 4px 0;">' +
            '<div class="wf-card-name" data-id="' + wf.id + '" style="font-size:14px;font-weight:700;color:#fff;cursor:text;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' +
              escapeHtml(wf.name) +
            '</div>' +
            '<div style="font-size:12px;color:rgba(255,255,255,0.35);margin-top:2px;">Last edited ' + timeAgo(wf.updatedAt) + '</div>' +
          '</div>';

        // Click thumbnail to open
        card.querySelector('.wf-thumb').addEventListener('click', function() {
          window.location.href = '/workflow?id=' + wf.id;
        });
        // Hover effect
        card.querySelector('.wf-thumb').addEventListener('mouseenter', function() {
          this.style.borderColor = 'rgba(255,255,255,0.18)';
          this.style.background = 'rgba(255,255,255,0.06)';
        });
        card.querySelector('.wf-thumb').addEventListener('mouseleave', function() {
          this.style.borderColor = 'rgba(255,255,255,0.08)';
          this.style.background = 'rgba(255,255,255,0.04)';
        });

        // Double-click name to rename
        card.querySelector('.wf-card-name').addEventListener('dblclick', function(e) {
          e.stopPropagation();
          var el = this;
          var id = el.getAttribute('data-id');
          var oldName = el.textContent;
          var input = document.createElement('input');
          input.type = 'text';
          input.value = oldName;
          input.style.cssText = 'background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.2);border-radius:6px;color:#fff;font-size:14px;font-weight:700;padding:4px 8px;width:100%;box-sizing:border-box;outline:none;font-family:inherit;';
          el.replaceWith(input);
          input.focus();
          input.select();
          function save() {
            var newName = input.value.trim() || oldName;
            el.textContent = newName;
            input.replaceWith(el);
            if (newName !== oldName) {
              fetch('/api/workflows/' + id, {
                method: 'PUT', headers: jsonHeaders,
                body: JSON.stringify({ name: newName })
              });
            }
          }
          input.addEventListener('blur', save);
          input.addEventListener('keydown', function(ev) {
            if (ev.key === 'Enter') save();
            if (ev.key === 'Escape') { el.textContent = oldName; input.replaceWith(el); }
          });
        });

        // Right-click context menu
        card.addEventListener('contextmenu', function(e) {
          e.preventDefault();
          var existing = document.querySelector('.wf-ctx');
          if (existing) existing.remove();
          var menu = document.createElement('div');
          menu.className = 'wf-ctx';
          menu.style.cssText = 'position:fixed;top:'+e.clientY+'px;left:'+e.clientX+'px;background:rgba(25,25,35,0.97);border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:6px;z-index:9999;min-width:160px;backdrop-filter:blur(16px);box-shadow:0 8px 32px rgba(0,0,0,0.5);';
          menu.innerHTML =
            '<div class="wf-ctx-item" data-a="open" style="padding:8px 14px;font-size:13px;color:rgba(255,255,255,0.7);cursor:pointer;border-radius:6px;display:flex;align-items:center;gap:8px;"><i class="fa-solid fa-arrow-up-right-from-square" style="width:16px;"></i>Open</div>' +
            '<div class="wf-ctx-item" data-a="dup" style="padding:8px 14px;font-size:13px;color:rgba(255,255,255,0.7);cursor:pointer;border-radius:6px;display:flex;align-items:center;gap:8px;"><i class="fa-solid fa-copy" style="width:16px;"></i>Duplicate</div>' +
            '<div style="height:1px;background:rgba(255,255,255,0.06);margin:4px 0;"></div>' +
            '<div class="wf-ctx-item" data-a="del" style="padding:8px 14px;font-size:13px;color:#ef4444;cursor:pointer;border-radius:6px;display:flex;align-items:center;gap:8px;"><i class="fa-solid fa-trash" style="width:16px;"></i>Delete</div>';
          document.body.appendChild(menu);
          menu.querySelectorAll('.wf-ctx-item').forEach(function(item) {
            item.addEventListener('mouseenter', function() { this.style.background = 'rgba(255,255,255,0.06)'; });
            item.addEventListener('mouseleave', function() { this.style.background = 'none'; });
            item.addEventListener('click', function() {
              var a = this.getAttribute('data-a');
              menu.remove();
              if (a === 'open') window.location.href = '/workflow?id=' + wf.id;
              else if (a === 'dup') {
                fetch('/api/workflows/' + wf.id + '/duplicate', { method: 'POST', headers: headers })
                .then(function() { loadWorkflows(); });
              } else if (a === 'del') {
                if (confirm('Delete "' + wf.name + '"?')) {
                  fetch('/api/workflows/' + wf.id, { method: 'DELETE', headers: headers })
                  .then(function() { loadWorkflows(); });
                }
              }
            });
          });
          document.addEventListener('click', function once() { menu.remove(); document.removeEventListener('click', once); }, { once: true });
        });

        grid.appendChild(card);
      });

      // Add empty placeholder slots to fill the row
      var remaining = (4 - (workflows.length % 4)) % 4;
      for (var i = 0; i < remaining; i++) {
        var empty = document.createElement('div');
        empty.innerHTML =
          '<div style="' +
            'background: rgba(255,255,255,0.02);' +
            'border: 1px solid rgba(255,255,255,0.05);' +
            'border-radius: 14px;' +
            'aspect-ratio: 4/3;' +
            'display: flex; align-items: center; justify-content: center;' +
          '">' +
            '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="1.5">' +
              '<rect x="3" y="3" width="6" height="6" rx="1"/>' +
              '<rect x="15" y="3" width="6" height="6" rx="1"/>' +
              '<rect x="9" y="15" width="6" height="6" rx="1"/>' +
              '<line x1="9" y1="6" x2="15" y2="6"/>' +
              '<line x1="12" y1="9" x2="12" y2="15"/>' +
            '</svg>' +
          '</div>';
        grid.appendChild(empty);
      }
    });
  }

  function escapeHtml(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

  // Create new workflow
  document.getElementById('btnCreate').addEventListener('click', function() {
    var name = prompt('Workflow name:', 'Untitled Workflow');
    if (name === null) return;
    fetch('/api/workflows', {
      method: 'POST', headers: jsonHeaders,
      body: JSON.stringify({ name: name || 'Untitled Workflow' })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.workflow) window.location.href = '/workflow?id=' + data.workflow.id;
    });
  });

  loadWorkflows();
})();
</script>
</body></html>
