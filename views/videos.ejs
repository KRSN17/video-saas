<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <%- include('partials/head') %>
  <style>
    body {
      background: #0a0a14;
      margin: 0;
      font-family: 'Manrope', sans-serif;
    }
    .dash-main { margin-left: 260px; min-height: 100vh; }
    .dash-topbar {
      padding: 20px 32px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .dash-topbar h1 { font-size: 22px; font-weight: 700; color: #fff; margin: 0; }
    .dash-topbar .user-info { display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,0.6); font-size: 14px; }
    .dash-topbar .user-avatar { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #7b5cff, #c86dd7); display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700; font-size: 14px; }
    .dash-content { padding: 28px 32px; }
    .video-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 14px;
      overflow: hidden;
      transition: all 0.2s ease;
    }
    .video-card:hover {
      border-color: rgba(123,92,255,0.25);
      transform: translateY(-2px);
    }
    .video-thumb {
      width: 100%;
      aspect-ratio: 16/9;
      background: linear-gradient(135deg, #1a1a2e, #16213e);
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.12);
      font-size: 40px;
      position: relative;
      overflow: hidden;
    }
    .video-thumb video {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .video-card-body { padding: 16px; }
    .video-card-body .prompt-text {
      font-size: 13px;
      color: rgba(255,255,255,0.65);
      margin-bottom: 10px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      line-height: 1.5;
    }
    .video-card-body .meta-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 10px;
    }
    .video-card-body .meta { font-size: 11px; color: rgba(255,255,255,0.3); }
    .video-card-body .model-tag {
      font-size: 11px;
      padding: 2px 8px;
      border-radius: 6px;
      background: rgba(123,92,255,0.1);
      color: rgba(123,92,255,0.8);
      font-weight: 600;
    }
    .status-badge {
      font-size: 11px;
      padding: 3px 10px;
      border-radius: 20px;
      font-weight: 600;
    }
    .status-pending { background: rgba(245,158,11,0.15); color: #f59e0b; }
    .status-processing { background: rgba(59,130,246,0.15); color: #3b82f6; animation: pulse-badge 1.5s infinite; }
    .status-completed { background: rgba(16,185,129,0.15); color: #10b981; }
    .status-failed { background: rgba(239,68,68,0.15); color: #ef4444; }
    @keyframes pulse-badge { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }
    .card-actions { display: flex; gap: 6px; margin-top: 12px; }
    .card-actions .btn-action {
      flex: 1;
      padding: 7px;
      border-radius: 8px;
      font-size: 12px;
      font-weight: 600;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.03);
      color: rgba(255,255,255,0.5);
      cursor: pointer;
      transition: all 0.2s ease;
      text-align: center;
      text-decoration: none;
      display: inline-block;
    }
    .card-actions .btn-action:hover { background: rgba(255,255,255,0.06); color: #fff; }
    .card-actions .btn-download { border-color: rgba(16,185,129,0.2); color: #10b981; }
    .card-actions .btn-download:hover { background: rgba(16,185,129,0.1); }
    .card-actions .btn-delete { border-color: rgba(239,68,68,0.15); color: #ef4444; }
    .card-actions .btn-delete:hover { background: rgba(239,68,68,0.1); }
    .empty-state {
      text-align: center;
      padding: 80px 20px;
    }
    .empty-state i {
      font-size: 64px;
      color: rgba(255,255,255,0.08);
      margin-bottom: 20px;
      display: block;
    }
    .empty-state p {
      color: rgba(255,255,255,0.35);
      font-size: 16px;
    }
    .empty-state a {
      color: #7b5cff;
      font-weight: 600;
    }
  </style>
</head>
<body>
  <%- include('partials/sidebar') %>

  <div class="dash-main">
    <div class="dash-topbar">
      <h1>My Videos</h1>
      <div class="user-info">
        <span id="topbarUserName"></span>
        <div class="user-avatar" id="topbarAvatar"></div>
      </div>
    </div>

    <div class="dash-content">
      <div class="row g-4" id="videosGrid">
        <div class="col-12 text-center py-5" id="videosLoading">
          <div class="spinner-border text-secondary" role="status"></div>
        </div>
      </div>
      <div id="emptyState" class="empty-state" style="display: none;">
        <i class="fa-solid fa-film"></i>
        <p>No videos yet. <a href="/generate">Generate your first video!</a></p>
      </div>
    </div>
  </div>

  <script src="/public/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script>
    (function() {
      var token = localStorage.getItem('token');
      if (!token) { window.location.href = '/login'; return; }
      var headers = { 'Authorization': 'Bearer ' + token };

      // Profile
      fetch('/api/auth/profile', { headers: headers })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.user) {
            var name = data.user.name || data.user.email || 'User';
            document.getElementById('topbarUserName').textContent = name;
            document.getElementById('topbarAvatar').textContent = name.charAt(0).toUpperCase();
          }
        });

      function loadVideos() {
        fetch('/api/videos', { headers: headers })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var videos = data.videos || data || [];
            if (!Array.isArray(videos)) videos = [];
            document.getElementById('videosLoading').style.display = 'none';

            if (videos.length === 0) {
              document.getElementById('emptyState').style.display = 'block';
              return;
            }

            document.getElementById('emptyState').style.display = 'none';
            var grid = document.getElementById('videosGrid');
            grid.innerHTML = '';

            videos.forEach(function(v) {
              var statusClass = 'status-' + (v.status || 'pending');
              var thumb = '';
              if (v.status === 'completed' && v.videoUrl) {
                thumb = '<video src="' + v.videoUrl + '" muted preload="metadata" onmouseenter="this.play()" onmouseleave="this.pause();this.currentTime=0;"></video>';
              } else {
                thumb = '<i class="fa-solid fa-film"></i>';
              }

              var actions = '';
              if (v.status === 'completed' && v.videoUrl) {
                actions += '<a href="' + v.videoUrl + '" download class="btn-action btn-download"><i class="fa-solid fa-download me-1"></i>Download</a>';
              }
              actions += '<button class="btn-action btn-delete" onclick="deleteVideo(\'' + (v._id || v.id) + '\')"><i class="fa-solid fa-trash me-1"></i>Delete</button>';

              var date = v.createdAt ? new Date(v.createdAt).toLocaleDateString() : '';

              var card = '<div class="col-xl-3 col-lg-4 col-md-6">' +
                '<div class="video-card">' +
                '<div class="video-thumb">' + thumb + '</div>' +
                '<div class="video-card-body">' +
                '<p class="prompt-text">' + (v.prompt || 'No prompt') + '</p>' +
                '<div class="meta-row">' +
                '<span class="status-badge ' + statusClass + '">' + (v.status || 'pending') + '</span>' +
                '<span class="model-tag">' + (v.model || 'N/A') + '</span>' +
                '</div>' +
                '<div class="meta">' + date + '</div>' +
                '<div class="card-actions">' + actions + '</div>' +
                '</div></div></div>';
              grid.innerHTML += card;
            });
          })
          .catch(function() {
            document.getElementById('videosLoading').style.display = 'none';
          });
      }

      window.deleteVideo = function(id) {
        if (!confirm('Delete this video?')) return;
        fetch('/api/videos/' + id, {
          method: 'DELETE',
          headers: headers
        }).then(function(r) {
          if (r.ok) loadVideos();
          else alert('Failed to delete video.');
        });
      };

      loadVideos();
    })();
  </script>
</body>
</html>
