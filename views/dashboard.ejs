<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <%- include('partials/head') %>
  <style>
    body { background: #0a0a14; margin: 0; font-family: 'Manrope', sans-serif; }
    .dash-main { margin-left: 260px; min-height: 100vh; }
    .dash-topbar {
      padding: 20px 32px; border-bottom: 1px solid rgba(255,255,255,0.06);
      display: flex; align-items: center; justify-content: space-between;
    }
    .dash-topbar h1 { font-size: 22px; font-weight: 700; color: #fff; margin: 0; }
    .user-info { display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,0.6); font-size: 14px; }
    .user-avatar {
      width: 36px; height: 36px; border-radius: 50%;
      background: linear-gradient(135deg, #7b5cff, #c86dd7);
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-weight: 700; font-size: 14px;
    }
    .dash-content { padding: 28px 32px; }
    .stat-card {
      background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px; padding: 24px; transition: all 0.2s ease;
    }
    .stat-card:hover { border-color: rgba(123,92,255,0.2); background: rgba(123,92,255,0.04); }
    .stat-icon {
      width: 44px; height: 44px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; margin-bottom: 16px;
    }
    .stat-value { font-size: 28px; font-weight: 800; color: #fff; margin-bottom: 4px; }
    .stat-label { font-size: 13px; color: rgba(255,255,255,0.45); font-weight: 500; }
    .section-title {
      font-size: 17px; font-weight: 700; color: #fff; margin-bottom: 20px;
      display: flex; align-items: center; gap: 10px;
    }
    .section-title i { color: #a78bfa; font-size: 16px; }

    /* Workflow Cards */
    .wf-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 36px; }
    .wf-card {
      background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);
      border-radius: 14px; padding: 20px; text-decoration: none; color: #fff;
      transition: all 0.2s ease; display: block;
    }
    .wf-card:hover { border-color: rgba(123,92,255,0.3); background: rgba(123,92,255,0.06); color: #fff; transform: translateY(-2px); }
    .wf-card-title { font-size: 15px; font-weight: 700; margin-bottom: 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .wf-card-meta { font-size: 12px; color: rgba(255,255,255,0.35); }
    .wf-card-nodes { font-size: 12px; color: rgba(123,92,255,0.7); font-weight: 600; margin-top: 10px; }

    /* Filter pills */
    .filter-bar { display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }
    .filter-pill {
      padding: 6px 18px; border-radius: 20px; font-size: 13px; font-weight: 600;
      border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.03);
      color: rgba(255,255,255,0.5); cursor: pointer; transition: all 0.15s ease;
    }
    .filter-pill:hover { border-color: rgba(123,92,255,0.3); color: rgba(255,255,255,0.7); }
    .filter-pill.active { background: rgba(123,92,255,0.15); border-color: rgba(123,92,255,0.4); color: #a78bfa; }

    /* Video grid */
    .video-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; }
    .vid-card {
      background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);
      border-radius: 14px; overflow: hidden; transition: all 0.25s ease; position: relative;
    }
    .vid-card:hover { border-color: rgba(123,92,255,0.3); transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.3); }
    .vid-thumb {
      width: 100%; aspect-ratio: 16/9; background: linear-gradient(135deg, #1a1a2e, #16213e);
      display: flex; align-items: center; justify-content: center;
      color: rgba(255,255,255,0.12); font-size: 36px; position: relative; overflow: hidden;
    }
    .vid-thumb video { width: 100%; height: 100%; object-fit: cover; }
    .vid-body { padding: 14px; }
    .vid-prompt {
      font-size: 13px; color: rgba(255,255,255,0.6); line-height: 1.4; margin-bottom: 10px;
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .vid-footer { display: flex; align-items: center; justify-content: space-between; }
    .vid-date { font-size: 11px; color: rgba(255,255,255,0.25); }
    .vid-actions { display: flex; gap: 6px; }
    .vid-actions button, .vid-actions a {
      background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);
      color: rgba(255,255,255,0.5); width: 30px; height: 30px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center; font-size: 12px;
      cursor: pointer; transition: all 0.15s ease; text-decoration: none;
    }
    .vid-actions .btn-dl:hover { background: rgba(16,185,129,0.15); color: #10b981; border-color: rgba(16,185,129,0.3); }
    .vid-actions .btn-del:hover { background: rgba(239,68,68,0.15); color: #ef4444; border-color: rgba(239,68,68,0.3); }
    .status-badge { font-size: 10px; padding: 2px 8px; border-radius: 20px; font-weight: 600; }
    .status-pending { background: rgba(245,158,11,0.15); color: #f59e0b; }
    .status-processing { background: rgba(59,130,246,0.15); color: #3b82f6; animation: pulse-badge 1.5s infinite; }
    .status-completed { background: rgba(16,185,129,0.15); color: #10b981; }
    .status-failed { background: rgba(239,68,68,0.15); color: #ef4444; }
    @keyframes pulse-badge { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }
    .empty-state {
      text-align: center; padding: 60px 20px; grid-column: 1 / -1;
    }
    .empty-state i { font-size: 48px; color: rgba(255,255,255,0.08); display: block; margin-bottom: 16px; }
    .empty-state p { color: rgba(255,255,255,0.3); font-size: 15px; }
    .empty-state a { color: #7b5cff; }
    @media (max-width: 1100px) { .wf-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 768px) {
      .dash-main { margin-left: 0; }
      .wf-grid { grid-template-columns: 1fr; }
      .video-grid { grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }
    }
  </style>
</head>
<body>
  <%- include('partials/sidebar') %>

  <div class="dash-main">
    <div class="dash-topbar">
      <h1>Home</h1>
      <div class="user-info">
        <span id="topbarUserName"></span>
        <div class="user-avatar" id="topbarAvatar"></div>
      </div>
    </div>

    <div class="dash-content">
      <!-- Stats Row -->
      <div class="row g-4 mb-4">
        <div class="col-lg-4 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon" style="background:rgba(245,158,11,0.12);color:#f59e0b;">
              <i class="fa-solid fa-coins"></i>
            </div>
            <div class="stat-value" id="statBalance">--</div>
            <div class="stat-label">Credits Balance</div>
          </div>
        </div>
        <div class="col-lg-4 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon" style="background:rgba(16,185,129,0.12);color:#10b981;">
              <i class="fa-solid fa-film"></i>
            </div>
            <div class="stat-value" id="statTotal">--</div>
            <div class="stat-label">Videos Generated</div>
          </div>
        </div>
        <div class="col-lg-4 col-sm-12">
          <div class="stat-card">
            <div class="stat-icon" style="background:rgba(59,130,246,0.12);color:#3b82f6;">
              <i class="fa-solid fa-spinner"></i>
            </div>
            <div class="stat-value" id="statProcessing">--</div>
            <div class="stat-label">Videos Processing</div>
          </div>
        </div>
      </div>

      <!-- Recent Workflows -->
      <div class="section-title"><i class="fa-solid fa-diagram-project"></i> Recent Workflows</div>
      <div class="wf-grid" id="workflowGrid">
        <div style="grid-column:1/-1;text-align:center;padding:24px;color:rgba(255,255,255,0.2);font-size:13px;">
          <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
        </div>
      </div>

      <!-- My Videos -->
      <div class="section-title"><i class="fa-solid fa-images"></i> My Videos</div>
      <div class="filter-bar" id="filterBar">
        <div class="filter-pill active" data-filter="all">All</div>
        <div class="filter-pill" data-filter="completed">Completed</div>
        <div class="filter-pill" data-filter="processing">Processing</div>
        <div class="filter-pill" data-filter="failed">Failed</div>
      </div>
      <div class="video-grid" id="videoGrid">
        <div class="empty-state" id="videosLoading">
          <div class="spinner-border text-secondary" role="status"></div>
        </div>
      </div>
    </div>
  </div>

  <script src="/public/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script>
  (function() {
    var token = localStorage.getItem('token');
    if (!token) { window.location.href = '/login'; return; }
    var headers = { 'Authorization': 'Bearer ' + token };
    var allVideos = [];
    var currentFilter = 'all';

    function timeAgo(d) {
      if (!d) return '';
      var s = Math.floor((Date.now() - new Date(d)) / 1000);
      if (s < 60) return 'just now';
      if (s < 3600) return Math.floor(s / 60) + 'm ago';
      if (s < 86400) return Math.floor(s / 3600) + 'h ago';
      if (s < 604800) return Math.floor(s / 86400) + 'd ago';
      return new Date(d).toLocaleDateString();
    }

    function escHtml(str) {
      var d = document.createElement('div'); d.textContent = str || ''; return d.innerHTML;
    }

    // Profile
    fetch('/api/auth/profile', { headers: headers })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.user) {
          var u = data.user, name = u.name || u.email || 'User';
          document.getElementById('topbarUserName').textContent = name;
          document.getElementById('topbarAvatar').textContent = name.charAt(0).toUpperCase();
          document.getElementById('statBalance').textContent = u.credits != null ? u.credits : 0;
        }
      }).catch(function() {});

    // Workflows
    fetch('/api/workflows', { headers: headers })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var wfs = Array.isArray(data) ? data : (data.workflows || []);
        var grid = document.getElementById('workflowGrid');
        if (wfs.length === 0) {
          grid.innerHTML = '<div class="empty-state"><i class="fa-solid fa-diagram-project"></i><p>No workflows yet. <a href="/workflow">Create your first workflow</a></p></div>';
          return;
        }
        var recent = wfs.slice(0, 3);
        grid.innerHTML = '';
        recent.forEach(function(wf) {
          var nodeCount = 0;
          try { var d = typeof wf.data === 'string' ? JSON.parse(wf.data) : wf.data; nodeCount = (d && d.nodes) ? d.nodes.length : 0; } catch(e) {}
          var a = document.createElement('a');
          a.className = 'wf-card';
          a.href = '/workflow?id=' + wf.id;
          a.innerHTML = '<div class="wf-card-title">' + escHtml(wf.name || 'Untitled Workflow') + '</div>' +
            '<div class="wf-card-meta">' + timeAgo(wf.updatedAt || wf.createdAt) + '</div>' +
            '<div class="wf-card-nodes"><i class="fa-solid fa-circle-nodes me-1"></i>' + nodeCount + ' nodes</div>';
          grid.appendChild(a);
        });
      }).catch(function() {
        document.getElementById('workflowGrid').innerHTML = '<div class="empty-state"><i class="fa-solid fa-diagram-project"></i><p>Could not load workflows</p></div>';
      });

    // Videos
    fetch('/api/videos', { headers: headers })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        allVideos = Array.isArray(data) ? data : (data.videos || []);
        var completed = allVideos.filter(function(v) { return v.status === 'completed'; }).length;
        var processing = allVideos.filter(function(v) { return v.status === 'processing' || v.status === 'pending'; }).length;
        document.getElementById('statTotal').textContent = completed;
        document.getElementById('statProcessing').textContent = processing;
        renderVideos();
      }).catch(function() {
        document.getElementById('videoGrid').innerHTML = '<div class="empty-state"><i class="fa-solid fa-film"></i><p>Could not load videos</p></div>';
      });

    function renderVideos() {
      var grid = document.getElementById('videoGrid');
      var filtered = currentFilter === 'all' ? allVideos :
        allVideos.filter(function(v) {
          if (currentFilter === 'processing') return v.status === 'processing' || v.status === 'pending';
          return v.status === currentFilter;
        });

      if (filtered.length === 0) {
        var msg = currentFilter === 'all' ? 'No videos yet. <a href="/generate">Generate your first video!</a>' : 'No ' + currentFilter + ' videos.';
        grid.innerHTML = '<div class="empty-state"><i class="fa-solid fa-film"></i><p>' + msg + '</p></div>';
        return;
      }

      grid.innerHTML = '';
      filtered.forEach(function(v) {
        var sc = 'status-' + (v.status || 'pending');
        var thumb = '';
        if (v.status === 'completed' && v.videoUrl) {
          thumb = '<video src="' + escHtml(v.videoUrl) + '" muted preload="metadata" onmouseenter="this.play()" onmouseleave="this.pause();this.currentTime=0;"></video>';
        } else {
          thumb = '<i class="fa-solid fa-film"></i>';
        }
        var actions = '';
        if (v.status === 'completed') {
          actions += '<a class="btn-dl" href="/api/videos/' + v.id + '/download" title="Download"><i class="fa-solid fa-download"></i></a>';
        }
        actions += '<button class="btn-del" onclick="window._delVideo(\'' + v.id + '\')" title="Delete"><i class="fa-solid fa-trash"></i></button>';

        var card = document.createElement('div');
        card.className = 'vid-card';
        card.innerHTML = '<div class="vid-thumb">' + thumb + '</div>' +
          '<div class="vid-body">' +
            '<div class="vid-prompt">' + escHtml(v.prompt || 'No prompt') + '</div>' +
            '<div class="vid-footer">' +
              '<div><span class="status-badge ' + sc + '">' + (v.status || 'pending') + '</span> <span class="vid-date">' + timeAgo(v.createdAt) + '</span></div>' +
              '<div class="vid-actions">' + actions + '</div>' +
            '</div>' +
          '</div>';
        grid.appendChild(card);
      });
    }

    // Filter pills
    document.getElementById('filterBar').addEventListener('click', function(e) {
      var pill = e.target.closest('.filter-pill');
      if (!pill) return;
      document.querySelectorAll('.filter-pill').forEach(function(p) { p.classList.remove('active'); });
      pill.classList.add('active');
      currentFilter = pill.getAttribute('data-filter');
      renderVideos();
    });

    // Delete
    window._delVideo = function(id) {
      if (!confirm('Delete this video?')) return;
      fetch('/api/videos/' + id, { method: 'DELETE', headers: headers })
        .then(function(r) {
          if (r.ok) {
            allVideos = allVideos.filter(function(v) { return v.id !== id; });
            renderVideos();
          } else { alert('Failed to delete video.'); }
        }).catch(function() { alert('Failed to delete video.'); });
    };
  })();
  </script>
</body>
</html>
