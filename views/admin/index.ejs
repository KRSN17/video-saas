<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <%- include('../partials/head') %>
  <style>
    body {
      background: #0a0a14;
      margin: 0;
      font-family: 'Manrope', sans-serif;
    }
    .dash-main { margin-left: 260px; min-height: 100vh; }
    .dash-topbar {
      padding: 20px 32px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .dash-topbar h1 { font-size: 22px; font-weight: 700; color: #fff; margin: 0; }
    .dash-topbar .user-info { display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,0.6); font-size: 14px; }
    .dash-topbar .user-avatar { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #7b5cff, #c86dd7); display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700; font-size: 14px; }
    .dash-content { padding: 28px 32px; }
    .section-title {
      font-size: 17px; font-weight: 700; color: #fff; margin-bottom: 20px;
      display: flex; align-items: center; gap: 10px;
    }
    .section-title i { color: #a78bfa; font-size: 16px; }

    .stat-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      padding: 24px;
      transition: all 0.2s ease;
    }
    .stat-card:hover { border-color: rgba(123,92,255,0.2); }
    .stat-card .stat-icon {
      width: 44px; height: 44px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; margin-bottom: 16px;
    }
    .stat-card .stat-value { font-size: 28px; font-weight: 800; color: #fff; margin-bottom: 4px; }
    .stat-card .stat-label { font-size: 13px; color: rgba(255,255,255,0.45); font-weight: 500; }

    .admin-panel {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      overflow: hidden;
      margin-bottom: 28px;
    }
    .admin-table { width: 100%; border-collapse: separate; border-spacing: 0; }
    .admin-table th {
      text-align: left; padding: 12px 16px; font-size: 11px; font-weight: 600;
      color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.5px;
      border-bottom: 1px solid rgba(255,255,255,0.06); background: rgba(255,255,255,0.02);
    }
    .admin-table td {
      padding: 12px 16px; font-size: 13px; color: rgba(255,255,255,0.6);
      border-bottom: 1px solid rgba(255,255,255,0.04); vertical-align: middle;
    }
    .admin-table tr:last-child td { border-bottom: none; }
    .admin-table tr:hover td { background: rgba(255,255,255,0.02); }

    .role-badge {
      font-size: 10px; padding: 2px 8px; border-radius: 20px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.5px;
    }
    .role-admin { background: rgba(239,68,68,0.15); color: #ef4444; }
    .role-user { background: rgba(59,130,246,0.15); color: #3b82f6; }

    .status-badge {
      font-size: 11px; padding: 3px 10px; border-radius: 20px; font-weight: 600;
    }
    .status-pending { background: rgba(245,158,11,0.15); color: #f59e0b; }
    .status-processing { background: rgba(59,130,246,0.15); color: #3b82f6; }
    .status-completed { background: rgba(16,185,129,0.15); color: #10b981; }
    .status-failed { background: rgba(239,68,68,0.15); color: #ef4444; }

    .btn-sm-action {
      padding: 5px 12px; border-radius: 6px; font-size: 11px; font-weight: 600;
      cursor: pointer; border: 1px solid rgba(123,92,255,0.3);
      background: rgba(123,92,255,0.1); color: #a78bfa;
      transition: all 0.15s ease;
    }
    .btn-sm-action:hover { background: rgba(123,92,255,0.2); }

    .settings-panel {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      padding: 28px;
      margin-bottom: 28px;
    }
    .settings-group {
      margin-bottom: 24px;
      padding-bottom: 24px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .settings-group:last-child { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
    .settings-group-title {
      font-size: 14px; font-weight: 700; color: rgba(255,255,255,0.8); margin-bottom: 16px;
      display: flex; align-items: center; gap: 8px;
    }
    .settings-group-title i { color: #a78bfa; font-size: 14px; }

    .form-label { color: rgba(255,255,255,0.7); font-size: 12px; font-weight: 600; margin-bottom: 6px; }
    .form-control, .form-select {
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1);
      border-radius: 8px; color: #fff; font-size: 13px; padding: 8px 12px;
    }
    .form-control:focus, .form-select:focus {
      background: rgba(255,255,255,0.06); border-color: rgba(123,92,255,0.4);
      box-shadow: 0 0 0 3px rgba(123,92,255,0.1); color: #fff;
    }
    .form-control::placeholder { color: rgba(255,255,255,0.25); }

    .api-key-row {
      display: flex; align-items: center; gap: 8px; margin-bottom: 8px;
      padding: 10px 14px; border-radius: 8px;
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.06);
    }
    .api-key-row .key-label { flex: 1; font-size: 13px; color: rgba(255,255,255,0.5); font-family: monospace; }
    .api-key-row .key-status {
      font-size: 10px; padding: 2px 8px; border-radius: 10px; font-weight: 600;
    }
    .api-key-row .key-active { background: rgba(16,185,129,0.15); color: #10b981; }
    .api-key-row .key-fallback { background: rgba(245,158,11,0.15); color: #f59e0b; }
    .api-key-row .btn-remove-key {
      background: none; border: none; color: rgba(239,68,68,0.5); cursor: pointer;
      font-size: 14px; padding: 2px 6px; transition: all 0.15s ease;
    }
    .api-key-row .btn-remove-key:hover { color: #ef4444; }

    .btn-save-settings {
      background: linear-gradient(135deg, #7b5cff, #c86dd7);
      border: none; color: #fff; padding: 10px 24px;
      border-radius: 8px; font-size: 13px; font-weight: 700;
      cursor: pointer; transition: all 0.2s ease;
    }
    .btn-save-settings:hover { opacity: 0.9; }
    .btn-save-settings:disabled { opacity: 0.5; cursor: not-allowed; }

    .toast-success {
      position: fixed; bottom: 24px; right: 24px; z-index: 9999;
      background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.3);
      color: #10b981; padding: 12px 20px; border-radius: 10px;
      font-size: 13px; font-weight: 600; display: none;
      animation: slideIn 0.3s ease;
    }
    @keyframes slideIn { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

    .modal-content {
      background: #141425;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
    }
    .modal-header { border-bottom: 1px solid rgba(255,255,255,0.06); }
    .modal-footer { border-top: 1px solid rgba(255,255,255,0.06); }
    .modal-title { color: #fff; font-weight: 700; }
    .btn-close { filter: invert(1); }

    /* Analytics Section */
    .analytics-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 28px;
    }
    .analytics-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      padding: 24px;
    }
    .analytics-card-title {
      font-size: 14px;
      font-weight: 700;
      color: rgba(255,255,255,0.7);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .analytics-card-title i { color: #a78bfa; font-size: 14px; }

    /* Horizontal bar chart */
    .h-bar-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }
    .h-bar-label {
      width: 100px;
      font-size: 12px;
      font-weight: 600;
      color: rgba(255,255,255,0.5);
      text-align: right;
      flex-shrink: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .h-bar-track {
      flex: 1;
      height: 24px;
      background: rgba(255,255,255,0.04);
      border-radius: 6px;
      overflow: hidden;
    }
    .h-bar-fill {
      height: 100%;
      border-radius: 6px;
      transition: width 0.6s ease;
      display: flex;
      align-items: center;
      padding-left: 8px;
      font-size: 11px;
      font-weight: 700;
      color: #fff;
      min-width: 24px;
    }
    .h-bar-count {
      width: 36px;
      font-size: 12px;
      font-weight: 700;
      color: rgba(255,255,255,0.4);
      flex-shrink: 0;
    }

    /* Status blocks */
    .status-blocks {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }
    .status-block {
      flex: 1;
      min-width: 100px;
      padding: 16px;
      border-radius: 12px;
      text-align: center;
    }
    .status-block .sb-count {
      font-size: 24px;
      font-weight: 800;
      color: #fff;
      margin-bottom: 4px;
    }
    .status-block .sb-label {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* Top users table */
    .top-users-table { width: 100%; border-collapse: collapse; }
    .top-users-table th {
      text-align: left; padding: 8px 12px; font-size: 10px; font-weight: 700;
      color: rgba(255,255,255,0.3); text-transform: uppercase; letter-spacing: 0.5px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .top-users-table td {
      padding: 10px 12px; font-size: 12px; color: rgba(255,255,255,0.6);
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .top-users-table tr:last-child td { border-bottom: none; }
    .top-user-rank {
      width: 24px; height: 24px; border-radius: 6px;
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 800;
    }

    /* API Key Management */
    .apikey-mgmt-row {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 16px;
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 10px;
      margin-bottom: 8px;
      transition: all 0.15s ease;
    }
    .apikey-mgmt-row:hover { border-color: rgba(123,92,255,0.15); }
    .apikey-mgmt-key {
      flex: 1;
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.5px;
    }
    .apikey-mgmt-usage {
      font-size: 11px;
      color: rgba(255,255,255,0.3);
      white-space: nowrap;
    }
    .apikey-status-badge {
      font-size: 10px;
      padding: 2px 10px;
      border-radius: 10px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.15s ease;
    }
    .apikey-active {
      background: rgba(16,185,129,0.15);
      color: #10b981;
    }
    .apikey-inactive {
      background: rgba(239,68,68,0.12);
      color: #ef4444;
    }
    .apikey-btn-del {
      background: none;
      border: none;
      color: rgba(239,68,68,0.4);
      cursor: pointer;
      font-size: 14px;
      padding: 4px 8px;
      transition: color 0.15s ease;
    }
    .apikey-btn-del:hover { color: #ef4444; }
    .apikey-add-row {
      display: flex;
      gap: 8px;
      margin-top: 12px;
    }
    .apikey-add-input {
      flex: 1;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 8px;
      color: #fff;
      font-size: 13px;
      padding: 8px 12px;
      font-family: monospace;
      outline: none;
    }
    .apikey-add-input:focus { border-color: rgba(123,92,255,0.4); }
    .apikey-add-input::placeholder { color: rgba(255,255,255,0.2); }
  </style>
</head>
<body>
  <%- include('../partials/sidebar') %>

  <div class="dash-main">
    <div class="dash-topbar">
      <h1><i class="fa-solid fa-shield me-2" style="color: #a78bfa;"></i>Admin Panel</h1>
      <div class="user-info">
        <span id="topbarUserName"></span>
        <div class="user-avatar" id="topbarAvatar"></div>
      </div>
    </div>

    <div class="dash-content">
      <!-- Stats Row -->
      <div class="row g-4 mb-4">
        <div class="col-lg-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon" style="background: rgba(59,130,246,0.12); color: #3b82f6;">
              <i class="fa-solid fa-users"></i>
            </div>
            <div class="stat-value" id="statUsers">--</div>
            <div class="stat-label">Total Users</div>
          </div>
        </div>
        <div class="col-lg-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon" style="background: rgba(16,185,129,0.12); color: #10b981;">
              <i class="fa-solid fa-film"></i>
            </div>
            <div class="stat-value" id="statVideos">--</div>
            <div class="stat-label">Total Videos</div>
          </div>
        </div>
        <div class="col-lg-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon" style="background: rgba(245,158,11,0.12); color: #f59e0b;">
              <i class="fa-solid fa-coins"></i>
            </div>
            <div class="stat-value" id="statCredits">--</div>
            <div class="stat-label">Credits Used</div>
          </div>
        </div>
        <div class="col-lg-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon" style="background: rgba(168,85,247,0.12); color: #a855f7;">
              <i class="fa-solid fa-dollar-sign"></i>
            </div>
            <div class="stat-value" id="statRevenue">--</div>
            <div class="stat-label">Revenue</div>
          </div>
        </div>
      </div>

      <!-- Analytics Section -->
      <div class="section-title"><i class="fa-solid fa-chart-pie"></i> Analytics</div>
      <div class="analytics-grid">
        <!-- Videos by Model -->
        <div class="analytics-card">
          <div class="analytics-card-title"><i class="fa-solid fa-robot"></i> Videos by Model</div>
          <div id="analyticsByModel">
            <div class="text-center py-3" style="color: rgba(255,255,255,0.2); font-size: 13px;">
              <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
            </div>
          </div>
        </div>
        <!-- Videos by Status -->
        <div class="analytics-card">
          <div class="analytics-card-title"><i class="fa-solid fa-signal"></i> Videos by Status</div>
          <div id="analyticsByStatus">
            <div class="text-center py-3" style="color: rgba(255,255,255,0.2); font-size: 13px;">
              <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Top Users -->
      <div class="admin-panel" style="margin-bottom: 28px;">
        <div style="padding: 16px 16px 0;">
          <div class="analytics-card-title"><i class="fa-solid fa-trophy"></i> Top Users</div>
        </div>
        <div id="topUsersContainer">
          <div class="text-center py-3" style="color: rgba(255,255,255,0.2); font-size: 13px;">
            <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
          </div>
        </div>
      </div>

      <!-- API Key Management -->
      <div class="section-title"><i class="fa-solid fa-key"></i> API Key Management</div>
      <div class="admin-panel" style="padding: 24px;">
        <p style="font-size: 12px; color: rgba(255,255,255,0.35); margin-bottom: 16px;">
          Manage fal.ai API keys. Toggle active/inactive, monitor usage, and add new keys for load balancing.
        </p>
        <div id="apiKeyMgmtContainer">
          <div class="text-center py-3" style="color: rgba(255,255,255,0.2); font-size: 13px;">
            <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
          </div>
        </div>
        <div class="apikey-add-row">
          <input type="text" class="apikey-add-input" id="newMgmtApiKey" placeholder="fal-xxxxxxxxxxxxxxxxxxxxxxxx">
          <button class="btn-sm-action" id="btnAddMgmtApiKey" style="padding: 8px 16px; white-space: nowrap;">
            <i class="fa-solid fa-plus me-1"></i>Add Key
          </button>
        </div>
      </div>

      <!-- Users Table -->
      <div class="section-title"><i class="fa-solid fa-users"></i> Users</div>
      <div class="admin-panel">
        <div id="usersTableContainer">
          <div class="text-center py-4">
            <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
          </div>
        </div>
      </div>

      <!-- Recent Videos Table -->
      <div class="section-title"><i class="fa-solid fa-film"></i> Recent Videos</div>
      <div class="admin-panel">
        <div id="videosTableContainer">
          <div class="text-center py-4">
            <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
          </div>
        </div>
      </div>

      <!-- Settings Section -->
      <div class="section-title"><i class="fa-solid fa-gear"></i> Settings</div>
      <div class="settings-panel">
        <!-- fal.ai API Keys (legacy) -->
        <div class="settings-group">
          <div class="settings-group-title">
            <i class="fa-solid fa-key"></i>
            fal.ai API Keys
          </div>
          <p style="font-size: 12px; color: rgba(255,255,255,0.35); margin-bottom: 14px;">
            Add multiple API keys for fallback support. The primary key is used first; if it fails, fallback keys are tried in order.
          </p>
          <div id="apiKeysContainer"></div>
          <div class="d-flex gap-2 mt-3">
            <input type="text" class="form-control" id="newApiKey" placeholder="fal-xxxxxxxxxxxxxxxxxxxxxxxx" style="flex: 1; font-family: monospace;">
            <button class="btn-sm-action" id="btnAddApiKey" style="padding: 8px 16px; white-space: nowrap;">
              <i class="fa-solid fa-plus me-1"></i>Add Key
            </button>
          </div>
        </div>

        <!-- Site Configuration -->
        <div class="settings-group">
          <div class="settings-group-title">
            <i class="fa-solid fa-gear"></i>
            Site Configuration
          </div>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Site Name</label>
              <input type="text" class="form-control" id="settingSiteName" placeholder="KRSN">
            </div>
            <div class="col-md-6">
              <label class="form-label">Logo URL</label>
              <input type="text" class="form-control" id="settingLogoUrl" placeholder="https://example.com/logo.png">
            </div>
          </div>
        </div>

        <div class="d-flex justify-content-end">
          <button class="btn-save-settings" id="btnSaveSettings">
            <i class="fa-solid fa-check me-2"></i>Save Settings
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div class="toast-success" id="toastSuccess">Settings saved successfully</div>

  <!-- Adjust Credits Modal -->
  <div class="modal fade" id="adjustCreditsModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Adjust Credits</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" id="adjustUserId">
          <p style="font-size: 13px; color: rgba(255,255,255,0.5);">User: <strong id="adjustUserEmail" style="color: #fff;"></strong></p>
          <label class="form-label">Credits to add (negative to subtract)</label>
          <input type="number" class="form-control" id="adjustAmount" placeholder="e.g. 10 or -5">
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-sm-action" id="btnAdjustSubmit" style="padding: 8px 20px;">Apply</button>
        </div>
      </div>
    </div>
  </div>

  <script src="/public/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script>
    (function() {
      var token = localStorage.getItem('token');
      if (!token) { window.location.href = '/login'; return; }
      var headers = { 'Authorization': 'Bearer ' + token };
      var jsonHeaders = { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' };

      var barColors = [
        'linear-gradient(135deg, #7b5cff, #c86dd7)',
        'linear-gradient(135deg, #3b82f6, #06b6d4)',
        'linear-gradient(135deg, #f59e0b, #f97316)',
        'linear-gradient(135deg, #10b981, #34d399)',
        'linear-gradient(135deg, #ef4444, #f97316)',
        'linear-gradient(135deg, #a855f7, #ec4899)'
      ];

      // Profile & admin check
      fetch('/api/auth/profile', { headers: headers })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.user) {
            var name = data.user.name || data.user.email || 'User';
            document.getElementById('topbarUserName').textContent = name;
            document.getElementById('topbarAvatar').textContent = name.charAt(0).toUpperCase();
            if (data.user.role !== 'admin') {
              window.location.href = '/dashboard';
            }
          }
        });

      // Load admin stats
      fetch('/api/admin/stats', { headers: headers })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          document.getElementById('statUsers').textContent = data.totalUsers || 0;
          document.getElementById('statVideos').textContent = data.totalVideos || 0;
          document.getElementById('statCredits').textContent = data.creditsUsed || 0;
          document.getElementById('statRevenue').textContent = '$' + (data.revenue || 0).toFixed(2);
        })
        .catch(function() {});

      // --- Analytics: Videos by Model & Status ---
      var allAdminVideos = [];
      var allAdminUsers = [];

      fetch('/api/admin/videos', { headers: headers })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var videos = data.videos || data || [];
          if (!Array.isArray(videos)) videos = [];
          allAdminVideos = videos;
          renderAnalytics(videos);
          renderVideosTable(videos);
        })
        .catch(function() {
          renderAnalytics([]);
        });

      function renderAnalytics(videos) {
        // Videos by Model
        var modelCounts = {};
        videos.forEach(function(v) {
          var m = v.model || 'unknown';
          modelCounts[m] = (modelCounts[m] || 0) + 1;
        });
        var modelContainer = document.getElementById('analyticsByModel');
        var modelKeys = Object.keys(modelCounts).sort(function(a, b) { return modelCounts[b] - modelCounts[a]; });
        if (modelKeys.length === 0) {
          modelContainer.innerHTML = '<div style="text-align:center;padding:20px;color:rgba(255,255,255,0.2);font-size:13px;">No data</div>';
        } else {
          var maxModel = Math.max.apply(null, modelKeys.map(function(k) { return modelCounts[k]; }));
          var html = '';
          modelKeys.forEach(function(key, idx) {
            var pct = maxModel > 0 ? Math.round((modelCounts[key] / maxModel) * 100) : 0;
            html += '<div class="h-bar-row">' +
              '<div class="h-bar-label">' + key + '</div>' +
              '<div class="h-bar-track"><div class="h-bar-fill" style="width:' + pct + '%;background:' + barColors[idx % barColors.length] + ';"></div></div>' +
              '<div class="h-bar-count">' + modelCounts[key] + '</div>' +
            '</div>';
          });
          modelContainer.innerHTML = html;
        }

        // Videos by Status
        var statusCounts = { completed: 0, processing: 0, pending: 0, failed: 0 };
        videos.forEach(function(v) {
          var s = v.status || 'pending';
          if (statusCounts[s] !== undefined) statusCounts[s]++;
          else statusCounts[s] = 1;
        });
        var statusContainer = document.getElementById('analyticsByStatus');
        var statusConfig = [
          { key: 'completed', label: 'Completed', bg: 'rgba(16,185,129,0.12)', color: '#10b981' },
          { key: 'processing', label: 'Processing', bg: 'rgba(59,130,246,0.12)', color: '#3b82f6' },
          { key: 'pending', label: 'Pending', bg: 'rgba(245,158,11,0.12)', color: '#f59e0b' },
          { key: 'failed', label: 'Failed', bg: 'rgba(239,68,68,0.12)', color: '#ef4444' }
        ];
        var statusHtml = '<div class="status-blocks">';
        statusConfig.forEach(function(sc) {
          statusHtml += '<div class="status-block" style="background:' + sc.bg + ';">' +
            '<div class="sb-count">' + (statusCounts[sc.key] || 0) + '</div>' +
            '<div class="sb-label" style="color:' + sc.color + ';">' + sc.label + '</div>' +
          '</div>';
        });
        statusHtml += '</div>';
        statusContainer.innerHTML = statusHtml;
      }

      // --- Top Users ---
      function loadUsers() {
        fetch('/api/admin/users', { headers: headers })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var users = data.users || data || [];
            if (!Array.isArray(users)) users = [];
            allAdminUsers = users;
            renderUsersTable(users);
            renderTopUsers(users);
          });
      }

      function renderTopUsers(users) {
        var container = document.getElementById('topUsersContainer');
        var sorted = users.slice().sort(function(a, b) {
          var va = a.videoCount != null ? a.videoCount : (a._count && a._count.videos != null ? a._count.videos : 0);
          var vb = b.videoCount != null ? b.videoCount : (b._count && b._count.videos != null ? b._count.videos : 0);
          return vb - va;
        });
        var top = sorted.slice(0, 10);
        if (top.length === 0) {
          container.innerHTML = '<div style="text-align:center;padding:20px;color:rgba(255,255,255,0.2);font-size:13px;">No users</div>';
          return;
        }
        var rankColors = [
          { bg: 'rgba(245,158,11,0.15)', color: '#f59e0b' },
          { bg: 'rgba(192,192,192,0.12)', color: '#c0c0c0' },
          { bg: 'rgba(205,127,50,0.12)', color: '#cd7f32' }
        ];
        var html = '<table class="top-users-table"><thead><tr>' +
          '<th style="width:40px;">#</th><th>User</th><th>Videos</th><th>Credits</th><th>Role</th>' +
        '</tr></thead><tbody>';
        top.forEach(function(u, idx) {
          var videoCount = u.videoCount != null ? u.videoCount : (u._count && u._count.videos != null ? u._count.videos : 0);
          var rc = idx < 3 ? rankColors[idx] : { bg: 'rgba(255,255,255,0.04)', color: 'rgba(255,255,255,0.3)' };
          var roleClass = u.role === 'admin' ? 'role-admin' : 'role-user';
          html += '<tr>' +
            '<td><span class="top-user-rank" style="background:' + rc.bg + ';color:' + rc.color + ';">' + (idx + 1) + '</span></td>' +
            '<td style="color:rgba(255,255,255,0.7);font-weight:600;">' + (u.email || u.name || '--') + '</td>' +
            '<td>' + videoCount + '</td>' +
            '<td>' + (u.credits != null ? u.credits : 0) + '</td>' +
            '<td><span class="role-badge ' + roleClass + '">' + (u.role || 'user') + '</span></td>' +
          '</tr>';
        });
        html += '</tbody></table>';
        container.innerHTML = html;
      }

      function renderUsersTable(users) {
        var container = document.getElementById('usersTableContainer');
        if (users.length === 0) {
          container.innerHTML = '<div class="text-center py-4" style="color: rgba(255,255,255,0.3);">No users found</div>';
          return;
        }
        var html = '<table class="admin-table"><thead><tr>' +
          '<th>Email</th><th>Name</th><th>Credits</th><th>Videos</th><th>Role</th><th>Joined</th><th>Action</th>' +
          '</tr></thead><tbody>';
        users.forEach(function(u) {
          var id = u._id || u.id;
          var roleClass = u.role === 'admin' ? 'role-admin' : 'role-user';
          var date = u.createdAt ? new Date(u.createdAt).toLocaleDateString() : '--';
          var videoCount = u.videoCount != null ? u.videoCount : (u._count && u._count.videos != null ? u._count.videos : 0);
          html += '<tr>' +
            '<td>' + (u.email || '--') + '</td>' +
            '<td>' + (u.name || '--') + '</td>' +
            '<td>' + (u.credits != null ? u.credits : 0) + '</td>' +
            '<td>' + videoCount + '</td>' +
            '<td><span class="role-badge ' + roleClass + '">' + (u.role || 'user') + '</span></td>' +
            '<td>' + date + '</td>' +
            '<td><button class="btn-sm-action btn-adjust" data-id="' + id + '" data-email="' + (u.email || '') + '">Adjust Credits</button></td>' +
            '</tr>';
        });
        html += '</tbody></table>';
        container.innerHTML = html;

        container.querySelectorAll('.btn-adjust').forEach(function(btn) {
          btn.addEventListener('click', function() {
            document.getElementById('adjustUserId').value = this.getAttribute('data-id');
            document.getElementById('adjustUserEmail').textContent = this.getAttribute('data-email');
            document.getElementById('adjustAmount').value = '';
            new bootstrap.Modal(document.getElementById('adjustCreditsModal')).show();
          });
        });
      }

      // Adjust credits submit
      document.getElementById('btnAdjustSubmit').addEventListener('click', function() {
        var userId = document.getElementById('adjustUserId').value;
        var amount = parseInt(document.getElementById('adjustAmount').value);
        if (isNaN(amount)) return alert('Enter a valid number.');
        fetch('/api/admin/users/' + userId + '/credits', {
          method: 'PUT',
          headers: jsonHeaders,
          body: JSON.stringify({ credits: amount })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.error) alert(data.error);
          else {
            bootstrap.Modal.getInstance(document.getElementById('adjustCreditsModal')).hide();
            loadUsers();
          }
        });
      });

      // --- Videos Table ---
      function renderVideosTable(videos) {
        var container = document.getElementById('videosTableContainer');
        if (videos.length === 0) {
          container.innerHTML = '<div class="text-center py-4" style="color: rgba(255,255,255,0.3);">No videos found</div>';
          return;
        }
        var html = '<table class="admin-table"><thead><tr>' +
          '<th>User</th><th>Prompt</th><th>Model</th><th>Status</th><th>Date</th>' +
          '</tr></thead><tbody>';
        videos.slice(0, 20).forEach(function(v) {
          var statusClass = 'status-' + (v.status || 'pending');
          var date = v.createdAt ? new Date(v.createdAt).toLocaleDateString() : '--';
          var userEmail = v.user ? (v.user.email || '--') : (v.userEmail || '--');
          var prompt = (v.prompt || 'No prompt');
          if (prompt.length > 60) prompt = prompt.substring(0, 60) + '...';
          html += '<tr>' +
            '<td>' + userEmail + '</td>' +
            '<td>' + prompt + '</td>' +
            '<td>' + (v.model || '--') + '</td>' +
            '<td><span class="status-badge ' + statusClass + '">' + (v.status || 'pending') + '</span></td>' +
            '<td>' + date + '</td>' +
            '</tr>';
        });
        html += '</tbody></table>';
        container.innerHTML = html;
      }

      // --- API Key Management (new section) ---
      var managedApiKeys = [];

      function loadApiKeyMgmt() {
        fetch('/api/admin/api-keys', { headers: headers })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            managedApiKeys = data.apiKeys || data.keys || data || [];
            if (!Array.isArray(managedApiKeys)) managedApiKeys = [];
            renderApiKeyMgmt();
          })
          .catch(function() {
            // Fallback: load from settings
            fetch('/api/admin/settings', { headers: headers })
              .then(function(r) { return r.json(); })
              .then(function(data) {
                var settings = data.settings || data || {};
                var keys = settings.apiKeys || [];
                managedApiKeys = keys.map(function(k, idx) {
                  return { key: k, active: true, usage: 0, id: 'key-' + idx };
                });
                renderApiKeyMgmt();
              })
              .catch(function() { renderApiKeyMgmt(); });
          });
      }

      function renderApiKeyMgmt() {
        var container = document.getElementById('apiKeyMgmtContainer');
        if (managedApiKeys.length === 0) {
          container.innerHTML = '<div style="text-align:center;padding:20px;color:rgba(255,255,255,0.2);font-size:13px;"><i class="fa-solid fa-key" style="font-size:24px;display:block;margin-bottom:8px;"></i>No API keys configured</div>';
          return;
        }
        container.innerHTML = '';
        managedApiKeys.forEach(function(item, idx) {
          var keyStr = typeof item === 'string' ? item : (item.key || item.value || '');
          var isActive = typeof item === 'object' ? (item.active !== false) : true;
          var usage = typeof item === 'object' ? (item.usage || item.usageCount || 0) : 0;
          var keyId = typeof item === 'object' ? (item._id || item.id || 'key-' + idx) : 'key-' + idx;
          var masked = keyStr.length > 12 ? keyStr.substring(0, 8) + '...' + keyStr.substring(keyStr.length - 4) : keyStr;

          var row = document.createElement('div');
          row.className = 'apikey-mgmt-row';
          row.innerHTML =
            '<span class="apikey-mgmt-key">' + masked + '</span>' +
            '<span class="apikey-mgmt-usage"><i class="fa-solid fa-chart-line me-1"></i>' + usage + ' uses</span>' +
            '<span class="apikey-status-badge ' + (isActive ? 'apikey-active' : 'apikey-inactive') + '" data-idx="' + idx + '">' + (isActive ? 'Active' : 'Inactive') + '</span>' +
            '<button class="apikey-btn-del" data-idx="' + idx + '" data-id="' + keyId + '"><i class="fa-solid fa-trash"></i></button>';

          // Toggle active/inactive
          row.querySelector('.apikey-status-badge').addEventListener('click', function() {
            var i = parseInt(this.getAttribute('data-idx'));
            if (typeof managedApiKeys[i] === 'object') {
              managedApiKeys[i].active = !managedApiKeys[i].active;
            }
            // Try to update via API
            fetch('/api/admin/api-keys/' + keyId, {
              method: 'PUT',
              headers: jsonHeaders
            }).catch(function() {});
            renderApiKeyMgmt();
          });

          // Delete
          row.querySelector('.apikey-btn-del').addEventListener('click', function() {
            if (!confirm('Delete this API key?')) return;
            var delId = this.getAttribute('data-id');
            fetch('/api/admin/api-keys/' + delId, {
              method: 'DELETE',
              headers: headers
            }).then(function() {
              managedApiKeys.splice(idx, 1);
              renderApiKeyMgmt();
            }).catch(function() {
              managedApiKeys.splice(idx, 1);
              renderApiKeyMgmt();
            });
          });

          container.appendChild(row);
        });
      }

      document.getElementById('btnAddMgmtApiKey').addEventListener('click', function() {
        var input = document.getElementById('newMgmtApiKey');
        var key = input.value.trim();
        if (!key) return alert('Enter an API key.');
        // Try to add via API
        fetch('/api/admin/api-keys', {
          method: 'POST',
          headers: jsonHeaders,
          body: JSON.stringify({ key: key })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          input.value = '';
          loadApiKeyMgmt();
          showToast('API key added');
        })
        .catch(function() {
          // Fallback: add locally
          managedApiKeys.push({ key: key, active: true, usage: 0 });
          input.value = '';
          renderApiKeyMgmt();
        });
      });

      // --- Settings: API Keys (legacy) ---
      var apiKeys = [];

      function loadSettings() {
        fetch('/api/admin/settings', { headers: headers })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var settings = data.settings || data || {};
            apiKeys = settings.apiKeys || [];
            document.getElementById('settingSiteName').value = settings.siteName || '';
            document.getElementById('settingLogoUrl').value = settings.logoUrl || '';
            renderApiKeys();
          })
          .catch(function() {
            renderApiKeys();
          });
      }

      function renderApiKeys() {
        var container = document.getElementById('apiKeysContainer');
        if (apiKeys.length === 0) {
          container.innerHTML = '<div style="text-align: center; padding: 12px; color: rgba(255,255,255,0.2); font-size: 13px;">No API keys configured</div>';
          return;
        }
        container.innerHTML = '';
        apiKeys.forEach(function(key, idx) {
          var masked = key.substring(0, 8) + '...' + key.substring(key.length - 4);
          var statusLabel = idx === 0 ? 'Primary' : 'Fallback';
          var statusClass = idx === 0 ? 'key-active' : 'key-fallback';
          var row = document.createElement('div');
          row.className = 'api-key-row';
          row.innerHTML =
            '<span class="key-label">' + masked + '</span>' +
            '<span class="key-status ' + statusClass + '">' + statusLabel + '</span>' +
            '<button class="btn-remove-key" data-idx="' + idx + '"><i class="fa-solid fa-xmark"></i></button>';
          row.querySelector('.btn-remove-key').addEventListener('click', function() {
            apiKeys.splice(idx, 1);
            renderApiKeys();
          });
          container.appendChild(row);
        });
      }

      document.getElementById('btnAddApiKey').addEventListener('click', function() {
        var input = document.getElementById('newApiKey');
        var key = input.value.trim();
        if (!key) return alert('Enter an API key.');
        apiKeys.push(key);
        input.value = '';
        renderApiKeys();
      });

      // Save settings
      document.getElementById('btnSaveSettings').addEventListener('click', function() {
        var btn = this;
        btn.disabled = true;
        btn.textContent = 'Saving...';
        var settings = [
          { key: 'siteName', value: document.getElementById('settingSiteName').value.trim() },
          { key: 'logoUrl', value: document.getElementById('settingLogoUrl').value.trim() }
        ];
        Promise.all(settings.map(function(s) {
          return fetch('/api/admin/settings', {
            method: 'PUT',
            headers: jsonHeaders,
            body: JSON.stringify(s)
          }).then(function(r) { return r.json(); });
        }))
        .then(function() {
          showToast('Settings saved successfully');
          btn.disabled = false;
          btn.innerHTML = '<i class="fa-solid fa-check me-2"></i>Save Settings';
        })
        .catch(function() {
          alert('Failed to save settings.');
          btn.disabled = false;
          btn.innerHTML = '<i class="fa-solid fa-check me-2"></i>Save Settings';
        });
      });

      function showToast(msg) {
        var toast = document.getElementById('toastSuccess');
        toast.textContent = msg;
        toast.style.display = 'block';
        setTimeout(function() { toast.style.display = 'none'; }, 3000);
      }

      // Initialize
      loadUsers();
      loadSettings();
      loadApiKeyMgmt();
    })();
  </script>
</body>
</html>
