<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <%- include('../partials/head') %>
  <style>
    body {
      background: #0a0a14;
      margin: 0;
      font-family: 'Manrope', sans-serif;
    }
    .dash-main { margin-left: 260px; min-height: 100vh; }
    .dash-topbar {
      padding: 20px 32px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .dash-topbar h1 { font-size: 22px; font-weight: 700; color: #fff; margin: 0; }
    .dash-topbar .user-info { display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,0.6); font-size: 14px; }
    .dash-topbar .user-avatar { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #7b5cff, #c86dd7); display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700; font-size: 14px; }
    .dash-content { padding: 28px 32px; }
    .section-title { font-size: 17px; font-weight: 700; color: #fff; margin-bottom: 20px; }

    .stat-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      padding: 24px;
      transition: all 0.2s ease;
    }
    .stat-card:hover { border-color: rgba(123,92,255,0.2); }
    .stat-card .stat-icon {
      width: 44px; height: 44px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; margin-bottom: 16px;
    }
    .stat-card .stat-value { font-size: 28px; font-weight: 800; color: #fff; margin-bottom: 4px; }
    .stat-card .stat-label { font-size: 13px; color: rgba(255,255,255,0.45); font-weight: 500; }

    .admin-panel {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      overflow: hidden;
      margin-bottom: 28px;
    }
    .admin-table { width: 100%; border-collapse: separate; border-spacing: 0; }
    .admin-table th {
      text-align: left; padding: 12px 16px; font-size: 11px; font-weight: 600;
      color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.5px;
      border-bottom: 1px solid rgba(255,255,255,0.06); background: rgba(255,255,255,0.02);
    }
    .admin-table td {
      padding: 12px 16px; font-size: 13px; color: rgba(255,255,255,0.6);
      border-bottom: 1px solid rgba(255,255,255,0.04); vertical-align: middle;
    }
    .admin-table tr:last-child td { border-bottom: none; }
    .admin-table tr:hover td { background: rgba(255,255,255,0.02); }

    .role-badge {
      font-size: 10px; padding: 2px 8px; border-radius: 20px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.5px;
    }
    .role-admin { background: rgba(239,68,68,0.15); color: #ef4444; }
    .role-user { background: rgba(59,130,246,0.15); color: #3b82f6; }

    .status-badge {
      font-size: 11px; padding: 3px 10px; border-radius: 20px; font-weight: 600;
    }
    .status-pending { background: rgba(245,158,11,0.15); color: #f59e0b; }
    .status-processing { background: rgba(59,130,246,0.15); color: #3b82f6; }
    .status-completed { background: rgba(16,185,129,0.15); color: #10b981; }
    .status-failed { background: rgba(239,68,68,0.15); color: #ef4444; }

    .btn-sm-action {
      padding: 5px 12px; border-radius: 6px; font-size: 11px; font-weight: 600;
      cursor: pointer; border: 1px solid rgba(123,92,255,0.3);
      background: rgba(123,92,255,0.1); color: #a78bfa;
      transition: all 0.15s ease;
    }
    .btn-sm-action:hover { background: rgba(123,92,255,0.2); }

    .settings-panel {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      padding: 28px;
      margin-bottom: 28px;
    }
    .settings-group {
      margin-bottom: 24px;
      padding-bottom: 24px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .settings-group:last-child { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
    .settings-group-title {
      font-size: 14px; font-weight: 700; color: rgba(255,255,255,0.8); margin-bottom: 16px;
      display: flex; align-items: center; gap: 8px;
    }
    .settings-group-title i { color: #a78bfa; font-size: 14px; }

    .form-label { color: rgba(255,255,255,0.7); font-size: 12px; font-weight: 600; margin-bottom: 6px; }
    .form-control, .form-select {
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1);
      border-radius: 8px; color: #fff; font-size: 13px; padding: 8px 12px;
    }
    .form-control:focus, .form-select:focus {
      background: rgba(255,255,255,0.06); border-color: rgba(123,92,255,0.4);
      box-shadow: 0 0 0 3px rgba(123,92,255,0.1); color: #fff;
    }
    .form-control::placeholder { color: rgba(255,255,255,0.25); }

    .api-key-row {
      display: flex; align-items: center; gap: 8px; margin-bottom: 8px;
      padding: 10px 14px; border-radius: 8px;
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.06);
    }
    .api-key-row .key-label { flex: 1; font-size: 13px; color: rgba(255,255,255,0.5); font-family: monospace; }
    .api-key-row .key-status {
      font-size: 10px; padding: 2px 8px; border-radius: 10px; font-weight: 600;
    }
    .api-key-row .key-active { background: rgba(16,185,129,0.15); color: #10b981; }
    .api-key-row .key-fallback { background: rgba(245,158,11,0.15); color: #f59e0b; }
    .api-key-row .btn-remove-key {
      background: none; border: none; color: rgba(239,68,68,0.5); cursor: pointer;
      font-size: 14px; padding: 2px 6px; transition: all 0.15s ease;
    }
    .api-key-row .btn-remove-key:hover { color: #ef4444; }

    .btn-save-settings {
      background: linear-gradient(135deg, #7b5cff, #c86dd7);
      border: none; color: #fff; padding: 10px 24px;
      border-radius: 8px; font-size: 13px; font-weight: 700;
      cursor: pointer; transition: all 0.2s ease;
    }
    .btn-save-settings:hover { opacity: 0.9; }
    .btn-save-settings:disabled { opacity: 0.5; cursor: not-allowed; }

    .toast-success {
      position: fixed; bottom: 24px; right: 24px; z-index: 9999;
      background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.3);
      color: #10b981; padding: 12px 20px; border-radius: 10px;
      font-size: 13px; font-weight: 600; display: none;
      animation: slideIn 0.3s ease;
    }
    @keyframes slideIn { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

    .modal-content {
      background: #141425;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
    }
    .modal-header { border-bottom: 1px solid rgba(255,255,255,0.06); }
    .modal-footer { border-top: 1px solid rgba(255,255,255,0.06); }
    .modal-title { color: #fff; font-weight: 700; }
    .btn-close { filter: invert(1); }
  </style>
</head>
<body>
  <%- include('../partials/sidebar') %>

  <div class="dash-main">
    <div class="dash-topbar">
      <h1><i class="fa-solid fa-shield me-2" style="color: #a78bfa;"></i>Admin Panel</h1>
      <div class="user-info">
        <span id="topbarUserName"></span>
        <div class="user-avatar" id="topbarAvatar"></div>
      </div>
    </div>

    <div class="dash-content">
      <!-- Stats Row -->
      <div class="row g-4 mb-4">
        <div class="col-lg-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon" style="background: rgba(59,130,246,0.12); color: #3b82f6;">
              <i class="fa-solid fa-users"></i>
            </div>
            <div class="stat-value" id="statUsers">--</div>
            <div class="stat-label">Total Users</div>
          </div>
        </div>
        <div class="col-lg-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon" style="background: rgba(16,185,129,0.12); color: #10b981;">
              <i class="fa-solid fa-film"></i>
            </div>
            <div class="stat-value" id="statVideos">--</div>
            <div class="stat-label">Total Videos</div>
          </div>
        </div>
        <div class="col-lg-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon" style="background: rgba(245,158,11,0.12); color: #f59e0b;">
              <i class="fa-solid fa-coins"></i>
            </div>
            <div class="stat-value" id="statCredits">--</div>
            <div class="stat-label">Credits Used</div>
          </div>
        </div>
        <div class="col-lg-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon" style="background: rgba(168,85,247,0.12); color: #a855f7;">
              <i class="fa-solid fa-dollar-sign"></i>
            </div>
            <div class="stat-value" id="statRevenue">--</div>
            <div class="stat-label">Revenue</div>
          </div>
        </div>
      </div>

      <!-- Users Table -->
      <div class="section-title">Users</div>
      <div class="admin-panel">
        <div id="usersTableContainer">
          <div class="text-center py-4">
            <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
          </div>
        </div>
      </div>

      <!-- Recent Videos Table -->
      <div class="section-title">Recent Videos</div>
      <div class="admin-panel">
        <div id="videosTableContainer">
          <div class="text-center py-4">
            <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
          </div>
        </div>
      </div>

      <!-- Settings Section -->
      <div class="section-title">Settings</div>
      <div class="settings-panel">
        <!-- fal.ai API Keys -->
        <div class="settings-group">
          <div class="settings-group-title">
            <i class="fa-solid fa-key"></i>
            fal.ai API Keys
          </div>
          <p style="font-size: 12px; color: rgba(255,255,255,0.35); margin-bottom: 14px;">
            Add multiple API keys for fallback support. The primary key is used first; if it fails, fallback keys are tried in order.
          </p>
          <div id="apiKeysContainer"></div>
          <div class="d-flex gap-2 mt-3">
            <input type="text" class="form-control" id="newApiKey" placeholder="fal-xxxxxxxxxxxxxxxxxxxxxxxx" style="flex: 1; font-family: monospace;">
            <button class="btn-sm-action" id="btnAddApiKey" style="padding: 8px 16px; white-space: nowrap;">
              <i class="fa-solid fa-plus me-1"></i>Add Key
            </button>
          </div>
        </div>

        <!-- Site Configuration -->
        <div class="settings-group">
          <div class="settings-group-title">
            <i class="fa-solid fa-gear"></i>
            Site Configuration
          </div>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Site Name</label>
              <input type="text" class="form-control" id="settingSiteName" placeholder="VideoGen AI">
            </div>
            <div class="col-md-6">
              <label class="form-label">Logo URL</label>
              <input type="text" class="form-control" id="settingLogoUrl" placeholder="https://example.com/logo.png">
            </div>
          </div>
        </div>

        <div class="d-flex justify-content-end">
          <button class="btn-save-settings" id="btnSaveSettings">
            <i class="fa-solid fa-check me-2"></i>Save Settings
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div class="toast-success" id="toastSuccess">Settings saved successfully</div>

  <!-- Adjust Credits Modal -->
  <div class="modal fade" id="adjustCreditsModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Adjust Credits</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" id="adjustUserId">
          <p style="font-size: 13px; color: rgba(255,255,255,0.5);">User: <strong id="adjustUserEmail" style="color: #fff;"></strong></p>
          <label class="form-label">Credits to add (negative to subtract)</label>
          <input type="number" class="form-control" id="adjustAmount" placeholder="e.g. 10 or -5">
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-sm-action" id="btnAdjustSubmit" style="padding: 8px 20px;">Apply</button>
        </div>
      </div>
    </div>
  </div>

  <script src="/public/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script>
    (function() {
      var token = localStorage.getItem('token');
      if (!token) { window.location.href = '/login'; return; }
      var headers = { 'Authorization': 'Bearer ' + token };
      var jsonHeaders = { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' };

      // Profile & admin check
      fetch('/api/auth/profile', { headers: headers })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.user) {
            var name = data.user.name || data.user.email || 'User';
            document.getElementById('topbarUserName').textContent = name;
            document.getElementById('topbarAvatar').textContent = name.charAt(0).toUpperCase();
            if (data.user.role !== 'admin') {
              window.location.href = '/dashboard';
            }
          }
        });

      // Load admin stats
      fetch('/api/admin/stats', { headers: headers })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          document.getElementById('statUsers').textContent = data.totalUsers || 0;
          document.getElementById('statVideos').textContent = data.totalVideos || 0;
          document.getElementById('statCredits').textContent = data.creditsUsed || 0;
          document.getElementById('statRevenue').textContent = '$' + (data.revenue || 0).toFixed(2);
        })
        .catch(function() {});

      // --- Users Table ---
      function loadUsers() {
        fetch('/api/admin/users', { headers: headers })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var users = data.users || data || [];
            if (!Array.isArray(users)) users = [];
            var container = document.getElementById('usersTableContainer');

            if (users.length === 0) {
              container.innerHTML = '<div class="text-center py-4" style="color: rgba(255,255,255,0.3);">No users found</div>';
              return;
            }

            var html = '<table class="admin-table"><thead><tr>' +
              '<th>Email</th><th>Name</th><th>Credits</th><th>Videos</th><th>Role</th><th>Joined</th><th>Action</th>' +
              '</tr></thead><tbody>';
            users.forEach(function(u) {
              var id = u._id || u.id;
              var roleClass = u.role === 'admin' ? 'role-admin' : 'role-user';
              var date = u.createdAt ? new Date(u.createdAt).toLocaleDateString() : '--';
              var videoCount = u.videoCount != null ? u.videoCount : (u._count && u._count.videos != null ? u._count.videos : 0);
              html += '<tr>' +
                '<td>' + (u.email || '--') + '</td>' +
                '<td>' + (u.name || '--') + '</td>' +
                '<td>' + (u.credits != null ? u.credits : 0) + '</td>' +
                '<td>' + videoCount + '</td>' +
                '<td><span class="role-badge ' + roleClass + '">' + (u.role || 'user') + '</span></td>' +
                '<td>' + date + '</td>' +
                '<td><button class="btn-sm-action btn-adjust" data-id="' + id + '" data-email="' + (u.email || '') + '">Adjust Credits</button></td>' +
                '</tr>';
            });
            html += '</tbody></table>';
            container.innerHTML = html;

            container.querySelectorAll('.btn-adjust').forEach(function(btn) {
              btn.addEventListener('click', function() {
                document.getElementById('adjustUserId').value = this.getAttribute('data-id');
                document.getElementById('adjustUserEmail').textContent = this.getAttribute('data-email');
                document.getElementById('adjustAmount').value = '';
                new bootstrap.Modal(document.getElementById('adjustCreditsModal')).show();
              });
            });
          });
      }

      // Adjust credits submit
      document.getElementById('btnAdjustSubmit').addEventListener('click', function() {
        var userId = document.getElementById('adjustUserId').value;
        var amount = parseInt(document.getElementById('adjustAmount').value);
        if (isNaN(amount)) return alert('Enter a valid number.');
        fetch('/api/admin/users/' + userId + '/credits', {
          method: 'POST',
          headers: jsonHeaders,
          body: JSON.stringify({ credits: amount })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.error) alert(data.error);
          else {
            bootstrap.Modal.getInstance(document.getElementById('adjustCreditsModal')).hide();
            loadUsers();
          }
        });
      });

      // --- Videos Table ---
      fetch('/api/admin/videos', { headers: headers })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var videos = data.videos || data || [];
          if (!Array.isArray(videos)) videos = [];
          var container = document.getElementById('videosTableContainer');

          if (videos.length === 0) {
            container.innerHTML = '<div class="text-center py-4" style="color: rgba(255,255,255,0.3);">No videos found</div>';
            return;
          }

          var html = '<table class="admin-table"><thead><tr>' +
            '<th>User</th><th>Prompt</th><th>Model</th><th>Status</th><th>Date</th>' +
            '</tr></thead><tbody>';
          videos.slice(0, 20).forEach(function(v) {
            var statusClass = 'status-' + (v.status || 'pending');
            var date = v.createdAt ? new Date(v.createdAt).toLocaleDateString() : '--';
            var userEmail = v.user ? (v.user.email || '--') : (v.userEmail || '--');
            var prompt = (v.prompt || 'No prompt');
            if (prompt.length > 60) prompt = prompt.substring(0, 60) + '...';
            html += '<tr>' +
              '<td>' + userEmail + '</td>' +
              '<td>' + prompt + '</td>' +
              '<td>' + (v.model || '--') + '</td>' +
              '<td><span class="status-badge ' + statusClass + '">' + (v.status || 'pending') + '</span></td>' +
              '<td>' + date + '</td>' +
              '</tr>';
          });
          html += '</tbody></table>';
          container.innerHTML = html;
        });

      // --- Settings: API Keys ---
      var apiKeys = [];

      function loadSettings() {
        fetch('/api/admin/settings', { headers: headers })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var settings = data.settings || data || {};
            apiKeys = settings.apiKeys || [];
            document.getElementById('settingSiteName').value = settings.siteName || '';
            document.getElementById('settingLogoUrl').value = settings.logoUrl || '';
            renderApiKeys();
          })
          .catch(function() {
            // Settings endpoint may not exist yet
            renderApiKeys();
          });
      }

      function renderApiKeys() {
        var container = document.getElementById('apiKeysContainer');
        if (apiKeys.length === 0) {
          container.innerHTML = '<div style="text-align: center; padding: 12px; color: rgba(255,255,255,0.2); font-size: 13px;">No API keys configured</div>';
          return;
        }
        container.innerHTML = '';
        apiKeys.forEach(function(key, idx) {
          var masked = key.substring(0, 8) + '...' + key.substring(key.length - 4);
          var statusLabel = idx === 0 ? 'Primary' : 'Fallback';
          var statusClass = idx === 0 ? 'key-active' : 'key-fallback';
          var row = document.createElement('div');
          row.className = 'api-key-row';
          row.innerHTML =
            '<span class="key-label">' + masked + '</span>' +
            '<span class="key-status ' + statusClass + '">' + statusLabel + '</span>' +
            '<button class="btn-remove-key" data-idx="' + idx + '"><i class="fa-solid fa-xmark"></i></button>';
          row.querySelector('.btn-remove-key').addEventListener('click', function() {
            apiKeys.splice(idx, 1);
            renderApiKeys();
          });
          container.appendChild(row);
        });
      }

      document.getElementById('btnAddApiKey').addEventListener('click', function() {
        var input = document.getElementById('newApiKey');
        var key = input.value.trim();
        if (!key) return alert('Enter an API key.');
        apiKeys.push(key);
        input.value = '';
        renderApiKeys();
      });

      // Save settings
      document.getElementById('btnSaveSettings').addEventListener('click', function() {
        var btn = this;
        btn.disabled = true;
        btn.textContent = 'Saving...';
        var body = {
          apiKeys: apiKeys,
          siteName: document.getElementById('settingSiteName').value.trim(),
          logoUrl: document.getElementById('settingLogoUrl').value.trim()
        };
        fetch('/api/admin/settings', {
          method: 'POST',
          headers: jsonHeaders,
          body: JSON.stringify(body)
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.error) {
            alert(data.error);
          } else {
            showToast('Settings saved successfully');
          }
          btn.disabled = false;
          btn.innerHTML = '<i class="fa-solid fa-check me-2"></i>Save Settings';
        })
        .catch(function() {
          alert('Failed to save settings.');
          btn.disabled = false;
          btn.innerHTML = '<i class="fa-solid fa-check me-2"></i>Save Settings';
        });
      });

      function showToast(msg) {
        var toast = document.getElementById('toastSuccess');
        toast.textContent = msg;
        toast.style.display = 'block';
        setTimeout(function() { toast.style.display = 'none'; }, 3000);
      }

      // Initialize
      loadUsers();
      loadSettings();
    })();
  </script>
</body>
</html>
