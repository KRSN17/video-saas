<%- include('../partials/head') %>
<body>
<div class="dashboard-wrapper">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <div class="content-header">
      <h2 class="gradient-text">Admin Panel</h2>
      <p class="text-secondary">Manage your SaaS platform</p>
    </div>
    <div class="content-body">
      <div class="row g-4 mb-4">
        <div class="col-md-3"><div class="glass-card p-4 text-center"><i class="fa-solid fa-users fa-2x mb-2 text-info"></i><h3 id="statUsers">0</h3><p class="text-secondary mb-0">Total Users</p></div></div>
        <div class="col-md-3"><div class="glass-card p-4 text-center"><i class="fa-solid fa-video fa-2x mb-2 text-success"></i><h3 id="statVideos">0</h3><p class="text-secondary mb-0">Videos Generated</p></div></div>
        <div class="col-md-3"><div class="glass-card p-4 text-center"><i class="fa-solid fa-coins fa-2x mb-2 text-warning"></i><h3 id="statCredits">0</h3><p class="text-secondary mb-0">Credits Used</p></div></div>
        <div class="col-md-3"><div class="glass-card p-4 text-center"><i class="fa-solid fa-dollar-sign fa-2x mb-2 text-success"></i><h3 id="statRevenue">$0</h3><p class="text-secondary mb-0">Revenue</p></div></div>
      </div>
      <div class="row g-4">
        <div class="col-lg-7">
          <div class="glass-card p-4">
            <h5 class="mb-3"><i class="fa-solid fa-users me-2"></i>Users</h5>
            <div class="table-responsive">
              <table class="table table-dark-custom">
                <thead><tr><th>Email</th><th>Name</th><th>Credits</th><th>Videos</th><th>Role</th><th>Actions</th></tr></thead>
                <tbody id="adminUsers"><tr><td colspan="6" class="text-center text-secondary">Loading...</td></tr></tbody>
              </table>
            </div>
          </div>
        </div>
        <div class="col-lg-5">
          <div class="glass-card p-4">
            <h5 class="mb-3"><i class="fa-solid fa-film me-2"></i>Recent Videos</h5>
            <div class="table-responsive">
              <table class="table table-dark-custom">
                <thead><tr><th>User</th><th>Prompt</th><th>Status</th></tr></thead>
                <tbody id="adminVideos"><tr><td colspan="3" class="text-center text-secondary">Loading...</td></tr></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
<script src="/public/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="/public/js/app.js"></script>
</body></html>
