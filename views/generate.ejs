<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <%- include('partials/head') %>
  <style>
    body {
      background: #0a0a14;
      margin: 0;
      font-family: 'Manrope', sans-serif;
    }
    .dash-main {
      margin-left: 260px;
      min-height: 100vh;
    }
    .dash-topbar {
      padding: 20px 32px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .dash-topbar h1 { font-size: 22px; font-weight: 700; color: #fff; margin: 0; }
    .dash-topbar .user-info { display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,0.6); font-size: 14px; }
    .dash-topbar .user-avatar { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #7b5cff, #c86dd7); display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700; font-size: 14px; }
    .dash-content { padding: 28px 32px; max-width: 900px; }
    .form-panel {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      padding: 28px;
    }
    .form-label { color: rgba(255,255,255,0.7); font-size: 13px; font-weight: 600; margin-bottom: 8px; }
    .form-control, .form-select {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 10px;
      color: #fff;
      font-size: 14px;
      padding: 10px 14px;
    }
    .form-control:focus, .form-select:focus {
      background: rgba(255,255,255,0.06);
      border-color: rgba(123,92,255,0.4);
      box-shadow: 0 0 0 3px rgba(123,92,255,0.1);
      color: #fff;
    }
    .form-control::placeholder { color: rgba(255,255,255,0.25); }
    .form-select option { background: #1a1a2e; color: #fff; }
    textarea.form-control { min-height: 120px; resize: vertical; }
    .char-counter { font-size: 11px; color: rgba(255,255,255,0.3); text-align: right; margin-top: 4px; }
    .option-group { display: flex; gap: 8px; flex-wrap: wrap; }
    .option-btn {
      padding: 8px 18px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      border: 1px solid rgba(255,255,255,0.1);
      background: rgba(255,255,255,0.03);
      color: rgba(255,255,255,0.5);
      transition: all 0.2s ease;
    }
    .option-btn.active {
      background: rgba(123,92,255,0.2);
      border-color: rgba(123,92,255,0.4);
      color: #fff;
    }
    .option-btn:hover { border-color: rgba(123,92,255,0.3); color: #fff; }
    .credit-cost {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(245,158,11,0.1);
      border: 1px solid rgba(245,158,11,0.2);
      border-radius: 8px;
      padding: 6px 14px;
      color: #f59e0b;
      font-size: 13px;
      font-weight: 600;
    }
    .btn-generate {
      background: linear-gradient(135deg, #7b5cff, #c86dd7);
      border: none;
      color: #fff;
      padding: 12px 32px;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .btn-generate:hover { opacity: 0.9; transform: translateY(-1px); }
    .btn-generate:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
    .image-url-row { display: none; }
    .image-url-row.visible { display: block; }
    #statusSection {
      display: none;
      margin-top: 28px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      padding: 28px;
      text-align: center;
    }
    .progress-spinner {
      width: 56px;
      height: 56px;
      border: 3px solid rgba(123,92,255,0.15);
      border-top-color: #7b5cff;
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin: 0 auto 16px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .progress-status { color: rgba(255,255,255,0.6); font-size: 14px; }
    .progress-status strong { color: #fff; }
    #videoPreview { display: none; margin-top: 16px; max-width: 480px; border-radius: 12px; }

    /* Prompt Enhancer */
    .prompt-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
    .btn-enhance {
      background: linear-gradient(135deg, #f59e0b, #f97316);
      border: none;
      color: #fff;
      padding: 6px 16px;
      border-radius: 8px;
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s ease;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .btn-enhance:hover { opacity: 0.85; transform: translateY(-1px); }
    .btn-enhance:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
    .btn-enhance .enhance-spinner {
      width: 12px; height: 12px;
      border: 2px solid rgba(255,255,255,0.3);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      display: none;
    }
    .enhance-preview {
      display: none;
      margin-top: 12px;
      background: rgba(245,158,11,0.06);
      border: 1px solid rgba(245,158,11,0.15);
      border-radius: 10px;
      padding: 16px;
    }
    .enhance-preview-label {
      font-size: 11px;
      font-weight: 700;
      color: #f59e0b;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .enhance-preview-text {
      font-size: 13px;
      color: rgba(255,255,255,0.7);
      line-height: 1.6;
      margin-bottom: 12px;
    }
    .btn-use-enhanced {
      background: rgba(245,158,11,0.15);
      border: 1px solid rgba(245,158,11,0.3);
      color: #f59e0b;
      padding: 6px 16px;
      border-radius: 8px;
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s ease;
      margin-right: 8px;
    }
    .btn-use-enhanced:hover { background: rgba(245,158,11,0.25); }
    .btn-dismiss-enhanced {
      background: none;
      border: 1px solid rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.4);
      padding: 6px 16px;
      border-radius: 8px;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .btn-dismiss-enhanced:hover { color: rgba(255,255,255,0.7); border-color: rgba(255,255,255,0.2); }

    /* Model selector card style */
    .model-select-wrapper { position: relative; }
    .model-cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 10px;
      margin-top: 8px;
    }
    .model-card-option {
      background: rgba(255,255,255,0.03);
      border: 2px solid rgba(255,255,255,0.06);
      border-radius: 12px;
      padding: 14px 16px;
      cursor: pointer;
      transition: all 0.2s ease;
      position: relative;
    }
    .model-card-option:hover {
      border-color: rgba(123,92,255,0.3);
      background: rgba(123,92,255,0.04);
    }
    .model-card-option.selected {
      border-color: rgba(123,92,255,0.5);
      background: rgba(123,92,255,0.08);
      box-shadow: 0 0 20px rgba(123,92,255,0.1);
    }
    .model-card-option .model-name {
      font-size: 14px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 6px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .model-card-option .model-meta {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }
    .model-type-badge {
      font-size: 10px;
      padding: 2px 8px;
      border-radius: 6px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.3px;
    }
    .type-text { background: rgba(59,130,246,0.15); color: #3b82f6; }
    .type-image { background: rgba(168,85,247,0.15); color: #a855f7; }
    .model-credit-badge {
      font-size: 10px;
      padding: 2px 8px;
      border-radius: 6px;
      font-weight: 700;
      background: rgba(245,158,11,0.12);
      color: #f59e0b;
    }
    .model-quality-badge {
      font-size: 10px;
      padding: 2px 8px;
      border-radius: 6px;
      font-weight: 700;
    }
    .quality-high { background: rgba(16,185,129,0.15); color: #10b981; }
    .quality-standard { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.4); }
    .quality-premium { background: rgba(245,158,11,0.15); color: #f59e0b; }
    .model-card-check {
      position: absolute;
      top: 10px;
      right: 10px;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: linear-gradient(135deg, #7b5cff, #c86dd7);
      display: none;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      color: #fff;
    }
    .model-card-option.selected .model-card-check { display: flex; }
    .models-loading {
      text-align: center;
      padding: 24px;
      color: rgba(255,255,255,0.3);
      font-size: 13px;
    }
  </style>
</head>
<body>
  <%- include('partials/sidebar') %>

  <div class="dash-main">
    <div class="dash-topbar">
      <h1>Generate Video</h1>
      <div class="user-info">
        <span id="topbarUserName"></span>
        <div class="user-avatar" id="topbarAvatar"></div>
      </div>
    </div>

    <div class="dash-content">
      <div class="form-panel">
        <form id="generateForm" autocomplete="off">
          <!-- Model Selector -->
          <div class="mb-3">
            <label class="form-label">AI Model</label>
            <input type="hidden" id="modelSelect" name="model" value="">
            <div class="models-loading" id="modelsLoading">
              <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
              <span style="margin-left: 8px;">Loading models...</span>
            </div>
            <div class="model-cards-grid" id="modelCardsGrid"></div>
          </div>

          <!-- Prompt with Enhance Button -->
          <div class="mb-3">
            <div class="prompt-header">
              <label class="form-label" style="margin-bottom: 0;">Prompt</label>
              <button type="button" class="btn-enhance" id="btnEnhance">
                <span class="enhance-spinner" id="enhanceSpinner"></span>
                <i class="fa-solid fa-wand-magic-sparkles" id="enhanceIcon"></i>
                Enhance Prompt
              </button>
            </div>
            <textarea class="form-control" id="prompt" name="prompt" maxlength="2000"
              placeholder="Describe the video you want to generate..."></textarea>
            <div class="char-counter"><span id="charCount">0</span> / 2000</div>

            <!-- Enhanced Prompt Preview -->
            <div class="enhance-preview" id="enhancePreview">
              <div class="enhance-preview-label">
                <i class="fa-solid fa-sparkles"></i> Enhanced Prompt
              </div>
              <div class="enhance-preview-text" id="enhancedText"></div>
              <div>
                <button type="button" class="btn-use-enhanced" id="btnUseEnhanced">
                  <i class="fa-solid fa-check me-1"></i>Use Enhanced
                </button>
                <button type="button" class="btn-dismiss-enhanced" id="btnDismissEnhanced">
                  <i class="fa-solid fa-xmark me-1"></i>Dismiss
                </button>
              </div>
            </div>
          </div>

          <div class="mb-3 image-url-row" id="imageUrlRow">
            <label class="form-label">Upload Image</label>
            <div id="imageDropzone" style="border:2px dashed rgba(255,255,255,0.12); border-radius:12px; padding:24px; text-align:center; cursor:pointer; transition:all 0.2s; background:rgba(255,255,255,0.02);">
              <div style="color:rgba(255,255,255,0.3); font-size:13px;">
                <i class="fa-solid fa-cloud-arrow-up" style="font-size:24px; display:block; margin-bottom:8px;"></i>
                Drop image here or click to browse
              </div>
              <img id="imagePreviewThumb" style="display:none; max-width:100%; max-height:120px; border-radius:8px; margin-top:12px;">
            </div>
            <input type="file" id="imageFileInput" accept="image/*" style="display:none;">
            <input type="hidden" id="imageUrl" name="imageUrl">
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="form-label">Duration</label>
              <div class="option-group" id="durationGroup">
                <div class="option-btn active" data-value="5">5s</div>
                <div class="option-btn" data-value="10">10s</div>
              </div>
            </div>
            <div class="col-md-6">
              <label class="form-label">Aspect Ratio</label>
              <div class="option-group" id="ratioGroup">
                <div class="option-btn active" data-value="16:9">16:9</div>
                <div class="option-btn" data-value="9:16">9:16</div>
                <div class="option-btn" data-value="1:1">1:1</div>
              </div>
            </div>
          </div>

          <div class="d-flex align-items-center justify-content-between mt-4">
            <div class="credit-cost" id="creditCostDisplay">
              <i class="fa-solid fa-coins"></i>
              <span id="creditCostText">1 credit</span>
            </div>
            <button type="submit" class="btn-generate" id="btnGenerate">
              <i class="fa-solid fa-wand-magic-sparkles me-2"></i>Generate Video
            </button>
          </div>
        </form>
      </div>

      <!-- Status Section -->
      <div id="statusSection">
        <div class="progress-spinner" id="statusSpinner"></div>
        <div class="progress-status">
          <strong id="genStatus">Submitting...</strong>
          <div style="margin-top: 6px; font-size: 13px;" id="genDetail">Sending request to AI model</div>
        </div>
        <video id="videoPreview" controls></video>
      </div>
    </div>
  </div>

  <script src="/public/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script>
    (function() {
      var token = localStorage.getItem('token');
      if (!token) { window.location.href = '/login'; return; }
      var headers = { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' };

      // Profile
      fetch('/api/auth/profile', { headers: { 'Authorization': 'Bearer ' + token } })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.user) {
            var name = data.user.name || data.user.email || 'User';
            document.getElementById('topbarUserName').textContent = name;
            document.getElementById('topbarAvatar').textContent = name.charAt(0).toUpperCase();
          }
        });

      // --- Load ALL models from API ---
      var allModels = [];
      var selectedModel = '';
      var modelCreditMap = {};

      var fallbackModels = [
        { id: 'kling-text', name: 'Kling Text-to-Video', type: 'text', credits: 1, quality: 'high' },
        { id: 'kling-image', name: 'Kling Image-to-Video', type: 'image', credits: 1, quality: 'high' },
        { id: 'minimax-text', name: 'MiniMax', type: 'text', credits: 1, quality: 'standard' },
        { id: 'wan-text', name: 'Wan', type: 'text', credits: 1, quality: 'standard' }
      ];

      function renderModelCards(models) {
        var grid = document.getElementById('modelCardsGrid');
        document.getElementById('modelsLoading').style.display = 'none';
        grid.innerHTML = '';
        models.forEach(function(m, idx) {
          var typeClass = (m.type === 'image' || m.type === 'img2video') ? 'type-image' : 'type-text';
          var typeLabel = (m.type === 'image' || m.type === 'img2video') ? 'Image' : 'Text';
          var qualClass = m.quality === 'premium' ? 'quality-premium' : (m.quality === 'high' ? 'quality-high' : 'quality-standard');
          var qualLabel = m.quality ? (m.quality.charAt(0).toUpperCase() + m.quality.slice(1)) : 'Standard';
          var credits = m.credits || m.creditCost || 1;
          modelCreditMap[m.id || m.value || m.name] = credits;

          var card = document.createElement('div');
          card.className = 'model-card-option' + (idx === 0 ? ' selected' : '');
          card.setAttribute('data-model', m.id || m.value || m.name);
          card.setAttribute('data-type', m.type || 'text');
          card.setAttribute('data-credits', credits);
          card.innerHTML =
            '<div class="model-card-check"><i class="fa-solid fa-check"></i></div>' +
            '<div class="model-name">' +
              '<i class="fa-solid ' + ((m.type === 'image' || m.type === 'img2video') ? 'fa-image' : 'fa-font') + '" style="font-size: 12px; color: rgba(255,255,255,0.3);"></i> ' +
              (m.name || m.id || m.value) +
            '</div>' +
            '<div class="model-meta">' +
              '<span class="model-type-badge ' + typeClass + '">' + typeLabel + '</span>' +
              '<span class="model-credit-badge"><i class="fa-solid fa-coins" style="margin-right: 3px;"></i>' + credits + ' cr</span>' +
              '<span class="model-quality-badge ' + qualClass + '">' + qualLabel + '</span>' +
            '</div>';
          card.addEventListener('click', function() {
            document.querySelectorAll('.model-card-option').forEach(function(c) { c.classList.remove('selected'); });
            card.classList.add('selected');
            selectedModel = card.getAttribute('data-model');
            document.getElementById('modelSelect').value = selectedModel;
            updateCreditCost();
            toggleImageUrl();
          });
          grid.appendChild(card);

          if (idx === 0) {
            selectedModel = m.id || m.value || m.name;
            document.getElementById('modelSelect').value = selectedModel;
          }
        });
        updateCreditCost();
        toggleImageUrl();
      }

      fetch('/api/videos/models', { headers: { 'Authorization': 'Bearer ' + token } })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var models = data.models || data || [];
          if (!Array.isArray(models) || models.length === 0) models = fallbackModels;
          allModels = models;
          renderModelCards(models);
        })
        .catch(function() {
          allModels = fallbackModels;
          renderModelCards(fallbackModels);
        });

      function updateCreditCost() {
        var sel = document.querySelector('.model-card-option.selected');
        var cost = sel ? sel.getAttribute('data-credits') : 1;
        document.getElementById('creditCostText').textContent = cost + ' credit' + (cost > 1 ? 's' : '');
      }

      // Show/hide image URL for image-to-video models
      var imageUrlRow = document.getElementById('imageUrlRow');
      function toggleImageUrl() {
        var sel = document.querySelector('.model-card-option.selected');
        var mtype = sel ? sel.getAttribute('data-type') : 'text';
        if (mtype === 'image' || mtype === 'img2video' || (selectedModel && selectedModel.indexOf('image') !== -1)) {
          imageUrlRow.classList.add('visible');
        } else {
          imageUrlRow.classList.remove('visible');
        }
      }

      // Image dropzone
      var imgDz = document.getElementById('imageDropzone');
      var imgFi = document.getElementById('imageFileInput');
      var imgPrev = document.getElementById('imagePreviewThumb');
      var imgUrl = document.getElementById('imageUrl');
      if (imgDz && imgFi) {
        imgDz.addEventListener('click', function() { imgFi.click(); });
        imgDz.addEventListener('dragover', function(e) { e.preventDefault(); imgDz.style.borderColor = 'rgba(102,126,234,0.5)'; imgDz.style.background = 'rgba(102,126,234,0.05)'; });
        imgDz.addEventListener('dragleave', function() { imgDz.style.borderColor = 'rgba(255,255,255,0.12)'; imgDz.style.background = 'rgba(255,255,255,0.02)'; });
        imgDz.addEventListener('drop', function(e) {
          e.preventDefault();
          imgDz.style.borderColor = 'rgba(255,255,255,0.12)';
          imgDz.style.background = 'rgba(255,255,255,0.02)';
          if (e.dataTransfer.files.length) handleImageFile(e.dataTransfer.files[0]);
        });
        imgFi.addEventListener('change', function() { if (this.files.length) handleImageFile(this.files[0]); });
      }
      function handleImageFile(file) {
        var reader = new FileReader();
        reader.onload = function(e) {
          imgPrev.src = e.target.result;
          imgPrev.style.display = 'block';
          imgUrl.value = e.target.result;
        };
        reader.readAsDataURL(file);
      }

      // Option buttons
      document.querySelectorAll('.option-group').forEach(function(group) {
        group.querySelectorAll('.option-btn').forEach(function(btn) {
          btn.addEventListener('click', function() {
            group.querySelectorAll('.option-btn').forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
          });
        });
      });

      // Char counter
      var promptEl = document.getElementById('prompt');
      promptEl.addEventListener('input', function() {
        document.getElementById('charCount').textContent = this.value.length;
      });

      function getSelectedValue(groupId) {
        var active = document.querySelector('#' + groupId + ' .option-btn.active');
        return active ? active.getAttribute('data-value') : null;
      }

      // --- Prompt Enhancer ---
      document.getElementById('btnEnhance').addEventListener('click', function() {
        var promptVal = promptEl.value.trim();
        if (!promptVal) return alert('Please enter a prompt first.');

        var btn = this;
        btn.disabled = true;
        document.getElementById('enhanceSpinner').style.display = 'inline-block';
        document.getElementById('enhanceIcon').style.display = 'none';

        fetch('/api/videos/enhance-prompt', {
          method: 'POST',
          headers: headers,
          body: JSON.stringify({ prompt: promptVal })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          btn.disabled = false;
          document.getElementById('enhanceSpinner').style.display = 'none';
          document.getElementById('enhanceIcon').style.display = 'inline';

          var enhanced = data.enhancedPrompt || data.enhanced || data.prompt || '';
          if (enhanced) {
            document.getElementById('enhancedText').textContent = enhanced;
            document.getElementById('enhancePreview').style.display = 'block';
          } else {
            alert('Could not enhance prompt. Try again.');
          }
        })
        .catch(function() {
          btn.disabled = false;
          document.getElementById('enhanceSpinner').style.display = 'none';
          document.getElementById('enhanceIcon').style.display = 'inline';
          alert('Failed to enhance prompt. Please try again.');
        });
      });

      document.getElementById('btnUseEnhanced').addEventListener('click', function() {
        var enhanced = document.getElementById('enhancedText').textContent;
        if (enhanced) {
          promptEl.value = enhanced;
          document.getElementById('charCount').textContent = enhanced.length;
        }
        document.getElementById('enhancePreview').style.display = 'none';
      });

      document.getElementById('btnDismissEnhanced').addEventListener('click', function() {
        document.getElementById('enhancePreview').style.display = 'none';
      });

      // Form submit
      document.getElementById('generateForm').addEventListener('submit', function(e) {
        e.preventDefault();
        var promptVal = promptEl.value.trim();
        if (!promptVal) return alert('Please enter a prompt.');

        var model = document.getElementById('modelSelect').value;
        if (!model) return alert('Please select a model.');

        var body = {
          model: model,
          prompt: promptVal,
          duration: getSelectedValue('durationGroup'),
          aspectRatio: getSelectedValue('ratioGroup')
        };

        // Determine type from model
        var selCard = document.querySelector('.model-card-option.selected');
        var mtype = selCard ? selCard.getAttribute('data-type') : 'text';
        if (mtype === 'image' || mtype === 'img2video' || model.indexOf('image') !== -1) {
          body.type = 'image';
          body.imageUrl = document.getElementById('imageUrl').value.trim();
          if (!body.imageUrl) return alert('Please provide an image URL for Image-to-Video.');
        } else {
          body.type = 'text';
        }

        document.getElementById('btnGenerate').disabled = true;
        var section = document.getElementById('statusSection');
        section.style.display = 'block';
        document.getElementById('statusSpinner').style.display = 'block';
        document.getElementById('genStatus').textContent = 'Submitting...';
        document.getElementById('genDetail').textContent = 'Sending request to AI model';
        document.getElementById('videoPreview').style.display = 'none';

        fetch('/api/videos/generate', { method: 'POST', headers: headers, body: JSON.stringify(body) })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.error) {
              alert(data.error);
              section.style.display = 'none';
              document.getElementById('btnGenerate').disabled = false;
              return;
            }
            var videoId = data.video ? data.video._id || data.video.id : data.id || data._id;
            if (videoId) pollStatus(videoId);
          })
          .catch(function(err) {
            alert('Generation failed. Please try again.');
            section.style.display = 'none';
            document.getElementById('btnGenerate').disabled = false;
          });
      });

      function pollStatus(videoId) {
        document.getElementById('genStatus').textContent = 'Processing...';
        document.getElementById('genDetail').textContent = 'Your video is being generated. This may take a few minutes.';

        var interval = setInterval(function() {
          fetch('/api/videos/' + videoId + '/status', { headers: { 'Authorization': 'Bearer ' + token } })
            .then(function(r) { return r.json(); })
            .then(function(data) {
              var status = data.status || (data.video && data.video.status);
              var videoUrl = data.videoUrl || (data.video && data.video.videoUrl);
              if (status === 'completed') {
                clearInterval(interval);
                document.getElementById('genStatus').textContent = 'Complete!';
                document.getElementById('genDetail').textContent = 'Your video is ready.';
                document.getElementById('statusSpinner').style.display = 'none';
                document.getElementById('btnGenerate').disabled = false;
                if (videoUrl) {
                  var preview = document.getElementById('videoPreview');
                  preview.src = videoUrl;
                  preview.style.display = 'block';
                }
                fetch('/api/auth/profile', { headers: { 'Authorization': 'Bearer ' + token } })
                  .then(function(r) { return r.json(); })
                  .then(function(d) {
                    if (d.user && d.user.credits != null) {
                      document.getElementById('sidebarCredits').textContent = d.user.credits;
                    }
                  });
              } else if (status === 'failed') {
                clearInterval(interval);
                document.getElementById('genStatus').textContent = 'Failed';
                document.getElementById('genDetail').textContent = data.error || 'Video generation failed. Please try again.';
                document.getElementById('statusSpinner').style.display = 'none';
                document.getElementById('btnGenerate').disabled = false;
              } else {
                document.getElementById('genStatus').textContent = 'Processing...';
              }
            });
        }, 3000);
      }
    })();
  </script>
</body>
</html>
