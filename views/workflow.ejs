<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <%- include('partials/head') %>
  <title>Workflow Editor - KRSN</title>
  <style>
    /* ── Workflow Toolbar ── */
    .workflow-toolbar {
      height: 50px;
      background: rgba(18,18,18,0.9);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255,255,255,0.08);
      display: flex;
      align-items: center;
      padding: 0 16px;
      gap: 8px;
      z-index: 100;
      flex-shrink: 0;
      box-shadow: 0 2px 12px rgba(0,0,0,0.3);
    }
    .workflow-toolbar .toolbar-title {
      font-size: 16px;
      font-weight: 800;
      color: #fff;
      margin-right: 16px;
      white-space: nowrap;
    }
    .toolbar-divider {
      width: 1px;
      height: 24px;
      background: rgba(255,255,255,0.08);
      margin: 0 4px;
      flex-shrink: 0;
    }
    .toolbar-spacer { flex: 1; }
    .wf-toolbar-btn {
      padding: 7px 14px;
      border-radius: 8px;
      font-size: 12px;
      font-weight: 600;
      border: 1px solid rgba(255,255,255,0.12);
      background: rgba(255,255,255,0.06);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      color: rgba(255,255,255,0.75);
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: all 0.2s ease;
      white-space: nowrap;
      font-family: 'Manrope', sans-serif;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
    }
    .wf-toolbar-btn:hover {
      background: rgba(255,255,255,0.12);
      border-color: rgba(255,255,255,0.2);
      color: #fff;
      box-shadow: 0 0 12px rgba(255,255,255,0.05), inset 0 1px 0 rgba(255,255,255,0.1);
    }
    .wf-toolbar-btn.primary {
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.2);
      color: #fff;
    }
    .wf-toolbar-btn.primary:hover {
      background: rgba(255,255,255,0.18);
    }
    .wf-toolbar-btn.primary:hover {
      filter: brightness(1.15);
    }
    .wf-toolbar-btn.success {
      background: rgba(39,174,96,0.15);
      border-color: rgba(39,174,96,0.3);
      color: #27ae60;
    }
    .wf-toolbar-btn.success:hover {
      background: rgba(39,174,96,0.25);
      color: #2ecc71;
    }
    .wf-toolbar-btn.danger {
      background: rgba(231,76,60,0.1);
      border-color: rgba(231,76,60,0.2);
      color: rgba(231,76,60,0.7);
    }
    .wf-toolbar-btn.danger:hover {
      background: rgba(231,76,60,0.2);
      color: #e74c3c;
    }

    /* ── Add Node Dropdown ── */
    .add-node-wrapper {
      position: relative;
    }
    .add-node-dropdown {
      position: absolute;
      top: calc(100% + 6px);
      left: 0;
      width: 240px;
      background: #1a1a3e;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      box-shadow: 0 12px 40px rgba(0,0,0,0.5);
      z-index: 500;
      display: none;
      overflow: hidden;
    }
    .add-node-dropdown.open {
      display: block;
    }
    .add-node-dropdown .dropdown-category {
      padding: 8px 14px 4px;
      font-size: 10px;
      color: rgba(255,255,255,0.3);
      text-transform: uppercase;
      font-weight: 700;
      letter-spacing: 1px;
    }
    .add-node-dropdown .dropdown-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 14px;
      cursor: grab;
      transition: background 0.1s;
      font-size: 13px;
      color: rgba(255,255,255,0.8);
      font-family: 'Manrope', sans-serif;
      user-select: none;
    }
    .add-node-dropdown .dropdown-item:hover {
      background: rgba(255,255,255,0.05);
    }
    .add-node-dropdown .dropdown-item:active {
      cursor: grabbing;
    }
    .add-node-dropdown .dropdown-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    /* ── Canvas Container ── */
    .workflow-canvas-wrap {
      flex: 1;
      position: relative;
      overflow: hidden;
    }

    /* ── Properties Panel ── */
    .properties-panel {
      position: fixed;
      top: 0;
      right: -340px;
      width: 340px;
      height: 100vh;
      background: #12122a;
      border-left: 1px solid rgba(255,255,255,0.08);
      transition: right 0.3s ease;
      z-index: 1100;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      font-family: 'Manrope', sans-serif;
    }
    .properties-panel.open {
      right: 0;
    }
    .properties-panel .pp-header {
      padding: 16px 20px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }
    .properties-panel .pp-header .pp-title {
      font-size: 14px;
      font-weight: 700;
      color: #fff;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .properties-panel .pp-header .pp-color-bar {
      width: 4px;
      height: 20px;
      border-radius: 2px;
    }
    .properties-panel .pp-close {
      width: 28px;
      height: 28px;
      border-radius: 6px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      color: rgba(255,255,255,0.5);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      transition: all 0.15s;
    }
    .properties-panel .pp-close:hover {
      background: rgba(255,255,255,0.1);
      color: #fff;
    }
    .properties-panel .pp-body {
      flex: 1;
      padding: 16px 20px;
      overflow-y: auto;
    }
    .pp-section-title {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: rgba(255,255,255,0.3);
      font-weight: 700;
      margin: 16px 0 8px;
    }
    .pp-section-title:first-child { margin-top: 0; }
    .pp-field { margin-bottom: 12px; }
    .pp-field label {
      display: block;
      font-size: 11px;
      color: rgba(255,255,255,0.5);
      margin-bottom: 4px;
      font-weight: 600;
    }
    .pp-field input,
    .pp-field select,
    .pp-field textarea {
      width: 100%;
      box-sizing: border-box;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 8px;
      color: #fff;
      font-size: 12px;
      padding: 8px 12px;
      outline: none;
      font-family: 'Manrope', sans-serif;
    }
    .pp-field input:focus,
    .pp-field select:focus,
    .pp-field textarea:focus {
      border-color: rgba(102,126,234,0.5);
    }
    .pp-field textarea {
      min-height: 80px;
      resize: vertical;
    }
    .pp-field select option {
      background: #1a1a3e;
    }
    .pp-connection-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .pp-connection-list li {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 0;
      font-size: 12px;
      color: rgba(255,255,255,0.6);
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .pp-connection-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .pp-run-section {
      padding: 16px 20px;
      border-top: 1px solid rgba(255,255,255,0.06);
      flex-shrink: 0;
    }
    .pp-run-btn {
      width: 100%;
      padding: 10px;
      background: linear-gradient(135deg, #667eea, #764ba2);
      border: none;
      border-radius: 8px;
      color: #fff;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      font-family: 'Manrope', sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: filter 0.15s;
    }
    .pp-run-btn:hover { filter: brightness(1.15); }
    .pp-credit-info {
      text-align: center;
      font-size: 11px;
      color: rgba(245,158,11,0.7);
      margin-top: 6px;
    }
    .pp-delete-btn {
      width: 100%;
      padding: 8px;
      background: rgba(231,76,60,0.1);
      border: 1px solid rgba(231,76,60,0.2);
      border-radius: 8px;
      color: rgba(231,76,60,0.7);
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      font-family: 'Manrope', sans-serif;
      margin-top: 8px;
      transition: all 0.15s;
    }
    .pp-delete-btn:hover {
      background: rgba(231,76,60,0.2);
      color: #e74c3c;
    }

    /* ── Zoom display ── */
    .zoom-display {
      font-size: 11px;
      color: rgba(255,255,255,0.4);
      min-width: 40px;
      text-align: center;
      font-weight: 600;
      font-variant-numeric: tabular-nums;
    }

    /* ── Scrollbar styling ── */
    .properties-panel::-webkit-scrollbar {
      width: 4px;
    }
    .properties-panel::-webkit-scrollbar-track {
      background: transparent;
    }
    .properties-panel::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.1);
      border-radius: 2px;
    }

    /* ── Toast notifications ── */
    .wf-toast-container {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 3000;
      display: flex;
      flex-direction: column;
      gap: 8px;
      align-items: center;
      pointer-events: none;
    }
    .wf-toast {
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 12px;
      font-weight: 600;
      color: #fff;
      background: rgba(30,30,60,0.95);
      border: 1px solid rgba(255,255,255,0.1);
      box-shadow: 0 4px 20px rgba(0,0,0,0.4);
      animation: toastIn 0.25s ease-out;
      font-family: 'Manrope', sans-serif;
    }
    .wf-toast.success { border-color: rgba(39,174,96,0.3); }
    .wf-toast.error { border-color: rgba(231,76,60,0.3); }
    @keyframes toastIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body style="margin:0; padding:0; overflow:hidden; background:#0a0a14; font-family:'Manrope',sans-serif;">
  <%- include('partials/sidebar') %>

  <div class="dash-main" style="margin-left:260px; height:100vh; display:flex; flex-direction:column; overflow:hidden;">

    <!-- ═══════ Toolbar ═══════ -->
    <div class="workflow-toolbar">
      <a href="/workflows" class="wf-toolbar-btn" title="Back to projects" style="text-decoration:none;">
        <i class="fa-solid fa-arrow-left"></i>
      </a>
      <span class="toolbar-title"><i class="fa-solid fa-diagram-project" style="margin-right:6px;"></i> Workflow</span>
      <div class="toolbar-divider"></div>

      <!-- Add Node -->
      <div class="add-node-wrapper">
        <button class="wf-toolbar-btn primary" id="btnAddNode">
          <i class="fa-solid fa-plus"></i> Add Node
        </button>
        <div class="add-node-dropdown" id="addNodeDropdown" style="max-height:480px;overflow-y:auto;">
          <div class="dropdown-category">Text</div>
          <div class="dropdown-item" data-type="prompt"><span class="dropdown-dot" style="background:#9b59b6;"></span> Prompt</div>
          <div class="dropdown-item" data-type="prompt-enhancer"><span class="dropdown-dot" style="background:#8e44ad;"></span> Prompt Enhancer</div>
          <div class="dropdown-item" data-type="prompt-concat"><span class="dropdown-dot" style="background:#7d3c98;"></span> Prompt Concatenator</div>
          <div class="dropdown-item" data-type="run-llm"><span class="dropdown-dot" style="background:#6c3483;"></span> Run LLM</div>
          <div class="dropdown-category">Input</div>
          <div class="dropdown-item" data-type="image-input"><span class="dropdown-dot" style="background:#27ae60;"></span> Image Input</div>
          <div class="dropdown-item" data-type="video-input"><span class="dropdown-dot" style="background:#e74c3c;"></span> Video Input</div>
          <div class="dropdown-category">Image Generation</div>
          <div class="dropdown-item" data-type="text-to-image"><span class="dropdown-dot" style="background:#2ecc71;"></span> Text to Image</div>
          <div class="dropdown-item" data-type="image-to-image"><span class="dropdown-dot" style="background:#2ecc71;"></span> Image to Image</div>
          <div class="dropdown-category">Video Generation</div>
          <div class="dropdown-item" data-type="text-to-video"><span class="dropdown-dot" style="background:#e74c3c;"></span> Text to Video</div>
          <div class="dropdown-item" data-type="image-to-video"><span class="dropdown-dot" style="background:#c0392b;"></span> Image to Video</div>
          <div class="dropdown-item" data-type="video-to-video"><span class="dropdown-dot" style="background:#c0392b;"></span> Video to Video</div>
          <div class="dropdown-category">Editing Tools</div>
          <div class="dropdown-item" data-type="upscale"><span class="dropdown-dot" style="background:#3498db;"></span> Upscale</div>
          <div class="dropdown-item" data-type="inpaint"><span class="dropdown-dot" style="background:#2980b9;"></span> Inpaint</div>
          <div class="dropdown-item" data-type="outpaint"><span class="dropdown-dot" style="background:#2980b9;"></span> Outpaint</div>
          <div class="dropdown-item" data-type="blur"><span class="dropdown-dot" style="background:#3498db;"></span> Blur</div>
          <div class="dropdown-item" data-type="crop"><span class="dropdown-dot" style="background:#3498db;"></span> Crop</div>
          <div class="dropdown-item" data-type="relight"><span class="dropdown-dot" style="background:#2471a3;"></span> Relight</div>
          <div class="dropdown-item" data-type="remove-bg"><span class="dropdown-dot" style="background:#3498db;"></span> Remove Background</div>
          <div class="dropdown-item" data-type="depth-map"><span class="dropdown-dot" style="background:#2980b9;"></span> Depth Map</div>
          <div class="dropdown-item" data-type="describe-image"><span class="dropdown-dot" style="background:#5b2c6f;"></span> Describe Image</div>
          <div class="dropdown-category">Control</div>
          <div class="dropdown-item" data-type="controlnet"><span class="dropdown-dot" style="background:#f39c12;"></span> ControlNet</div>
          <div class="dropdown-item" data-type="lora"><span class="dropdown-dot" style="background:#d4ac0d;"></span> LoRA</div>
          <div class="dropdown-category">Utility</div>
          <div class="dropdown-item" data-type="video-merge"><span class="dropdown-dot" style="background:#16a085;"></span> Merge Videos</div>
          <div class="dropdown-item" data-type="layer-composite"><span class="dropdown-dot" style="background:#17a2b8;"></span> Layer Composite</div>
          <div class="dropdown-item" data-type="compare"><span class="dropdown-dot" style="background:#95a5a6;"></span> Compare</div>
          <div class="dropdown-item" data-type="router"><span class="dropdown-dot" style="background:#7f8c8d;"></span> Router</div>
          <div class="dropdown-item" data-type="preview"><span class="dropdown-dot" style="background:#95a5a6;"></span> Preview</div>
          <div class="dropdown-item" data-type="sticky-note"><span class="dropdown-dot" style="background:#f1c40f;"></span> Sticky Note</div>
          <div class="dropdown-category">Output</div>
          <div class="dropdown-item" data-type="video-output"><span class="dropdown-dot" style="background:#1abc9c;"></span> Export Video</div>
          <div class="dropdown-item" data-type="image-output"><span class="dropdown-dot" style="background:#1abc9c;"></span> Export Image</div>
        </div>
      </div>

      <div class="toolbar-divider"></div>

      <button class="wf-toolbar-btn success" id="btnRunAll" title="Run entire workflow">
        <i class="fa-solid fa-play"></i> Run All
      </button>
      <button class="wf-toolbar-btn" id="btnSave" title="Export workflow (Ctrl+S)">
        <i class="fa-solid fa-floppy-disk"></i> Save
      </button>
      <button class="wf-toolbar-btn" id="btnLoad" title="Import workflow">
        <i class="fa-solid fa-folder-open"></i> Load
      </button>

      <div class="toolbar-spacer"></div>

      <button class="wf-toolbar-btn" id="btnZoomOut" title="Zoom Out">
        <i class="fa-solid fa-minus"></i>
      </button>
      <span class="zoom-display" id="zoomDisplay">100%</span>
      <button class="wf-toolbar-btn" id="btnZoomIn" title="Zoom In">
        <i class="fa-solid fa-plus"></i>
      </button>
      <button class="wf-toolbar-btn" id="btnFitView" title="Fit all nodes in view">
        <i class="fa-solid fa-expand"></i>
      </button>
      <div class="toolbar-divider"></div>
      <button class="wf-toolbar-btn danger" id="btnClear" title="Clear canvas">
        <i class="fa-solid fa-trash-can"></i> Clear
      </button>
    </div>

    <!-- ═══════ Canvas ═══════ -->
    <div id="workflowCanvas" class="workflow-canvas-wrap"></div>

    <!-- ═══════ Properties Panel ═══════ -->
    <div id="propertiesPanel" class="properties-panel">
      <div class="pp-header">
        <div class="pp-title">
          <span class="pp-color-bar" id="ppColorBar"></span>
          <span id="ppNodeName">Node</span>
        </div>
        <button class="pp-close" id="ppClose" title="Close"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="pp-body" id="ppBody">
        <!-- Populated dynamically -->
      </div>
      <div class="pp-run-section" id="ppRunSection" style="display:none;">
        <button class="pp-run-btn" id="ppRunBtn">
          <i class="fa-solid fa-play"></i> Run This Node
        </button>
        <div class="pp-credit-info" id="ppCreditInfo"></div>
      </div>
    </div>
  </div>

  <!-- ═══════ Toast Container ═══════ -->
  <div class="wf-toast-container" id="toastContainer"></div>

  <!-- Hidden file input for load -->
  <input type="file" id="fileLoadInput" accept=".json" style="display:none;">

  <script src="/public/js/workflow.js"></script>
  <script>
  (function() {
    'use strict';

    // ── Auth guard ──
    var token = localStorage.getItem('token');
    if (!token) { window.location.href = '/login'; return; }

    // ── Read workflow ID from URL ──
    var urlParams = new URLSearchParams(window.location.search);
    var workflowId = urlParams.get('id');

    // ── Toast helper ──
    function toast(msg, type) {
      var c = document.getElementById('toastContainer');
      if (!c) return;
      var t = document.createElement('div');
      t.className = 'wf-toast ' + (type || '');
      t.textContent = msg;
      c.appendChild(t);
      setTimeout(function() { t.style.opacity = '0'; t.style.transition = 'opacity 0.3s'; }, 2200);
      setTimeout(function() { t.remove(); }, 2600);
    }

    // ── Initialize canvas ──
    var canvas = new WorkflowCanvas('workflowCanvas');
    window._wfCanvas = canvas;

    // ── Immediate save function ──
    function saveNow() {
      if (!workflowId || !canvas.nodes.size) return;
      var workflowData = JSON.parse(canvas.exportWorkflow());
      navigator.sendBeacon('/api/workflows/' + workflowId + '/save?token=' + token,
        new Blob([JSON.stringify({ data: workflowData })], { type: 'application/json' })
      );
    }

    // ── Override auto-save to save to server ──
    var originalAutoSave = canvas._autoSave.bind(canvas);
    canvas._autoSave = function() {
      originalAutoSave();
      if (workflowId) {
        clearTimeout(canvas._serverSaveTimer);
        canvas._serverSaveTimer = setTimeout(function() {
          var workflowData = JSON.parse(canvas.exportWorkflow());
          fetch('/api/workflows/' + workflowId, {
            method: 'PUT',
            headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
            body: JSON.stringify({ data: workflowData })
          }).catch(function() {});
        }, 800);
      }
    };

    // ── Save on exit (page unload, tab close, navigate away) ──
    window.addEventListener('beforeunload', function() { saveNow(); });
    window.addEventListener('pagehide', function() { saveNow(); });

    // ── Save immediately when clicking any sidebar link ──
    document.querySelectorAll('.dash-sidebar a, a[href="/workflows"]').forEach(function(link) {
      link.addEventListener('click', function() {
        if (workflowId && canvas.nodes.size) {
          var workflowData = JSON.parse(canvas.exportWorkflow());
          fetch('/api/workflows/' + workflowId, {
            method: 'PUT',
            headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
            body: JSON.stringify({ data: workflowData })
          }).catch(function() {});
        }
      });
    });

    // ── Zoom display sync ──
    var zoomEl = document.getElementById('zoomDisplay');
    function syncZoom() {
      if (zoomEl) zoomEl.textContent = Math.round(canvas.zoom * 100) + '%';
      requestAnimationFrame(syncZoom);
    }
    syncZoom();

    // ── Add Node dropdown ──
    var btnAdd = document.getElementById('btnAddNode');
    var dropdown = document.getElementById('addNodeDropdown');

    btnAdd.addEventListener('click', function(e) {
      e.stopPropagation();
      dropdown.classList.toggle('open');
    });
    document.addEventListener('click', function(e) {
      if (!e.target.closest('.add-node-wrapper')) {
        dropdown.classList.remove('open');
      }
    });

    // ── Custom drag-and-drop (mousedown/mousemove/mouseup) ──
    var dragGhost = document.createElement('div');
    dragGhost.style.cssText = 'position:fixed;pointer-events:none;z-index:99999;padding:10px 18px;border-radius:10px;font-size:13px;font-weight:700;color:#fff;backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,0.2);box-shadow:0 8px 32px rgba(0,0,0,0.6);display:none;white-space:nowrap;transform:translate(-50%,-50%);';
    document.body.appendChild(dragGhost);

    var dragNodeType = null;
    var dragStartX = 0, dragStartY = 0;
    var isDragging = false;
    var hasDragged = false;

    dropdown.querySelectorAll('.dropdown-item').forEach(function(item) {
      item.style.cursor = 'grab';
      item.style.userSelect = 'none';

      item.addEventListener('mousedown', function(e) {
        if (e.button !== 0) return;
        e.preventDefault();
        dragNodeType = item.getAttribute('data-type');
        dragStartX = e.clientX;
        dragStartY = e.clientY;
        isDragging = true;
        hasDragged = false;

        var dot = item.querySelector('.dropdown-dot');
        var color = dot ? dot.style.background : 'rgba(102,126,234,0.85)';
        dragGhost.textContent = item.textContent.trim();
        dragGhost.style.background = color;
      });
    });

    document.addEventListener('mousemove', function(e) {
      if (!isDragging) return;
      var dx = e.clientX - dragStartX;
      var dy = e.clientY - dragStartY;

      // Start showing ghost after 5px of movement
      if (!hasDragged && (Math.abs(dx) > 5 || Math.abs(dy) > 5)) {
        hasDragged = true;
        dragGhost.style.display = 'block';
        dropdown.classList.remove('open');
      }

      if (hasDragged) {
        dragGhost.style.left = e.clientX + 'px';
        dragGhost.style.top = e.clientY + 'px';
      }
    });

    document.addEventListener('mouseup', function(e) {
      if (!isDragging) return;
      isDragging = false;
      dragGhost.style.display = 'none';

      if (!hasDragged) {
        // Was a click, not a drag — use original click behavior
        var type = dragNodeType;
        dragNodeType = null;
        if (!type) return;

        var rect = canvas.container.getBoundingClientRect();
        var cx = (rect.width / 2 - canvas.pan.x) / canvas.zoom;
        var cy = (rect.height / 2 - canvas.pan.y) / canvas.zoom;
        cx += (Math.random() - 0.5) * 80;
        cy += (Math.random() - 0.5) * 80;

        if (typeof MODEL_CATALOG !== 'undefined' && MODEL_CATALOG[type]) {
          dropdown.classList.remove('open');
          canvas._showModelPicker(type, cx, cy);
        } else {
          var id = canvas.addNode(type, cx, cy);
          dropdown.classList.remove('open');
          toast(NODE_TYPES[type].label + ' added');
          canvas.selectedNodes.clear();
          canvas.selectedNodes.add(id);
          canvas._updateSelectionVisuals();
        }
        return;
      }

      // Was a drag — check if dropped on canvas
      var type = dragNodeType;
      dragNodeType = null;
      if (!type) return;

      var canvasRect = canvas.container.getBoundingClientRect();
      var inCanvas = e.clientX >= canvasRect.left && e.clientX <= canvasRect.right &&
                     e.clientY >= canvasRect.top && e.clientY <= canvasRect.bottom;

      if (inCanvas) {
        var pos = canvas._screenToCanvas(e.clientX, e.clientY);
        if (typeof MODEL_CATALOG !== 'undefined' && MODEL_CATALOG[type]) {
          canvas._showModelPicker(type, pos.x, pos.y);
        } else {
          var id = canvas.addNode(type, pos.x, pos.y);
          toast(NODE_TYPES[type].label + ' added');
          canvas.selectedNodes.clear();
          canvas.selectedNodes.add(id);
          canvas._updateSelectionVisuals();
        }
      } else {
        toast('Drop on the canvas to add node', 'error');
      }
    });

    // ── Load workflow from server ──
    if (workflowId) {
      fetch('/api/workflows/' + workflowId, {
        headers: { 'Authorization': 'Bearer ' + token }
      })
      .then(function(r) { return r.json(); })
      .then(function(res) {
        if (res.workflow && res.workflow.data) {
          canvas.importWorkflow(res.workflow.data);
          // If no saved pan/zoom, fit all nodes into view
          if (!res.workflow.data.pan && !res.workflow.data.zoom) {
            canvas.fitView();
          }
          // Update toolbar title to show workflow name
          var titleEl = document.querySelector('.toolbar-title');
          if (titleEl) titleEl.innerHTML = '<i class="fa-solid fa-diagram-project" style="margin-right:6px;"></i> ' + (res.workflow.name || 'Workflow');
          // Make title editable on double-click
          if (titleEl) {
            titleEl.style.cursor = 'pointer';
            titleEl.addEventListener('dblclick', function() {
              var currentName = res.workflow.name || 'Untitled';
              var newName = prompt('Rename workflow:', currentName);
              if (newName && newName !== currentName) {
                fetch('/api/workflows/' + workflowId, {
                  method: 'PUT',
                  headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
                  body: JSON.stringify({ name: newName })
                }).then(function() {
                  titleEl.innerHTML = '<i class="fa-solid fa-diagram-project" style="margin-right:6px;"></i> ' + newName;
                  res.workflow.name = newName;
                  toast('Renamed to "' + newName + '"');
                });
              }
            });
          }
        }
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            canvas.render();
            toast('Workflow loaded');
          });
        });
      });
    } else {
      // No ID — redirect to workflows dashboard
      window.location.href = '/workflows';
    }

    // ── Run All ──
    document.getElementById('btnRunAll').addEventListener('click', function() {
      if (canvas.nodes.size === 0) {
        toast('No nodes on canvas', 'error');
        return;
      }
      toast('Running workflow...');
      canvas.runWorkflow().then(function(results) {
        toast('Workflow complete!', 'success');
        console.log('[Workflow] Results:', results);
      }).catch(function(err) {
        toast('Workflow error: ' + err.message, 'error');
      });
    });

    // ── Save to server ──
    document.getElementById('btnSave').addEventListener('click', function() {
      if (!workflowId) { toast('No workflow loaded', 'error'); return; }
      var btn = this;
      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';
      var workflowData = JSON.parse(canvas.exportWorkflow());
      fetch('/api/workflows/' + workflowId, {
        method: 'PUT',
        headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
        body: JSON.stringify({ data: workflowData })
      })
      .then(function() { toast('Saved!', 'success'); })
      .catch(function() { toast('Save failed', 'error'); })
      .finally(function() {
        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Save';
      });
    });

    // ── Load (import) ──
    document.getElementById('btnLoad').addEventListener('click', function() {
      document.getElementById('fileLoadInput').click();
    });
    document.getElementById('fileLoadInput').addEventListener('change', function(e) {
      if (!e.target.files.length) return;
      var reader = new FileReader();
      reader.onload = function(ev) {
        try {
          canvas.importWorkflow(ev.target.result);
          toast('Workflow loaded', 'success');
        } catch (err) {
          toast('Invalid workflow file', 'error');
        }
      };
      reader.readAsText(e.target.files[0]);
      e.target.value = '';
    });

    // ── Clear ──
    document.getElementById('btnClear').addEventListener('click', function() {
      if (canvas.nodes.size === 0) return;
      if (!confirm('Clear all nodes and connections?')) return;
      canvas.nodes.forEach(function(n) { if (n.el && n.el.parentNode) n.el.parentNode.removeChild(n.el); });
      canvas.nodes.clear();
      canvas.connections = [];
      canvas.selectedNodes.clear();
      canvas.render();
      closeProperties();
      toast('Canvas cleared');
    });

    // ── Zoom controls ──
    document.getElementById('btnZoomIn').addEventListener('click', function() {
      canvas.zoom = Math.min(3, canvas.zoom + 0.15);
      canvas._updateTransform();
      canvas._drawGrid();
      canvas.render();
    });
    document.getElementById('btnZoomOut').addEventListener('click', function() {
      canvas.zoom = Math.max(0.25, canvas.zoom - 0.15);
      canvas._updateTransform();
      canvas._drawGrid();
      canvas.render();
    });
    document.getElementById('btnFitView').addEventListener('click', function() {
      canvas.fitView();
    });

    // ── Keyboard shortcut: Ctrl+S ──
    document.addEventListener('keydown', function(e) {
      if ((e.ctrlKey || e.metaKey) && e.key === 's') {
        e.preventDefault();
        document.getElementById('btnSave').click();
      }
    });

    // ── Properties Panel ──
    var panel = document.getElementById('propertiesPanel');
    var ppBody = document.getElementById('ppBody');
    var ppRunSection = document.getElementById('ppRunSection');
    var ppCreditInfo = document.getElementById('ppCreditInfo');
    var currentPropNodeId = null;

    document.getElementById('ppClose').addEventListener('click', closeProperties);

    function closeProperties() {
      panel.classList.remove('open');
      currentPropNodeId = null;
    }

    function showProperties(nodeId) {
      var node = canvas.nodes.get(nodeId);
      if (!node) { closeProperties(); return; }
      var def = NODE_TYPES[node.type];
      if (!def) { closeProperties(); return; }

      currentPropNodeId = nodeId;

      // Header
      document.getElementById('ppColorBar').style.background = def.color;
      document.getElementById('ppNodeName').textContent = def.label;

      // Build body
      ppBody.innerHTML = '';

      // Parameters
      if (def.params && def.params.length) {
        var title = document.createElement('div');
        title.className = 'pp-section-title';
        title.textContent = 'Parameters';
        ppBody.appendChild(title);

        def.params.forEach(function(p) {
          var field = document.createElement('div');
          field.className = 'pp-field';
          var lbl = document.createElement('label');
          lbl.textContent = p.name;
          field.appendChild(lbl);

          var input;
          if (p.type === 'textarea') {
            input = document.createElement('textarea');
            input.placeholder = p.placeholder || '';
            input.value = node.values[p.name] || '';
          } else if (p.type === 'select') {
            input = document.createElement('select');
            (p.options || []).forEach(function(opt) {
              var o = document.createElement('option');
              o.value = opt; o.textContent = opt;
              if (node.values[p.name] === opt) o.selected = true;
              input.appendChild(o);
            });
          } else {
            input = document.createElement('input');
            input.type = 'text';
            input.placeholder = p.placeholder || '';
            input.value = node.values[p.name] || '';
          }

          input.addEventListener('input', function() {
            node.values[p.name] = this.value;
            // Sync inline param on node card
            var inlineInput = node.el.querySelector('[data-param-name="' + p.name + '"]');
            if (inlineInput) inlineInput.value = this.value;
          });
          field.appendChild(input);
          ppBody.appendChild(field);
        });
      }

      // Connections info
      var inConns = canvas.connections.filter(function(c) { return c.toNode === nodeId; });
      var outConns = canvas.connections.filter(function(c) { return c.fromNode === nodeId; });

      if (inConns.length || outConns.length) {
        var connTitle = document.createElement('div');
        connTitle.className = 'pp-section-title';
        connTitle.textContent = 'Connections';
        ppBody.appendChild(connTitle);

        if (inConns.length) {
          var inLbl = document.createElement('div');
          inLbl.style.cssText = 'font-size:10px;color:rgba(255,255,255,0.3);margin-bottom:4px;';
          inLbl.textContent = 'Inputs';
          ppBody.appendChild(inLbl);
          var ul = document.createElement('ul');
          ul.className = 'pp-connection-list';
          inConns.forEach(function(c) {
            var li = document.createElement('li');
            var dot = document.createElement('span');
            dot.className = 'pp-connection-dot';
            dot.style.background = TYPE_COLORS[c.type] || '#888';
            li.appendChild(dot);
            var fromNode = canvas.nodes.get(c.fromNode);
            var fromLabel = fromNode ? NODE_TYPES[fromNode.type].label : '?';
            li.appendChild(document.createTextNode(fromLabel + '.' + c.fromPort + ' \u2192 ' + c.toPort));
            ul.appendChild(li);
          });
          ppBody.appendChild(ul);
        }
        if (outConns.length) {
          var outLbl = document.createElement('div');
          outLbl.style.cssText = 'font-size:10px;color:rgba(255,255,255,0.3);margin:8px 0 4px;';
          outLbl.textContent = 'Outputs';
          ppBody.appendChild(outLbl);
          var ul2 = document.createElement('ul');
          ul2.className = 'pp-connection-list';
          outConns.forEach(function(c) {
            var li = document.createElement('li');
            var dot = document.createElement('span');
            dot.className = 'pp-connection-dot';
            dot.style.background = TYPE_COLORS[c.type] || '#888';
            li.appendChild(dot);
            var toNode = canvas.nodes.get(c.toNode);
            var toLabel = toNode ? NODE_TYPES[toNode.type].label : '?';
            li.appendChild(document.createTextNode(c.fromPort + ' \u2192 ' + toLabel + '.' + c.toPort));
            ul2.appendChild(li);
          });
          ppBody.appendChild(ul2);
        }
      }

      // Node ID
      var idInfo = document.createElement('div');
      idInfo.style.cssText = 'margin-top:16px;font-size:10px;color:rgba(255,255,255,0.15);';
      idInfo.textContent = 'Node ID: ' + nodeId;
      ppBody.appendChild(idInfo);

      // Delete button
      var delBtn = document.createElement('button');
      delBtn.className = 'pp-delete-btn';
      delBtn.innerHTML = '<i class="fa-solid fa-trash-can" style="margin-right:6px;"></i> Delete Node';
      delBtn.addEventListener('click', function() {
        canvas.removeNode(nodeId);
        closeProperties();
        toast('Node deleted');
      });
      ppBody.appendChild(delBtn);

      // Run section (AI nodes only)
      if (def.aiNode) {
        ppRunSection.style.display = 'block';
        ppCreditInfo.textContent = 'This node uses AI credits to run';
      } else {
        ppRunSection.style.display = 'none';
      }

      panel.classList.add('open');
    }

    // Run button in properties panel
    document.getElementById('ppRunBtn').addEventListener('click', function() {
      if (currentPropNodeId == null) return;
      toast('Running node...');
      canvas.runNode(currentPropNodeId).then(function(result) {
        toast('Node complete!', 'success');
      }).catch(function(err) {
        toast('Node error: ' + err.message, 'error');
      });
    });

    // ── Listen for node selection via click ──
    // The WorkflowCanvas selects nodes internally; poll selectedNodes
    var lastSelectedStr = '';
    function pollSelection() {
      var ids = Array.from(canvas.selectedNodes);
      var str = ids.join(',');
      if (str !== lastSelectedStr) {
        lastSelectedStr = str;
        if (ids.length === 1) {
          showProperties(ids[0]);
        } else {
          closeProperties();
        }
      }
      requestAnimationFrame(pollSelection);
    }
    pollSelection();

  })();
  </script>
</body>
</html>
