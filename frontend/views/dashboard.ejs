<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - VideoForge AI</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/vendor/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="/assets/fonts/bootstrap-icons-1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/assets/fonts/font-awesome-6.4.2/css/all.css">
  <link rel="stylesheet" href="/assets/fonts/gordita/stylesheet.css">
  <link rel="stylesheet" href="/assets/css/style.css">
  <link rel="stylesheet" href="/css/custom.css">
</head>
<body class="dark-bg-two">
<div class="dashboard-wrapper d-flex">
  <%- include('partials/sidebar', { active: 'dashboard' }) %>

  <button class="sidebar-toggle d-lg-none" id="sidebarToggle">
    <i class="bi bi-list fs-24"></i>
  </button>

  <main class="dashboard-main flex-grow-1">
    <div class="dashboard-header d-flex align-items-center justify-content-between p-25">
      <div>
        <h4 class="font-manrope fw-600 text-white m0">Dashboard</h4>
        <p class="fs-14 opacity-50 m0 mt-5">Welcome back! Here's your overview.</p>
      </div>
      <a href="/generate" class="btn-three tran3s fs-14" style="line-height: 44px; padding: 0 25px;">
        <i class="bi bi-plus-lg me-1"></i> New Video
      </a>
    </div>

    <div class="dashboard-content p-25">
      <div class="row g-4 mb-30">
        <div class="col-lg-3 col-sm-6">
          <div class="stat-card bg-wrapper border-20 p-25">
            <div class="d-flex align-items-center justify-content-between mb-15">
              <div class="stat-icon" style="width:45px;height:45px;background:rgba(138,66,255,0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-coin" style="color:#8A42FF;"></i>
              </div>
              <span class="fs-12 opacity-40">Credits</span>
            </div>
            <div class="stat-value font-manrope fw-600 text-white fs-28" id="dashCredits">--</div>
            <div class="fs-13 opacity-40 mt-5">Available credits</div>
          </div>
        </div>
        <div class="col-lg-3 col-sm-6">
          <div class="stat-card bg-wrapper border-20 p-25">
            <div class="d-flex align-items-center justify-content-between mb-15">
              <div class="stat-icon" style="width:45px;height:45px;background:rgba(105,238,198,0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-play-circle" style="color:#69EEC6;"></i>
              </div>
              <span class="fs-12 opacity-40">Videos</span>
            </div>
            <div class="stat-value font-manrope fw-600 text-white fs-28" id="dashTotalVideos">--</div>
            <div class="fs-13 opacity-40 mt-5">Total generated</div>
          </div>
        </div>
        <div class="col-lg-3 col-sm-6">
          <div class="stat-card bg-wrapper border-20 p-25">
            <div class="d-flex align-items-center justify-content-between mb-15">
              <div class="stat-icon" style="width:45px;height:45px;background:rgba(255,75,216,0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-hourglass-split" style="color:#FF4BD8;"></i>
              </div>
              <span class="fs-12 opacity-40">Processing</span>
            </div>
            <div class="stat-value font-manrope fw-600 text-white fs-28" id="dashProcessing">--</div>
            <div class="fs-13 opacity-40 mt-5">In progress</div>
          </div>
        </div>
        <div class="col-lg-3 col-sm-6">
          <div class="stat-card bg-wrapper border-20 p-25">
            <div class="d-flex align-items-center justify-content-between mb-15">
              <div class="stat-icon" style="width:45px;height:45px;background:rgba(225,255,45,0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-check-circle" style="color:#E1FF2D;"></i>
              </div>
              <span class="fs-12 opacity-40">Completed</span>
            </div>
            <div class="stat-value font-manrope fw-600 text-white fs-28" id="dashCompleted">--</div>
            <div class="fs-13 opacity-40 mt-5">Ready to download</div>
          </div>
        </div>
      </div>

      <div class="bg-wrapper border-20 p-25">
        <div class="d-flex align-items-center justify-content-between mb-25">
          <h5 class="font-manrope fw-600 text-white m0 fs-18">Recent Videos</h5>
          <a href="/videos" class="fs-14 tran3s" style="color:#8A42FF;">View All <i class="bi bi-arrow-right"></i></a>
        </div>
        <div class="table-responsive">
          <table class="table vf-table">
            <thead>
              <tr>
                <th>Prompt</th>
                <th>Model</th>
                <th>Status</th>
                <th>Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="dashRecentVideos">
              <tr>
                <td colspan="5" class="text-center opacity-40 py-4">
                  <i class="bi bi-camera-video fs-28 d-block mb-10"></i>
                  Loading videos...
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>

<script src="/assets/vendor/jquery.min.js"></script>
<script src="/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="/js/app.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    VideoForge.requireAuth();
    VideoForge.loadDashboard();
  });
</script>
</body>
</html>
