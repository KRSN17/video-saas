<aside class="dashboard-sidebar" id="sidebar">
  <div class="sidebar-inner">
    <div class="sidebar-logo p-25">
      <a href="/" class="d-flex align-items-center">
        <span class="fs-22 fw-600 text-white font-manrope">VideoForge</span>
        <span class="badge bg-seven ms-2 fs-12">AI</span>
      </a>
    </div>

    <nav class="sidebar-nav mt-20">
      <ul class="style-none">
        <li class="nav-section-title fs-12 text-uppercase opacity-40 px-25 mb-10 letter-spacing-2">Main</li>
        <li>
          <a href="/dashboard" class="sidebar-link<%= typeof active !== 'undefined' && active === 'dashboard' ? ' active' : '' %>">
            <i class="bi bi-grid-1x2"></i>
            <span>Dashboard</span>
          </a>
        </li>
        <li>
          <a href="/generate" class="sidebar-link<%= typeof active !== 'undefined' && active === 'generate' ? ' active' : '' %>">
            <i class="bi bi-stars"></i>
            <span>Generate Video</span>
          </a>
        </li>
        <li>
          <a href="/videos" class="sidebar-link<%= typeof active !== 'undefined' && active === 'videos' ? ' active' : '' %>">
            <i class="bi bi-play-circle"></i>
            <span>My Videos</span>
          </a>
        </li>
        <li>
          <a href="/merge" class="sidebar-link<%= typeof active !== 'undefined' && active === 'merge' ? ' active' : '' %>">
            <i class="bi bi-layers"></i>
            <span>Merge Videos</span>
          </a>
        </li>

        <li class="nav-section-title fs-12 text-uppercase opacity-40 px-25 mb-10 mt-25 letter-spacing-2">Account</li>
        <li>
          <a href="/credits" class="sidebar-link<%= typeof active !== 'undefined' && active === 'credits' ? ' active' : '' %>">
            <i class="bi bi-coin"></i>
            <span>Buy Credits</span>
          </a>
        </li>
        <li>
          <a href="#" class="sidebar-link" onclick="event.preventDefault();">
            <i class="bi bi-gear"></i>
            <span>Settings</span>
          </a>
        </li>
      </ul>
    </nav>

    <div class="sidebar-credits mx-20 mt-auto">
      <div class="credit-card bg-wrapper border-20 p-20 text-center">
        <div class="fs-12 text-uppercase opacity-50 mb-5 letter-spacing-2">Credit Balance</div>
        <div class="credit-amount font-manrope fw-600 text-white" id="sidebarCredits" style="font-size: 32px;">--</div>
        <a href="/credits" class="btn-three tran3s w-100 fs-14 mt-15" style="line-height: 40px;">Buy Credits</a>
      </div>
    </div>

    <div class="sidebar-user p-20 mt-20">
      <div class="d-flex align-items-center gap-10">
        <div class="user-avatar">
          <i class="bi bi-person-circle fs-28 text-white opacity-50"></i>
        </div>
        <div class="flex-grow-1">
          <div class="fs-14 fw-500 text-white" id="sidebarUserName">User</div>
          <div class="fs-12 opacity-40" id="sidebarUserEmail">user@email.com</div>
        </div>
        <button class="btn p-0" onclick="VideoForge.logout()" title="Logout">
          <i class="bi bi-box-arrow-right fs-18 text-white opacity-50 tran3s"></i>
        </button>
      </div>
    </div>
  </div>
</aside>
