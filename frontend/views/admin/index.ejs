<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel - VideoForge AI</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/vendor/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="/assets/fonts/bootstrap-icons-1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/assets/fonts/font-awesome-6.4.2/css/all.css">
  <link rel="stylesheet" href="/assets/fonts/gordita/stylesheet.css">
  <link rel="stylesheet" href="/assets/css/style.css">
  <link rel="stylesheet" href="/css/custom.css">
</head>
<body class="dark-bg-two">
<div class="dashboard-wrapper d-flex">
  <!-- Admin Sidebar -->
  <aside class="dashboard-sidebar" id="sidebar">
    <div class="sidebar-inner">
      <div class="sidebar-logo p-25">
        <a href="/" class="d-flex align-items-center">
          <span class="fs-22 fw-600 text-white font-manrope">VideoForge</span>
          <span class="badge bg-danger ms-2 fs-10">ADMIN</span>
        </a>
      </div>
      <nav class="sidebar-nav mt-20">
        <ul class="style-none">
          <li class="nav-section-title fs-12 text-uppercase opacity-40 px-25 mb-10 letter-spacing-2">Admin</li>
          <li>
            <a href="/admin" class="sidebar-link active">
              <i class="bi bi-speedometer2"></i>
              <span>Overview</span>
            </a>
          </li>
          <li>
            <a href="/admin#users" class="sidebar-link" onclick="VideoForge.adminTab('users')">
              <i class="bi bi-people"></i>
              <span>Users</span>
            </a>
          </li>
          <li>
            <a href="/admin#videos" class="sidebar-link" onclick="VideoForge.adminTab('videos')">
              <i class="bi bi-play-circle"></i>
              <span>Videos</span>
            </a>
          </li>
          <li>
            <a href="/admin#credits" class="sidebar-link" onclick="VideoForge.adminTab('credits')">
              <i class="bi bi-coin"></i>
              <span>Credit Packages</span>
            </a>
          </li>
          <li class="nav-section-title fs-12 text-uppercase opacity-40 px-25 mb-10 mt-25 letter-spacing-2">Navigation</li>
          <li>
            <a href="/dashboard" class="sidebar-link">
              <i class="bi bi-arrow-left"></i>
              <span>Back to App</span>
            </a>
          </li>
        </ul>
      </nav>
      <div class="sidebar-user p-20 mt-auto">
        <div class="d-flex align-items-center gap-10">
          <i class="bi bi-shield-check fs-22" style="color: #FF4BD8;"></i>
          <div class="flex-grow-1">
            <div class="fs-14 fw-500 text-white">Admin</div>
            <div class="fs-12 opacity-40" id="adminEmail">admin@email.com</div>
          </div>
          <button class="btn p-0" onclick="VideoForge.logout()" title="Logout">
            <i class="bi bi-box-arrow-right fs-18 text-white opacity-50"></i>
          </button>
        </div>
      </div>
    </div>
  </aside>

  <button class="sidebar-toggle d-lg-none" id="sidebarToggle">
    <i class="bi bi-list fs-24"></i>
  </button>

  <main class="dashboard-main flex-grow-1">
    <div class="dashboard-header p-25">
      <h4 class="font-manrope fw-600 text-white m0">Admin Dashboard</h4>
      <p class="fs-14 opacity-50 m0 mt-5">Platform overview and management</p>
    </div>

    <div class="dashboard-content p-25">
      <!-- Stats -->
      <div class="row g-4 mb-30">
        <div class="col-lg-3 col-sm-6">
          <div class="stat-card bg-wrapper border-20 p-25">
            <div class="d-flex align-items-center justify-content-between mb-15">
              <div class="stat-icon" style="width:45px;height:45px;background:rgba(138,66,255,0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-people" style="color:#8A42FF;"></i>
              </div>
            </div>
            <div class="stat-value font-manrope fw-600 text-white fs-28" id="adminTotalUsers">--</div>
            <div class="fs-13 opacity-40 mt-5">Total Users</div>
          </div>
        </div>
        <div class="col-lg-3 col-sm-6">
          <div class="stat-card bg-wrapper border-20 p-25">
            <div class="d-flex align-items-center justify-content-between mb-15">
              <div class="stat-icon" style="width:45px;height:45px;background:rgba(105,238,198,0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-play-circle" style="color:#69EEC6;"></i>
              </div>
            </div>
            <div class="stat-value font-manrope fw-600 text-white fs-28" id="adminTotalVideos">--</div>
            <div class="fs-13 opacity-40 mt-5">Videos Generated</div>
          </div>
        </div>
        <div class="col-lg-3 col-sm-6">
          <div class="stat-card bg-wrapper border-20 p-25">
            <div class="d-flex align-items-center justify-content-between mb-15">
              <div class="stat-icon" style="width:45px;height:45px;background:rgba(255,75,216,0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-coin" style="color:#FF4BD8;"></i>
              </div>
            </div>
            <div class="stat-value font-manrope fw-600 text-white fs-28" id="adminCreditsUsed">--</div>
            <div class="fs-13 opacity-40 mt-5">Credits Used</div>
          </div>
        </div>
        <div class="col-lg-3 col-sm-6">
          <div class="stat-card bg-wrapper border-20 p-25">
            <div class="d-flex align-items-center justify-content-between mb-15">
              <div class="stat-icon" style="width:45px;height:45px;background:rgba(225,255,45,0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-currency-dollar" style="color:#E1FF2D;"></i>
              </div>
            </div>
            <div class="stat-value font-manrope fw-600 text-white fs-28" id="adminRevenue">--</div>
            <div class="fs-13 opacity-40 mt-5">Total Revenue</div>
          </div>
        </div>
      </div>

      <!-- Recent Users -->
      <div class="bg-wrapper border-20 p-25 mb-30" id="adminUsersSection">
        <div class="d-flex align-items-center justify-content-between mb-25">
          <h5 class="font-manrope fw-600 text-white m0 fs-18">Recent Users</h5>
        </div>
        <div class="table-responsive">
          <table class="table vf-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Credits</th>
                <th>Videos</th>
                <th>Joined</th>
                <th>Role</th>
              </tr>
            </thead>
            <tbody id="adminUsersTable">
              <tr>
                <td colspan="6" class="text-center opacity-40 py-4">Loading...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Recent Videos -->
      <div class="bg-wrapper border-20 p-25 mb-30" id="adminVideosSection">
        <div class="d-flex align-items-center justify-content-between mb-25">
          <h5 class="font-manrope fw-600 text-white m0 fs-18">Recent Videos</h5>
        </div>
        <div class="table-responsive">
          <table class="table vf-table">
            <thead>
              <tr>
                <th>User</th>
                <th>Prompt</th>
                <th>Model</th>
                <th>Status</th>
                <th>Credits</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody id="adminVideosTable">
              <tr>
                <td colspan="6" class="text-center opacity-40 py-4">Loading...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Credit Package Management -->
      <div class="bg-wrapper border-20 p-25" id="adminCreditsSection">
        <div class="d-flex align-items-center justify-content-between mb-25">
          <h5 class="font-manrope fw-600 text-white m0 fs-18">Credit Packages</h5>
          <button class="btn-three tran3s fs-13" style="line-height: 36px; padding: 0 18px;" onclick="VideoForge.showAddPackageModal()">
            <i class="bi bi-plus-lg me-1"></i> Add Package
          </button>
        </div>
        <div class="table-responsive">
          <table class="table vf-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Credits</th>
                <th>Price</th>
                <th>Per Credit</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="adminPackagesTable">
              <tr>
                <td>Starter</td>
                <td>50</td>
                <td>$9.00</td>
                <td>$0.18</td>
                <td><span class="status-badge status-completed">Active</span></td>
                <td>
                  <button class="btn fs-12 text-white opacity-50 tran3s p-0"><i class="bi bi-pencil"></i></button>
                </td>
              </tr>
              <tr>
                <td>Pro</td>
                <td>200</td>
                <td>$29.00</td>
                <td>$0.145</td>
                <td><span class="status-badge status-completed">Active</span></td>
                <td>
                  <button class="btn fs-12 text-white opacity-50 tran3s p-0"><i class="bi bi-pencil"></i></button>
                </td>
              </tr>
              <tr>
                <td>Enterprise</td>
                <td>600</td>
                <td>$79.00</td>
                <td>$0.13</td>
                <td><span class="status-badge status-completed">Active</span></td>
                <td>
                  <button class="btn fs-12 text-white opacity-50 tran3s p-0"><i class="bi bi-pencil"></i></button>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>

<script src="/assets/vendor/jquery.min.js"></script>
<script src="/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="/js/app.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    VideoForge.requireAuth();
    VideoForge.loadAdmin();
  });
</script>
</body>
</html>
