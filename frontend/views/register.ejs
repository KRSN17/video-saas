<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register - VideoForge AI</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/vendor/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="/assets/fonts/bootstrap-icons-1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/assets/fonts/gordita/stylesheet.css">
  <link rel="stylesheet" href="/assets/css/style.css">
  <link rel="stylesheet" href="/css/custom.css">
</head>
<body class="dark-bg-two">
<div class="main-page-wrapper d-flex align-items-center justify-content-center" style="min-height: 100vh; padding: 40px 0;">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-5 col-md-7">
        <div class="text-center mb-40">
          <a href="/" class="d-inline-flex align-items-center mb-30">
            <span class="fs-28 fw-600 text-white font-manrope">VideoForge</span>
            <span class="badge bg-seven ms-2 fs-14">AI</span>
          </a>
          <h4 class="font-manrope fw-600 text-white">Create Your Account</h4>
          <p class="fs-16 opacity-50 mt-10">Start creating AI videos in minutes</p>
        </div>

        <div class="auth-card bg-wrapper border-20 p-40">
          <div id="register-error" class="alert alert-danger d-none fs-14" role="alert"></div>
          <div id="register-success" class="alert alert-success d-none fs-14" role="alert"></div>

          <form id="registerForm" novalidate>
            <div class="mb-25">
              <label class="fs-14 fw-500 text-white mb-10">Full Name</label>
              <input type="text" name="name" class="form-control vf-input" placeholder="John Doe" required>
            </div>
            <div class="mb-25">
              <label class="fs-14 fw-500 text-white mb-10">Email Address</label>
              <input type="email" name="email" class="form-control vf-input" placeholder="you@example.com" required>
            </div>
            <div class="mb-25">
              <label class="fs-14 fw-500 text-white mb-10">Password</label>
              <div class="position-relative">
                <input type="password" name="password" class="form-control vf-input" placeholder="Min 8 characters" required minlength="8">
                <button type="button" class="password-toggle" onclick="togglePassword(this)">
                  <i class="bi bi-eye"></i>
                </button>
              </div>
            </div>
            <div class="mb-25">
              <label class="fs-14 fw-500 text-white mb-10">Confirm Password</label>
              <div class="position-relative">
                <input type="password" name="confirmPassword" class="form-control vf-input" placeholder="Re-enter password" required>
                <button type="button" class="password-toggle" onclick="togglePassword(this)">
                  <i class="bi bi-eye"></i>
                </button>
              </div>
            </div>
            <div class="mb-25 d-flex align-items-start gap-2">
              <input type="checkbox" id="terms" class="form-check-input vf-check mt-5" required>
              <label for="terms" class="fs-14 opacity-75 m0">I agree to the <a href="#" style="color: #8A42FF;">Terms of Service</a> and <a href="#" style="color: #8A42FF;">Privacy Policy</a></label>
            </div>
            <button type="submit" class="btn-three tran3s w-100 fw-500 fs-18" id="registerBtn">
              Create Account
            </button>
          </form>

          <div class="text-center mt-25">
            <p class="fs-14 opacity-50">Already have an account? <a href="/login" style="color: #8A42FF;" class="fw-500">Sign in</a></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/assets/vendor/jquery.min.js"></script>
<script src="/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="/js/app.js"></script>
</body>
</html>
