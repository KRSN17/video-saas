<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Credits - VideoForge AI</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/vendor/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="/assets/fonts/bootstrap-icons-1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/assets/fonts/font-awesome-6.4.2/css/all.css">
  <link rel="stylesheet" href="/assets/fonts/gordita/stylesheet.css">
  <link rel="stylesheet" href="/assets/css/style.css">
  <link rel="stylesheet" href="/css/custom.css">
</head>
<body class="dark-bg-two">
<div class="dashboard-wrapper d-flex">
  <%- include('partials/sidebar', { active: 'credits' }) %>

  <button class="sidebar-toggle d-lg-none" id="sidebarToggle">
    <i class="bi bi-list fs-24"></i>
  </button>

  <main class="dashboard-main flex-grow-1">
    <div class="dashboard-header p-25">
      <h4 class="font-manrope fw-600 text-white m0">Credits</h4>
      <p class="fs-14 opacity-50 m0 mt-5">Purchase credits and view transaction history</p>
    </div>

    <div class="dashboard-content p-25">
      <!-- Current Balance -->
      <div class="bg-wrapper border-20 p-30 mb-30 text-center" style="background: linear-gradient(135deg, rgba(138,66,255,0.1) 0%, rgba(255,75,216,0.05) 100%);">
        <div class="fs-14 text-uppercase opacity-40 letter-spacing-2 mb-10">Current Balance</div>
        <div class="font-manrope fw-600 text-white mb-5" style="font-size: 72px; letter-spacing: -3px;" id="creditBalance">--</div>
        <div class="fs-16 opacity-50">credits available</div>
      </div>

      <!-- Credit Packages -->
      <div class="mb-40">
        <h5 class="font-manrope fw-600 text-white mb-25 fs-18">Buy Credits</h5>
        <div class="row g-4">
          <!-- Starter -->
          <div class="col-lg-4 col-md-6">
            <div class="credit-package bg-wrapper border-20 p-30 text-center h-100 tran3s">
              <div class="fs-12 text-uppercase letter-spacing-2 mb-15" style="color: #8A42FF;">STARTER</div>
              <div class="font-manrope fw-600 text-white mb-5" style="font-size: 42px;">$9</div>
              <div class="fs-16 opacity-50 mb-5">50 Credits</div>
              <div class="fs-13 opacity-30 mb-25">$0.18 per credit</div>
              <button class="btn-four tran3s w-100" onclick="VideoForge.buyCredits('starter')">
                Purchase
              </button>
            </div>
          </div>
          <!-- Pro -->
          <div class="col-lg-4 col-md-6">
            <div class="credit-package bg-wrapper border-20 p-30 text-center h-100 tran3s pricing-popular position-relative">
              <div class="popular-badge">BEST VALUE</div>
              <div class="fs-12 text-uppercase letter-spacing-2 mb-15" style="color: #FF4BD8;">PRO</div>
              <div class="font-manrope fw-600 text-white mb-5" style="font-size: 42px;">$29</div>
              <div class="fs-16 opacity-50 mb-5">200 Credits</div>
              <div class="fs-13 opacity-30 mb-25">$0.145 per credit</div>
              <button class="btn-three tran3s w-100" onclick="VideoForge.buyCredits('pro')">
                Purchase
              </button>
            </div>
          </div>
          <!-- Enterprise -->
          <div class="col-lg-4 col-md-6">
            <div class="credit-package bg-wrapper border-20 p-30 text-center h-100 tran3s">
              <div class="fs-12 text-uppercase letter-spacing-2 mb-15" style="color: #E1FF2D;">ENTERPRISE</div>
              <div class="font-manrope fw-600 text-white mb-5" style="font-size: 42px;">$79</div>
              <div class="fs-16 opacity-50 mb-5">600 Credits</div>
              <div class="fs-13 opacity-30 mb-25">$0.13 per credit</div>
              <button class="btn-four tran3s w-100" onclick="VideoForge.buyCredits('enterprise')">
                Purchase
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Transaction History -->
      <div class="bg-wrapper border-20 p-25">
        <h5 class="font-manrope fw-600 text-white mb-25 fs-18">Transaction History</h5>
        <div class="table-responsive">
          <table class="table vf-table">
            <thead>
              <tr>
                <th>Date</th>
                <th>Type</th>
                <th>Description</th>
                <th>Amount</th>
                <th>Balance</th>
              </tr>
            </thead>
            <tbody id="transactionHistory">
              <tr>
                <td colspan="5" class="text-center opacity-40 py-4">
                  <i class="bi bi-clock-history fs-28 d-block mb-10"></i>
                  Loading transactions...
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>

<script src="/assets/vendor/jquery.min.js"></script>
<script src="/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="/js/app.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    VideoForge.requireAuth();
    VideoForge.loadCredits();
  });
</script>
</body>
</html>
